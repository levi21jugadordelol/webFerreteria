---

import { siteInfo } from '../const/site-info.ts';
import NavBar from '../components/sections/navBar.astro';
import Header from "../components/sections/Header.astro"
import Body from '../components/sections/Body.astro';
import Footer from "../components/sections/Footer.astro"


interface Props{
  title ?:string;
  description?:string;
  image?:string
}

const {
  title = siteInfo.title,
  description=siteInfo.description,
  image
}=Astro.props
---


<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

     <!-- SEO -->
     <meta name="description" content={description} />
     <meta name="author" content={'saul rodriguez'} />

         <!-- OG METATAGS -->
      <meta property="og:title" content={title} />
      <meta property="og:description" content={description} />
      <meta property="og:image" content={image} />


		<title>{title}</title>

		<!-- Bootstrap CSS desde CDN -->
		<link 
			href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
			rel="stylesheet" 
			integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" 
			crossorigin="anonymous">

    <!-- iconos de fontwsone -->
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A=="
      crossorigin="anonymous" referrerpolicy="no-referrer" />

	</head>
	<body>

  <NavBar />

  <Header />
  <Body />
  <Footer />

  <!-- ⬇⬇ AGREGAR AQUÍ EL BOTÓN DE WHATSAPP ⬇⬇ -->
  <a 
    href="https://wa.me/51987654321"
    class="whatsapp-float"
    target="_blank"
    rel="noopener noreferrer"
  >
    <i class="fa-brands fa-whatsapp"></i>
  </a>

  <!-- Estilo del WhatsApp, aislado -->
  <style>
    .whatsapp-float {
      position: fixed;
      bottom: 22px;
      right: 22px;
      width: 62px;
      height: 62px;
      background: #25D366;
      border-radius: 50%;
      color: white !important;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 28px; /* tamaño normal */
      box-shadow: 0 4px 10px rgba(0,0,0,0.2);
      z-index: 5000;
    }

    .whatsapp-float:hover {
      transform: scale(1.05);
    }
  </style>
  <!-- ⬆⬆ FIN DEL BOTÓN DE WHATSAPP ⬆⬆ -->

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
    crossorigin="anonymous"
    is:inline>
  </script>
</body>

</html>