---
import Formulario from "../components/shared/Form.astro";

// 🔗 Backend
const API_URL = "http://localhost:3000";

// 🧠 Defaults seguros
let siteContent = {
  title: "Login de Administrador",
  description: "Panel de administración",
};

let image = undefined;

// 🌐 Fetch site settings
try {
  const res = await fetch(`${API_URL}/api/site-settings`);
  if (res.ok) {
    const settings = await res.json();

    if (settings.site_content) {
      siteContent = {
        ...siteContent,
        ...settings.site_content,
      };
    }
  }
} catch (error) {
  console.error("❌ Error cargando site-settings:", error);
}

// 👉 valores finales
const title = siteContent.title;
const description = siteContent.description;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <meta name="description" content={description} />
    <meta name="author" content="saul rodriguez" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}

    <title>{title}</title>

    <!-- Bootstrap CSS -->
    <link 
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      crossorigin="anonymous"
    />

    <!-- Font Awesome -->
    <link 
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
  </head>

  <body>
    <!-- ✅ AQUÍ debe ir el formulario -->
    <Formulario />

    <!-- Bootstrap JS -->
    <script 
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      crossorigin="anonymous"
      is:inline
    ></script>
  </body>
</html>
