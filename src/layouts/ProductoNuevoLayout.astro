---
import { siteInfo } from "../const/site-info.ts";
import ProductoForm from "../components/shared/ProductoForm.astro";

const {
  title = siteInfo.title,
  description = siteInfo.description,
  image,
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <meta name="description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- FilePond -->
    <link href="https://unpkg.com/filepond/dist/filepond.min.css" rel="stylesheet" />
    <script src="https://unpkg.com/filepond/dist/filepond.min.js" defer></script>

    <!-- Variable global API -->
    <script is:inline>
      window.API_URL = "http://localhost:3000";
    </script>
  </head>

  <body>
    <div class="container my-5">
      <h1 class="fw-bold mb-4">{title}</h1>
      <ProductoForm />
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="/js/filepondProducto.js" defer></script>
  </body>
</html>



