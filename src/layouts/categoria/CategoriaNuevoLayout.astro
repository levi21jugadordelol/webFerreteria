---
import CategoriaForm from "../../components/shared/categoria/CategoriaForm.astro";

const API_URL = "http://localhost:3000";

let siteContent = {
  title: "Nueva Categoría",
  description: "Crear nueva categoría",
};

try {
  const res = await fetch(`${API_URL}/api/site-settings`);
  if (res.ok) {
    const settings = await res.json();
    if (settings.site_content) {
      siteContent = {
        ...siteContent,
        ...settings.site_content,
      };
    }
  }
} catch (error) {
  console.error(error);
}

const title = siteContent.title;
---

<div class="container my-5">
  <h1 class="fw-bold mb-4">{title}</h1>
  <CategoriaForm />
</div>

<!-- 🔥 PASAR API -->
<script is:inline>
  window.API_URL = "http://localhost:3000";
</script>

<!-- 🔥 FILEPOND (IMPORTANTE COMPLETO) -->
<link href="https://unpkg.com/filepond/dist/filepond.min.css" rel="stylesheet" />
<script src="https://unpkg.com/filepond/dist/filepond.min.js"></script>

<!-- 🔥 TU SCRIPT -->
<script type="module" src="/js/categorias/categorias.page.js"></script>




