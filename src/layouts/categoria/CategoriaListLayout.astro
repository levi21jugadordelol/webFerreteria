---
import CategoriaList from "../../components/shared/categoria/CategoriaList.astro";

// 🔗 Backend
import { API_URL, BACKEND_URL } from "../../config/api";

// 🧠 Defaults
let siteContent = {
  title: "Listado de Categorías",
  description: "Administración de categorías",
};

let image = undefined;

// 🌐 Fetch CMS
try {
  const res = await fetch(`${API_URL}/site-settings`);
  if (res.ok) {
    const settings = await res.json();

    if (settings.site_content) {
      siteContent = {
        ...siteContent,
        ...settings.site_content,
      };
    }
  }
} catch (error) {
  console.error("Error cargando site-settings:", error);
}

const title = siteContent.title;
const description = siteContent.description;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <script is:inline define:vars={{ BACKEND_URL }}>
  window.API_URL = BACKEND_URL;
</script>
  </head>

  <body>
    <div class="container my-5">
      <h1 class="fw-bold mb-4">{title}</h1>
      <CategoriaList />
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </body>
</html>
