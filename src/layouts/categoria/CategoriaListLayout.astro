---
import CategoriaList from "../../components/shared/categoria/CategoriaList.astro";

// 🔗 Backend
const API_URL = "http://localhost:3000";

// 🧠 Defaults
let siteContent = {
  title: "Listado de Categorías",
  description: "Administración de categorías",
};

let image = undefined;

// 🌐 Fetch CMS
try {
  const res = await fetch(`${API_URL}/api/site-settings`);
  if (res.ok) {
    const settings = await res.json();

    if (settings.site_content) {
      siteContent = {
        ...siteContent,
        ...settings.site_content,
      };
    }
  }
} catch (error) {
  console.error("Error cargando site-settings:", error);
}

const title = siteContent.title;
const description = siteContent.description;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <meta name="description" content={description} />
    {image && <meta property="og:image" content={image} />}

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link href="https://unpkg.com/filepond/dist/filepond.min.css" rel="stylesheet" />
    <script src="https://unpkg.com/filepond/dist/filepond.min.js" defer></script>

    <script is:inline>
      window.API_URL = "http://localhost:3000";
    </script>
  </head>

  <body>
    <div class="container my-5">
      <h1 class="fw-bold mb-4">{title}</h1>
      <CategoriaList />
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="/js/filepondCategoria.js" defer></script>
  </body>
</html>
