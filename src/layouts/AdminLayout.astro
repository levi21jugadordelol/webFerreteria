---
const { title = "Panel Admin" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
    />


    
  </head>

  <body class="bg-gray-100 d-flex">
    <aside class="bg-dark text-white p-3 d-flex flex-column sidebar-admin">

  <h4 class="text-center mb-4 fw-bold">Admin</h4>

  <nav class="nav flex-column gap-2 flex-grow-1">

<!-- PRINCIPAL -->
<small class="text-uppercase text-secondary">Principal</small>

<a href="/admin/panel-admin" class="nav-link text-white">
 🏠 Inicio
</a>

<hr class="border-secondary opacity-25" />

<!-- CATÁLOGO -->
<small class="text-uppercase text-secondary">Catálogo</small>

<a href="/admin/productos" class="nav-link text-white">
 <i class="bi bi-box"></i> Productos
</a>

<a href="/admin/productos/producto-nuevo" class="nav-link text-white">
 <i class="bi bi-plus-square"></i> Nuevo Producto
</a>


<a href="/admin/productos/tabs" class="nav-link text-white">
 <i class="bi bi-ui-checks"></i> Tabs de producto
</a>

<a href="/admin/categoria-lista" class="nav-link text-white">
 <i class="bi bi-tags"></i> Categorías
</a>

<a href="/admin/marcas/marca-lista" class="nav-link text-white">
 <i class="bi bi-award"></i> Marcas
</a>



<hr class="border-secondary opacity-25" />

<!-- VENTAS -->
<small class="text-uppercase text-secondary">Ventas</small>

<a href="/admin/pagos/comprobantes" class="nav-link text-white">
 <i class="bi bi-receipt"></i> Comprobantes
</a>

<a href="/admin/auditoria/pagos" class="nav-link text-white">
 <i class="bi bi-clock-history"></i> Auditoría
</a>

<hr class="border-secondary opacity-25" />

<!-- CONTENIDO -->
<small class="text-uppercase text-secondary">Contenido</small>

<a href="/admin/hero" class="nav-link text-white">
  <i class="bi bi-images"></i> Hero Carrusel
</a>


<a href="/admin/hero-triple" class="nav-link text-white">
  <i class="bi bi-layout-three-columns"></i> Hero Triple
</a>


<a href="/admin/paginas/lista" class="nav-link text-white">
 <i class="bi bi-file-text"></i> Páginas
</a>

<a href="/admin/menu/lista" class="nav-link text-white">
 <i class="bi bi-list"></i> Menú
</a>

<hr class="border-secondary opacity-25" />



<!-- CONFIGURACIÓN -->
<small class="text-uppercase text-secondary">Configuración</small>

<div class="ms-2">

  <a href="/admin/configuracion/general" class="nav-link text-white">
    <i class="bi bi-sliders"></i> General
  </a>

  <a href="/admin/configuracion/footer" class="nav-link text-white">
    <i class="bi bi-layout-text-window"></i> Footer
  </a>

</div>

</nav>

  <!-- LOGOUT -->
  <div class="mt-auto">

    <hr class="border-secondary opacity-25" />

    <div class="mt-auto">
  <button id="btnLogout" class="btn btn-danger w-100">
    <i class="bi bi-box-arrow-right"></i> Cerrar sesión
  </button>
</div>

  </div>

</aside>

    <main class="flex-grow-1 p-4">
      <h2 class="fw-bold mb-4">{title}</h2>
      <slot />
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Logout -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const btnLogout = document.getElementById("btnLogout");

        if (!btnLogout) return;

        btnLogout.addEventListener("click", async () => {
          await fetch("/auth/logout", {
            method: "POST",
            credentials: "include",
          });

          window.location.replace("/admin/login");
        });
      });

      // 🔥 Protección contra botón atrás (bfcache)
    window.addEventListener("pageshow", function (event) {
    if (event.persisted) {
      console.log("🔄 Página cargada desde bfcache, recargando...");
      window.location.reload();
    }
  });
    </script>
  </body>
</html>


<style is:global>

  .nav-link{
  border-radius:8px;
  transition:all .2s;
}

.nav-link:hover{
  background:#343a40;
  padding-left:12px;
}

 .sidebar-admin {
  width: 260px;
  height: 100vh;
  overflow-y: auto;
}
</style>



