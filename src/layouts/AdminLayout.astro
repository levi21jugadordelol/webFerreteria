---
const { title = "Panel Admin", children } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.css"
    />
    <link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
/>

  </head>

  <body class="bg-gray-100 d-flex">
   <aside class="bg-dark text-white p-3" style="width: 250px; height: 100vh;">
  <h3 class="text-center mb-4">Admin</h3>

  <nav class="d-flex flex-column gap-2">

    <a href="/admin/panel-admin" class="text-white text-decoration-none">
      🏠 Inicio
    </a>

    <a href="/admin/productos" class="text-white text-decoration-none">
      <i class="bi bi-box"></i> Productos
    </a>

    <a href="/admin/categoria-lista" class="text-white text-decoration-none">
      <i class="bi bi-tags"></i> Categorías
    </a>

    <a href="/admin/categoria-nueva" class="text-white text-decoration-none">
      <i class="bi bi-plus-lg"></i> Agregar Categoría
    </a>

    <a href="/admin/marcas/marca-lista" class="text-white text-decoration-none">
      <i class="bi bi-bookmark-star"></i> Marcas
    </a>

    <a href="/admin/marcas/marca-nueva" class="text-white text-decoration-none">
      <i class="bi bi-plus-square"></i> Agregar Marca
    </a>

    <a href="/admin/producto-nuevo" class="text-white text-decoration-none">
      <i class="bi bi-plus-circle"></i> Nuevo Producto
    </a>

    <a href="/admin/pagos/comprobantes" class="text-white text-decoration-none">
  <i class="bi bi-receipt"></i> Validar Pagos
</a>


  </nav>
</aside>


   <main class="flex-grow-1 p-4">
  <h2 class="fw-bold mb-4">{title}</h2>
  <slot /> <!-- Aquí se renderiza el contenido que envíes desde productos.astro -->
</main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/min/dropzone.min.js"></script>
  </body>
</html>

