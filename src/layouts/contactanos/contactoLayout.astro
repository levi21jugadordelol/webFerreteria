---

import "../../styles/theme.css";

// 🔗 Backend
const API_URL = "http://localhost:3000";

// 🧠 Defaults seguros
let siteContent = {
  title: "Mi sitio",
  description: "Descripción del sitio",
  whatsapp: "000000000",
};

let appearance = {
  font_base: "Inter",
  font_heading: "Inter",
};

let image = undefined;

// 🌐 Fetch settings
try {
  const res = await fetch(`${API_URL}/api/site-settings`);
  if (res.ok) {
    const settings = await res.json();

    if (settings.site_content) {
      siteContent = { ...siteContent, ...settings.site_content };
    }

    if (settings.appearance) {
      appearance = { ...appearance, ...settings.appearance };
    }
  }
} catch (error) {
  console.error("Error cargando site-settings:", error);
}


console.log("👉 FONT BASE:", appearance.font_base);
console.log("👉 FONT HEADING:", appearance.font_heading);

const title = siteContent.title;
const description = siteContent.description;

// 🎯 Diccionario controlado de fuentes (PMV)
const fontLinks: Record<string, string> = {
  Inter: "https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap",
  Poppins: "https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap",
  Roboto: "https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700&display=swap",
  "Open Sans": "https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&display=swap"
};


const baseFontUrl = fontLinks[appearance.font_base];
const headingFontUrl = fontLinks[appearance.font_heading];




---

<html 
  lang="en"
  data-font-base={appearance.font_base}
  data-font-heading={appearance.font_heading}
>
  <head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- SEO -->
  <meta name="description" content={description} />
  <meta name="author" content="saul rodriguez" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {image && <meta property="og:image" content={image} />}

  <title>{title}</title>

  <!-- Bootstrap -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <!-- Google Fonts -->
  {baseFontUrl && <link rel="stylesheet" href={baseFontUrl} />}
  {headingFontUrl && headingFontUrl !== baseFontUrl && (
    <link rel="stylesheet" href={headingFontUrl} />
  )}

  <!-- Font Awesome -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
</head>



  <body>
    <main>
    <slot />
  </main>

    <script 
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      is:inline
    ></script>
  </body>
</html>