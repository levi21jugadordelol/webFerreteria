---
import ProductoCard from "../../components/ui/tarjetaProducto.astro";
import { BACKEND_URL } from "../../config/api";

interface Producto {
  id_producto: number;
  nombre_producto: string;
  descripcion: string;
  precio: number;
  url_imagen: string | null;
  stock?: number;
  stock_disponible?: number;
}

const apiUrl = BACKEND_URL;

let productos: Producto[] = [];

const getProductImage = (url: string | null) => {
  const value = String(url || "").trim();

  if (!value || value.includes("..")) {
    return "https://via.placeholder.com/300x300?text=Sin+imagen";
  }

  if (value.startsWith("http://") || value.startsWith("https://")) {
    return value;
  }

  return `${BACKEND_URL}/uploads/${value}`;
};

try {
  const res = await fetch(`${apiUrl}/productos`, { cache: "no-store" });

  if (res.ok) {
    productos = await res.json();
  } else {
    console.error("Error al cargar productos:", res.statusText);
  }
} catch (err) {
  console.error("❌ Error de conexión con el backend:", err);
}
---

<section class="productos-section container my-5">
  <h2 class="text-center mb-4 fw-bold text-primary">
    Nuestros Productos
  </h2>

  {productos.length === 0 ? (
    <p class="text-center text-muted">
      No hay productos disponibles por el momento.
    </p>
  ) : (
    <div class="productos-grid">
      {productos.map((p) => {
        const imagen = getProductImage(p.url_imagen);

        return (
          <ProductoCard
            id={p.id_producto}
            titulo={p.nombre_producto}
            precio={`S/ ${p.precio}`}
            descripcion={p.descripcion}
            stock={p.stock_disponible ?? p.stock ?? 0}
            imagen={{ src: imagen }}
          />
        );
      })}
    </div>
  )}
</section>