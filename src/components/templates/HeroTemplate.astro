---
const { pagina } = Astro.props;

const imagenSegura =
  typeof pagina.imagen_portada === "string" &&
  /^https?:\/\//.test(pagina.imagen_portada)
    ? pagina.imagen_portada
    : "";
---

<section
  class="py-5 text-center text-white"
  style={imagenSegura ? `background-image:url('${imagenSegura}'); background-size:cover; background-position:center;` : ""}
>
  <div class="container">
    <h1 class="display-4 fw-bold">{pagina.titulo}</h1>

    {pagina.meta_description && (
      <p class="lead">{pagina.meta_description}</p>
    )}
  </div>
</section>