---
interface SiteSettings {
  site_content?: {
    whatsapp?: string;
  };
}

const API_URL =
  import.meta.env.PUBLIC_API_URL || "http://localhost:3000/api/v1";

let config: SiteSettings = {};

try {
  const res = await fetch(`${API_URL}/site-settings`, {
    cache: "no-store",
  });

  if (res.ok) {
    const result = await res.json();
    config = result.data ?? {};
  }
} catch (error) {
  console.error("Error cargando site-settings:", error);
}

/* =========================
   HELPERS
========================= */

function safeWhatsapp(number = "") {
  const clean = String(number)
    .replace(/\D/g, "");

  return clean.length >= 8
    ? clean
    : "";
}

const whatsappNumber = safeWhatsapp(
  config.site_content?.whatsapp
);
---

{
  whatsappNumber && (
    <a
      href={`https://wa.me/${whatsappNumber}`}
      class="whatsapp-float"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="WhatsApp"
    >
      💬
    </a>
  )
}

<style>
.whatsapp-float {
  position: fixed;
  bottom: 25px;
  right: 25px;
  width: 64px;
  height: 64px;

  background: #25D366;
  border-radius: 50%;

  color: white;
  font-size: 28px;

  display: flex;
  justify-content: center;
  align-items: center;

  z-index: 99999;

  animation: pulseWhatsapp 2.5s infinite;
  transition: transform .2s ease;
}

.whatsapp-float:hover {
  transform: scale(1.1);
  box-shadow: 0 10px 25px rgba(0,0,0,.3);
}

@keyframes pulseWhatsapp {
  0% {
    box-shadow: 0 0 0 0 rgba(37,211,102,.6);
  }

  70% {
    box-shadow: 0 0 0 15px rgba(37,211,102,0);
  }

  100% {
    box-shadow: 0 0 0 0 rgba(37,211,102,0);
  }
}
</style>