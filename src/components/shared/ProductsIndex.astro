import pintura from "../../assets/rubro1.jpg"
import clavos from "../../assets/rubro2.jpg"
import arena from "../../assets/rubro3.jpg"
// Lista de productos
const productos = [
  {
    titulo: "Taladro Inalámbrico",
    precio: "S/ 320.00",
    descripcion: "Potente y ligero para todo tipo de trabajos",
    imagen: pintura
  },
  {
    titulo: "Sierra Circular",
    precio: "S/ 280.00",
