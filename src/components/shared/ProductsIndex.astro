---
import Title from "./Title.astro";
import Subtitulo from "./Subtitulo.astro";
import TarjetaProducto from "../ui/tarjetaProducto.astro";
import Button from "../ui/Button.astro";

interface Props {
  title?: string;
  subtitle?: string;
  tipo?: string;
  limit?: number;
  showButton?: boolean;
}

const {
  title = "Productos destacados",
  subtitle = "Explora nuestros mejores productos",
  tipo = "destacados",
  limit = 8,
  showButton = true,
} = Astro.props;

const API_URL =
  import.meta.env.PUBLIC_API_URL || "http://localhost:3000/api/v1";

const UPLOADS_URL =
  import.meta.env.PUBLIC_UPLOADS_URL || "http://localhost:3000/uploads";

let productos: any[] = [];

try {
  const res = await fetch(
    `${API_URL}/productos/home?tipo=${tipo}&limit=${limit}`,
    { cache: "no-store" }
  );

  if (!res.ok) {
    console.error("Error cargando productos home:", res.status, res.statusText);
  } else {
    const result = await res.json();
    productos = result.data ?? [];
  }
} catch (error) {
  console.error("Error cargando productos home:", error);
}
---

<section class="products-section">
  <div class="container">
    <Title>{title}</Title>
    <Subtitulo>{subtitle}</Subtitulo>

    {productos.length === 0 && (
      <p class="text-center text-danger fw-bold">
        ⚠️ No hay productos disponibles
      </p>
    )}

    {productos.length > 0 && (
      <div class="products-grid">
        {productos.map((p: any) => (
        <TarjetaProducto
  id={p.id_producto}
  titulo={p.nombre_producto}
  precio={`${p.precio}`}
  descripcion={p.descripcion}
  stock={p.stock_disponible}
  imagen={{
    src: p.url_imagen
      ? `${UPLOADS_URL}/${p.url_imagen}`
      : "/img/no-image.png",
  }}
  agotado={p.agotado}
/>
        ))}
      </div>
    )}

    {showButton && (
      <div class="text-center mt-4">
        <Button href="/productos">
          Ver todos los productos
        </Button>
      </div>
    )}
  </div>
</section>

<style>
.products-section {
  position: relative;
  z-index: 2;
}

.products-section .container {
  max-width: 1200px;
  margin: 0 auto;
}

.products-grid {
  display: grid;
  gap: 32px;
  grid-template-columns: repeat(auto-fit, minmax(260px, 300px));
  justify-content: center;
}

.products-grid > * {
  height: 100%;
}

.products-section .text-center {
  margin-top: 3rem;
  display: flex;
  justify-content: center;
}
</style>