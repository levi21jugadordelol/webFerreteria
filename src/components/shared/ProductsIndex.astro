    imagen: clavos
  },


];
---

<div class="mt-5">
  <Title>Productos destacados</Title>
  <Subtitulo>Explora nuestros mejores productos</Subtitulo>

  <div class="container">
    <div class="row justify-content-center">
      {productos.map((p) => (
        <div class="col-md-3 mb-4">
          <TarjetaProducto
            titulo={p.titulo}
            precio={p.precio}
            descripcion={p.descripcion}
            imagen={p.imagen}
          />
        </div>
      ))}
    </div>

    <div class="text-center">
      <Button>+ Ver todos nuestros productos</Button>
    </div>
  </div>
</div>





