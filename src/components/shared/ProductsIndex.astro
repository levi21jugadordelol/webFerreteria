    imagen: arena
  },
    {
    titulo: "Taladro Inalámbrico",
    precio: "S/ 320.00",
    descripcion: "Potente y ligero para todo tipo de trabajos",
    imagen: pintura
  },
  {
    titulo: "Sierra Circular",
    precio: "S/ 280.00",
    descripcion: "Ideal para cortes precisos y potentes",
    imagen: clavos
  },
  {
    titulo: "Amoladora Angular",
    precio: "S/ 190.00",
    descripcion: "Compacta y resistente para uso intensivo",
    imagen: arena
  },  {
    titulo: "Taladro Inalámbrico",
