---
const apiUrl = "http://localhost:3000";
---

<form id="formProducto" class="bg-white p-4 shadow rounded">
  <!-- Nombre -->
  <div class="mb-3">
    <label class="form-label fw-semibold">Nombre del producto</label>
    <input type="text" name="nombre_producto" class="form-control" required />
  </div>

  <!-- Descripción -->
  <div class="mb-3">
    <label class="form-label fw-semibold">Descripción</label>
    <textarea name="descripcion" class="form-control"></textarea>
  </div>

  <!-- Precio -->
  <div class="mb-3">
    <label class="form-label fw-semibold">Precio</label>
    <input type="number" name="precio" step="0.01" class="form-control" required />
  </div>

  <!-- Stock -->
  <div class="mb-3">
    <label class="form-label fw-semibold">Stock</label>
    <input type="number" name="stock" class="form-control" required />
  </div>

  <!-- CATEGORÍA -->
  <div class="mb-3">
    <label class="form-label fw-semibold">Categoría</label>
    <select name="categoria_id" id="categoriaSelect" class="form-select" required>
      <option value="">Cargando categorías...</option>
    </select>
  </div>

  <!-- MARCA -->
  <div class="mb-3">
    <label class="form-label fw-semibold">Marca</label>
    <select name="marca_id" id="marcaSelect" class="form-select" required>
      <option value="">Cargando marcas...</option>
    </select>
  </div>

  <!-- Imagen -->
  <div class="mb-3">
    <label class="form-label fw-semibold">Imagen del producto</label>
    <input type="file" id="imagen" name="imagen" />
  </div>

  <button type="submit" class="btn btn-primary w-100 fw-semibold">
    Guardar Producto
  </button>
</form>

<!-- @ts-ignore -->
<script is:client>
  const apiUrl = "http://localhost:3000";

  // 🔹 Cargar Categorías
  async function cargarCategorias() {
    const select = document.getElementById("categoriaSelect");
    if (!select) return;

    try {
      const res = await fetch(`${apiUrl}/categorias`, { credentials: "include" });
      const categorias = await res.json();

      select.innerHTML = categorias.length
        ? categorias
            .map((c) => `<option value="${c.id_categoria}">${c.nombre_categoria}</option>`)
            .join("")
        : `<option value="">No hay categorías disponibles</option>`;
    } catch (error) {
      select.innerHTML = `<option value="">Error al cargar categorías</option>`;
    }
  }

  // 🔹 Cargar Marcas
  async function cargarMarcas() {
    const select = document.getElementById("marcaSelect");
    if (!select) return;

    try {
      const res = await fetch(`${apiUrl}/marcas`, { credentials: "include" });
      const marcas = await res.json();

      select.innerHTML = marcas.length
        ? marcas
            .map((m) => `<option value="${m.id_marca}">${m.nombre_marca}</option>`)
            .join("")
        : `<option value="">No hay marcas disponibles</option>`;
    } catch (error) {
      select.innerHTML = `<option value="">Error al cargar marcas</option>`;
    }
  }

  // 🟢 CREAR PRODUCTO + IMAGEN + REDIRECCIÓN
  async function manejarSubmit(e) {
  e.preventDefault();
  const form = e.target;
  const fd = new FormData(form);

  const payload = {
    nombre_producto: fd.get("nombre_producto"),
    descripcion: fd.get("descripcion"),
    precio: Number(fd.get("precio")),
    stock: Number(fd.get("stock")),
    categoria_id: fd.get("categoria_id") || null,
    marca_id: fd.get("marca_id") || null,
  };

  try {
    // 1) Crear producto
    const res = await fetch(`${apiUrl}/productos`, {
      method: "POST",
      credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    const data = await res.json();

    // 🔍 LOG 1: Ver la respuesta completa
    console.log("🔍 Respuesta del backend al crear producto:", data);

    if (!res.ok) {
      console.error(data);
      alert("❌ Error al crear producto");
      return;
    }

    // 🔍 LOG 2: Ver el ID recibido
    const id = data.producto.id_producto;
    console.log("🆔 ID recibido:", id);

    // 2) Subir imagen principal (si se eligió)
    const fileInput = document.getElementById("imagen");
    if (fileInput && fileInput.files[0]) {
      const imgForm = new FormData();
      imgForm.append("file", fileInput.files[0]);

      const resImg = await fetch(`${apiUrl}/productos/${id}/imagen`, {
        method: "POST",
        credentials: "include",
        body: imgForm,
      });

      if (!resImg.ok) {
        console.warn("⚠️ Producto creado, pero error subiendo imagen principal");
      }
    }

    // 🔍 LOG 3: Ver la URL de redirección
    console.log(`➡️ Redirigiendo a: /admin/productos/editar/${id}`);

    // 3) Redirigir
    window.location.href = `/admin/productos/editar/${id}`;
  } catch (err) {
    console.error(err);
    alert("❌ Error de conexión al crear producto");
  }
}


  document.addEventListener("DOMContentLoaded", () => {
    cargarCategorias();
    cargarMarcas();

    const form = document.getElementById("formProducto");
    if (form) form.addEventListener("submit", manejarSubmit);
  });
</script>












