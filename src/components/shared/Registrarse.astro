---
export const prerender = false;

const { error = "", exito = "" } = Astro.props;
const title = "Registrar Administrador";
---

<div class="card shadow-lg p-4" style="width: 380px; border-radius: 1rem;">
  <h3 class="text-center mb-3 text-primary fw-bold">{title}</h3>

  <form method="POST">
    <div class="mb-3">
      <label for="nombre" class="form-label fw-semibold">Nombre completo</label>
      <input
        type="text"
        id="nombre"
        name="nombre"
        class="form-control"
        placeholder="Ingresa tu nombre"
        required
      />
    </div>

    <div class="mb-3">
      <label for="correo" class="form-label fw-semibold">Correo electrónico</label>
      <input
        type="email"
        id="correo"
        name="correo"
        class="form-control"
        placeholder="ejemplo@correo.com"
        required
      />
    </div>

    <div class="mb-3">
      <label for="password" class="form-label fw-semibold">Contraseña</label>
      <input
        type="password"
        id="password"
        name="password"
        class="form-control"
        placeholder="Mínimo 6 caracteres"
        required
      />
    </div>

    <button type="submit" class="btn btn-success w-100 fw-semibold">
      Registrarse
    </button>

    {error && <div class="alert alert-danger mt-3 text-center p-2">{error}</div>}
    {exito && <div class="alert alert-success mt-3 text-center p-2">{exito}</div>}
  </form>

  <div class="text-center mt-3">
    <a href="/admin/login" class="text-decoration-none">
      ¿Ya tienes una cuenta? <span class="fw-bold text-primary">Inicia sesión</span>
    </a>
  </div>
</div>


