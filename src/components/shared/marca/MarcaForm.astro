---
import { BACKEND_URL } from "../../../config/api";
---

<div class="container my-4">
  <h3 class="fw-bold mb-3">Crear Marca</h3>

  <!-- 🟢 FORMULARIO -->
  <form id="formMarca" class="bg-white p-4 shadow rounded">
    
    <div class="mb-3">
      <label class="form-label fw-semibold">Nombre de la Marca</label>
      <input
        type="text"
        name="nombre_marca"
        class="form-control"
        placeholder="Ejemplo: Bosch, Makita, Dewalt"
        required
      />
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold">Descripción</label>
      <textarea
        name="descripcion"
        class="form-control"
        rows="3"
        placeholder="Agrega una breve descripción de la marca"
      ></textarea>
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold">Logo de la Marca</label>
      <input type="file" id="imagenMarca" name="imagen" />
    </div>

    <button type="submit" class="btn btn-success w-100 fw-semibold">
      Guardar Marca
    </button>
  </form>

  <hr class="my-4" />

  <h4 class="fw-semibold">Marcas existentes</h4>
  <div id="lista-marcas" class="mt-3 d-flex flex-wrap gap-3"></div>
</div>

<!-- 🔥 IMPORTANTE: pasar API al JS -->
<script is:inline define:vars={{ BACKEND_URL }}>
  window.API_URL = BACKEND_URL;
</script>

<!-- FilePond -->
<link href="https://unpkg.com/filepond/dist/filepond.min.css" rel="stylesheet" />
<script src="https://unpkg.com/filepond/dist/filepond.min.js"></script>

<!-- TU LÓGICA -->
<script type="module" src="/js/marcas/marcas.page.js"></script>

<style>
  .card img {
    object-fit: cover;
    height: 150px;
  }
</style>
