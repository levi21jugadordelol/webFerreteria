---
const apiUrl = "http://localhost:3000";
---

<div class="container my-4">
  <h3 class="fw-bold mb-3">Crear Marca</h3>

  <!-- 🟢 FORMULARIO DE NUEVA MARCA -->
  <form id="formMarca" class="bg-white p-4 shadow rounded">
    
    <!-- Nombre -->
    <div class="mb-3">
      <label class="form-label fw-semibold">Nombre de la Marca</label>
      <input
        type="text"
        name="nombre_marca"
        class="form-control"
        placeholder="Ejemplo: Bosch, Makita, Dewalt"
        required
      />
    </div>

    <!-- Descripción -->
    <div class="mb-3">
      <label class="form-label fw-semibold">Descripción</label>
      <textarea
        name="descripcion"
        class="form-control"
        rows="3"
        placeholder="Agrega una breve descripción de la marca"
      ></textarea>
    </div>

    <!-- Logo -->
    <div class="mb-3">
      <label class="form-label fw-semibold">Logo de la Marca</label>
      <input type="file" id="imagenMarca" name="imagenMarca" />
    </div>

    <button type="submit" class="btn btn-success w-100 fw-semibold">
      Guardar Marca
    </button>
  </form>

  <hr class="my-4" />

  <!-- 🟡 LISTADO DE MARCAS -->
  <h4 class="fw-semibold">Marcas existentes</h4>
  <div id="lista-marcas" class="mt-3 d-flex flex-wrap gap-3"></div>
</div>

<!-- @ts-ignore -->
<script is:client>
  const apiUrl = "http://localhost:3000";

  // 🟡 Cargar lista de marcas
  async function cargarMarcas() {
    const contenedor = document.getElementById("lista-marcas");
    if (!contenedor) return;

    try {
      const res = await fetch(`${apiUrl}/marcas`);
      if (!res.ok) throw new Error("Error al cargar marcas");

      const marcas = await res.json();

      contenedor.innerHTML =
        marcas.length > 0
          ? marcas
              .map(
                (m) => `
              <div class="card p-3 shadow-sm text-center" style="width:200px">
                <img src="${
                  m.url_logo
                    ? apiUrl + "/uploads/" + m.url_logo
                    : "https://via.placeholder.com/150"
                }" class="img-fluid rounded mb-2" alt="${m.nombre_marca}" />
                <h6 class="fw-bold mb-1">${m.nombre_marca}</h6>
                <p class="text-muted small">${m.descripcion || "Sin descripción"}</p>
              </div>`
              )
              .join("")
          : "<p class='text-center text-muted'>No hay marcas aún.</p>";
    } catch (err) {
      console.error("❌ Error:", err);
    }
  }

  document.addEventListener("DOMContentLoaded", cargarMarcas);
</script>

<style>
  .card img {
    object-fit: cover;
    height: 150px;
  }
</style>
