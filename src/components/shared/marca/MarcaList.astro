---
import ModalEditMarca from "../../ui/marca/ModalEditMarca.astro";
import { API_URL, UPLOADS_URL } from "../../../config/api";
---

<div
  class="container my-4"
  id="marcas-root"
  data-api-url={API_URL}
  data-uploads-url={UPLOADS_URL}
>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="fw-bold mb-0">Lista de Marcas</h3>

    <a href="/admin/marcas/marca-nueva" class="btn btn-primary">
      ➕ Nueva Marca
    </a>
  </div>

  <p id="contador" class="text-muted">Cargando marcas...</p>

  <div id="lista-marcas" class="d-flex flex-column gap-3 mt-3">
    <p class="text-center text-muted">Cargando marcas...</p>
  </div>
</div>

<ModalEditMarca id="modal-editar-marca" />

<script is:client>
 const root = document.getElementById("marcas-root");
const apiUrl = root?.dataset.apiUrl;
const uploadsUrl = root?.dataset.uploadsUrl;

if (!apiUrl || !uploadsUrl) {
  console.error("No se encontró configuración de marcas");
}

  async function fetchJSON(url, options = {}) {
    const res = await fetch(url, {
      credentials: "include",
      ...options,
    });

    const result = await res.json();

    if (!res.ok) {
      throw new Error(result?.message || result?.msg || "Error en la API");
    }

    return result.data ?? result;
  }


  function escapeHTML(value = "") {
  return String(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");
}

function safeUploadUrl(fileName) {
  if (!fileName) return "/img/no-image.png";

  const clean = String(fileName).replace(/^\/?uploads\//, "");

  if (
    clean.includes("..") ||
    clean.includes("<") ||
    clean.includes(">") ||
    clean.includes('"') ||
    clean.includes("'")
  ) {
    return "/img/no-image.png";
  }

  return `${uploadsUrl}/${encodeURIComponent(clean)}`;
}

  async function cargarMarcas() {
    const contenedor = document.getElementById("lista-marcas");
    const contador = document.getElementById("contador");

    try {
      const marcas = await fetchJSON(`${apiUrl}/marcas`);

      contador.textContent = `Total marcas: ${marcas.length}`;

      if (marcas.length === 0) {
        contenedor.innerHTML =
          "<p class='text-center text-muted'>No hay marcas aún.</p>";
        return;
      }

      contenedor.innerHTML = marcas
        .map((m) => {
          const imagenUrl = safeUploadUrl(m.url_logo);
const nombre = escapeHTML(m.nombre_marca ?? "-");
const descripcion = escapeHTML(m.descripcion || "Sin descripción");
const idMarca = Number(m.id_marca) || 0;

          return `
            <div class="card p-3 shadow-sm d-flex flex-row align-items-center gap-3" data-id="${idMarca}">
              <img src="${imagenUrl}" width="120" height="120" class="rounded" alt="${nombre}" />

              <div class="flex-grow-1">
                <h5 class="mb-1">${nombre}</h5>
<p class="text-muted mb-1">${descripcion}</p>
              </div>

              <div class="d-flex gap-2">
                <button class="btn btn-warning btn-sm btn-editar">✏️ Editar</button>
                <button class="btn btn-danger btn-sm btn-eliminar">🗑️ Eliminar</button>
              </div>
            </div>
          `;
        })
        .join("");

      contenedor.querySelectorAll(".btn-eliminar").forEach((btn) =>
        btn.addEventListener("click", async (e) => {
          const card = e.target.closest(".card");
          const id = Number(card.dataset.id);
if (!id) return alert("ID de marca inválido");

          if (!confirm("¿Seguro que deseas eliminar esta marca?")) return;

          try {
            await fetchJSON(`${apiUrl}/marcas/${id}`, {
              method: "DELETE",
            });

            alert("✅ Marca eliminada correctamente");
            card.remove();
          } catch (err) {
            alert("❌ " + (err.message || err));
          }
        })
      );

      contenedor.querySelectorAll(".btn-editar").forEach((btn) =>
        btn.addEventListener("click", async (e) => {
          const card = e.target.closest(".card");
          const id = card.dataset.id;

          try {
            const marca = await fetchJSON(`${apiUrl}/marcas/${id}`);

            document.getElementById("marca-id").value = marca.id_marca;
            document.getElementById("marca-nombre").value = marca.nombre_marca;
            document.getElementById("marca-descripcion").value =
              marca.descripcion || "";

            const preview = document.getElementById("marca-img-preview");

            preview.src = safeUploadUrl(marca.url_logo);

            document
              .getElementById("modal-editar-marca")
              .classList.add("visible");
          } catch (err) {
            alert("❌ Error cargando marca");
          }
        })
      );
    } catch (err) {
      contenedor.innerHTML = `<p class="text-danger">❌ Error: ${escapeHTML(err.message)}</p>`;
      contador.textContent = "Error de conexión";
    }
  }

  document.addEventListener("DOMContentLoaded", cargarMarcas);

  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("form-editar-marca");

    if (!form) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const id = document.getElementById("marca-id").value;
      const nombre = document.getElementById("marca-nombre").value;
      const descripcion = document.getElementById("marca-descripcion").value;
      const nuevoLogo = document.getElementById("marca-img").files[0];

      try {
        await fetchJSON(`${apiUrl}/marcas/${id}`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            nombre_marca: nombre,
            descripcion,
          }),
        });

        if (nuevoLogo) {
          const data = new FormData();
          data.append("imagen", nuevoLogo);

          await fetchJSON(`${apiUrl}/marcas/subir-logo/${id}`, {
            method: "POST",
            body: data,
          });
        }

        alert("✅ Marca actualizada");

        document.dispatchEvent(new Event("cerrar-modal-marca"));
        cargarMarcas();
      } catch (err) {
        alert("❌ Error actualizando marca");
      }
    });
  });
</script>

<style>
.card img {
  object-fit: cover;
}
</style>