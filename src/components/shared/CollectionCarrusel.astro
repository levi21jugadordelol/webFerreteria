---
import TarjetaCollection from "../ui/tarjetaCollection.astro";

const apiUrl = "http://localhost:3000";

interface Categoria {
  id_categoria: number;
  nombre_categoria: string;
  descripcion?: string;
  url_imagen?: string;
}

let categorias: Categoria[] = [];

try {
  const res = await fetch(`${apiUrl}/categorias`, { cache: "no-store" });
  if (res.ok) {
    categorias = await res.json() as Categoria[];
  } else {
    console.error("Error al cargar categorías:", res.statusText);
  }
} catch (err) {
  console.error("❌ Error de conexión con el backend:", err);
}
---



<div class="collection-carrusel container position-relative">

 

  <div class="carrusel-container">

    <!-- Flecha izquierda -->
    <button id="prevBtn" class="btn-flecha btn-left" aria-label="Anterior">
  <i class="fa-solid fa-chevron-left"></i>
</button>

    <!-- Carrusel -->
  <div id="carrusel" class="carrusel">
  {categorias.map((c) => (
  <div class="item">
  <a href={`/productos?categoria=${c.id_categoria}`} class="categoria-link">
    <TarjetaCollection
      title={c.nombre_categoria}
      imageUrl={
        c.url_imagen
          ? `${apiUrl}/uploads/${c.url_imagen}`
          : "https://via.placeholder.com/300x260?text=Sin+imagen"
      }
    />
  </a>
</div>

  ))}
</div>


    <!-- Flecha derecha -->
    <button id="nextBtn" class="btn-flecha btn-right" aria-label="Siguiente">
  <i class="fa-solid fa-chevron-right"></i>
</button>

  </div>
</div>


<!-- @ts-ignore -->
<script is:client>
  const carrusel = document.getElementById("carrusel");
  const prevBtn = document.getElementById("prevBtn");
  const nextBtn = document.getElementById("nextBtn");

  function anchoItem() {
    const item = carrusel.querySelector(".item");
    return item ? item.offsetWidth + 24 : 324; // ancho + gap
  }

  prevBtn.addEventListener("click", () => {
    carrusel.scrollBy({ left: -anchoItem(), behavior: "smooth" });
  });

  nextBtn.addEventListener("click", () => {
    carrusel.scrollBy({ left: anchoItem(), behavior: "smooth" });
  });
</script>





<style>
.carrusel-container {
  position: relative;
  width: 100%;
  max-width: 1100px;
  margin: auto;
}

/* CARRUSEL BASE */
.carrusel-container {
  position: relative;
  width: 100%;
  max-width: 1100px;
  margin: auto;
}

.carrusel {
  display: flex;
  gap: 1.5rem;
  overflow: hidden;
  scroll-behavior: smooth;
  padding: 1rem 0;
}

.categoria-link {
  text-decoration: none;
  color: inherit;
  display: block;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.categoria-link:hover {
  transform: translateY(-5px);
}

.card {
  cursor: pointer;
}


.item {
  flex: 0 0 300px;  /* 🔥 ANCHO FIJO DE CADA TARJETA */
}

/************ DESKTOP: 3 TARJETAS ************/
@media (min-width: 768px) {
  .item {
    flex: 0 0 calc((100% / 3) - 1rem);
  }
}

/************ MOBILE: 1 TARJETA ************/
@media (max-width: 767px) {
  .carrusel {
    overflow-x: auto;              /* 🔥 scroll visible */
    scroll-snap-type: x mandatory;
  }

  .item {
    flex: 0 0 100%;                /* 🔥 SOLO 1 TARJETA */
    scroll-snap-align: start;
  }
}



/* =========================
   🎯 CARRUSEL FLECHAS PRO
========================= */

.btn-flecha {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid var(--color-border);
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(6px);
  color: var(--color-text);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.25s ease;
  box-shadow: 0 4px 14px rgba(0,0,0,0.08);
  z-index: 20;
}

.btn-flecha i {
  font-size: 0.95rem;
}

.btn-flecha:hover {
  background: var(--color-primary);
  color: white;
  transform: translateY(-50%) scale(1.08);
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}

/* Posiciones */
.btn-left { left: -55px; }
.btn-right { right: -55px; }

/* Dark mode ajuste */
html[data-theme="dark"] .btn-flecha {
  background: rgba(30,30,30,0.8);
}


/* MOBILE — OCULTAR FLECHAS PORQUE NO SE USAN */
@media (max-width: 767px) {
  .btn-flecha {
    display: none;
  }
}

</style>



