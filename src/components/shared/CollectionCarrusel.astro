---
import TarjetaCollection from "../ui/tarjetaCollection.astro";

import { API_URL, UPLOADS_URL } from "../../config/api";

interface Categoria {
  id_categoria: number;
  nombre_categoria: string;
  descripcion?: string;
  url_imagen?: string | null;
}

let categorias: Categoria[] = [];


const getCollectionImage = (url: string | null | undefined) => {
  const value = String(url || "").trim();

  if (!value || value.includes("..")) {
    return "https://via.placeholder.com/300x260?text=Sin+imagen";
  }

  if (value.startsWith("http://") || value.startsWith("https://")) {
    return value;
  }

  return `${UPLOADS_URL}/${value.replace(/^\/+/, "")}`;
};

try {
  const res = await fetch(`${API_URL}/categorias`, {
    cache: "no-store",
  });

  if (!res.ok) {
    console.error("Error al cargar categorías:", res.status, res.statusText);
  } else {
    const result = await res.json();
    categorias = result.data ?? [];
  }
} catch (err) {
  console.error("Error de conexión con el backend:", err);
}
---

<div class="collection-carrusel container position-relative">
  <div class="carrusel-container">
    <button id="prevBtn" class="btn-flecha btn-left" aria-label="Anterior">
      <i class="fa-solid fa-chevron-left"></i>
    </button>

    <div id="carrusel" class="carrusel">
      {categorias.map((c) => (
        <div class="item">
          <a href={`/productos?categoria=${c.id_categoria}`} class="categoria-link">
            <TarjetaCollection
              title={c.nombre_categoria}
             imageUrl={getCollectionImage(c.url_imagen)}
            />
          </a>
        </div>
      ))}
    </div>

    <button id="nextBtn" class="btn-flecha btn-right" aria-label="Siguiente">
      <i class="fa-solid fa-chevron-right"></i>
    </button>
  </div>
</div>

<script>
  const carrusel = document.getElementById("carrusel");
  const prevBtn = document.getElementById("prevBtn");
  const nextBtn = document.getElementById("nextBtn");

 function anchoItem(): number {
  const item = carrusel?.querySelector<HTMLElement>(".item");

  return item ? item.offsetWidth + 24 : 324;
}

  prevBtn?.addEventListener("click", () => {
    carrusel?.scrollBy({ left: -anchoItem(), behavior: "smooth" });
  });

  nextBtn?.addEventListener("click", () => {
    carrusel?.scrollBy({ left: anchoItem(), behavior: "smooth" });
  });
</script>

<style>
.collection-carrusel {
  position: relative;
}

.carrusel-container {
  position: relative;
  width: 100%;
  max-width: 1100px;
  margin: auto;
}

.carrusel {
  display: flex;
  gap: 1.5rem;
  overflow: hidden;
  scroll-behavior: smooth;
  padding: 1rem 0;
}

.categoria-link {
  text-decoration: none;
  color: inherit;
  display: block;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.categoria-link:hover {
  transform: translateY(-5px);
}

.item {
  flex: 0 0 300px;
}

.btn-flecha {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid var(--color-border);
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(6px);
  color: var(--color-text);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.25s ease;
  box-shadow: 0 4px 14px rgba(0,0,0,0.08);
  z-index: 20;
}

.btn-flecha i {
  font-size: 0.95rem;
}

.btn-flecha:hover {
  background: var(--color-primary);
  color: white;
  transform: translateY(-50%) scale(1.08);
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}

.btn-left {
  left: -55px;
}

.btn-right {
  right: -55px;
}

html[data-theme="dark"] .btn-flecha {
  background: rgba(30,30,30,0.8);
}

@media (min-width: 768px) {
  .item {
    flex: 0 0 calc((100% / 3) - 1rem);
  }
}

@media (max-width: 767px) {
  .carrusel {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
  }

  .item {
    flex: 0 0 100%;
    scroll-snap-align: start;
  }

  .btn-flecha {
    display: none;
  }
}
</style>