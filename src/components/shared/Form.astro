---
const title = "Login de Administrador";
const API_URL = import.meta.env.PUBLIC_API_URL;
let error = "";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>

  <body class="bg-light d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4" style="width: 380px; border-radius: 1rem;">
      <h3 class="text-center mb-4 text-primary fw-bold">Iniciar Sesión</h3>

      <form id="loginForm">
        <div class="mb-3">
          <label for="correo" class="form-label fw-semibold">Correo electrónico</label>
          <input type="email" id="correo" name="correo" class="form-control" required />
        </div>

        <div class="mb-3">
          <label for="password" class="form-label fw-semibold">Contraseña</label>
          <input type="password" id="password" name="password" class="form-control" required />
        </div>

        <button type="submit" class="btn btn-primary w-100 fw-semibold">Ingresar</button>

        {error && <div class="alert alert-danger mt-3 text-center p-2">{error}</div>}
      </form>

      <div class="text-center mt-3">
        <a href="/admin/registro" class="text-decoration-none">
          ¿No tienes una cuenta? <span class="fw-bold text-success">Regístrate</span>
        </a>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>



   <script define:vars={{ API_URL }}>
  const form = document.getElementById("loginForm");
  const correoInput = document.getElementById("correo");
  const passwordInput = document.getElementById("password");

  if (form && correoInput instanceof HTMLInputElement && passwordInput instanceof HTMLInputElement) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      try {
        const response = await fetch(`${API_URL}/auth/login`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({
            correo: correoInput.value,
            password: passwordInput.value,
          }),
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || data.msg || "Error en login");
        }

        window.location.replace("/admin/panel-admin");
      } catch (error) {
        alert(error instanceof Error ? error.message : "Error inesperado en login");
      }
    });
  }
</script>
  </body>
</html>
