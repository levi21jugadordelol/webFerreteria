---
const title = "Login de Administrador";
let error = "";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>

  <body class="bg-light d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4" style="width: 380px; border-radius: 1rem;">
      <h3 class="text-center mb-4 text-primary fw-bold">Iniciar Sesión</h3>

      <form id="loginForm">
        <div class="mb-3">
          <label for="correo" class="form-label fw-semibold">Correo electrónico</label>
          <input type="email" id="correo" name="correo" class="form-control" required />
        </div>

        <div class="mb-3">
          <label for="password" class="form-label fw-semibold">Contraseña</label>
          <input type="password" id="password" name="password" class="form-control" required />
        </div>

        <button type="submit" class="btn btn-primary w-100 fw-semibold">Ingresar</button>

        {error && <div class="alert alert-danger mt-3 text-center p-2">{error}</div>}
      </form>

      <div class="text-center mt-3">
        <a href="/admin/registro" class="text-decoration-none">
          ¿No tienes una cuenta? <span class="fw-bold text-success">Regístrate</span>
        </a>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>



    <script>
      const form = document.getElementById("loginForm");
      if (form) {
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const target = e.target as HTMLFormElement;
          const correo = (target.querySelector("#correo") as HTMLInputElement).value;
          const password = (target.querySelector("#password") as HTMLInputElement).value;

          console.log("📤 Enviando datos al backend:", { correo, password });

          try {
            const response = await fetch("http://localhost:3000/auth/login", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ correo, password }),
              credentials: "include",
            });

            if (response.ok) {
              console.log("✅ Login exitoso, redirigiendo...");
              window.location.href = "http://localhost:4321/admin/panel-admin";

            } else {
              const data = await response.json();
              alert(data.msg || "⚠️ Credenciales incorrectas.");
            }
          } catch (err) {
            console.error("💥 Error al conectar con el servidor:", err);
            alert("Error al conectar con el servidor.");
          }
        });
      }
    </script>
  </body>
</html>
