---
const apiUrl = "http://localhost:3000";
---

<div class="container my-4">
  <h3 class="fw-bold mb-3">Crear Categoría</h3>

  <!-- ✅ FORMULARIO DE NUEVA CATEGORÍA -->
  <form id="formCategoria" class="bg-white p-4 shadow rounded">
    <div class="mb-3">
      <label class="form-label fw-semibold">Nombre de la categoría</label>
      <input
        type="text"
        name="nombre_categoria"
        class="form-control"
        placeholder="Ejemplo: Herramientas eléctricas"
        required
      />
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold">Descripción</label>
      <textarea
        name="descripcion"
        class="form-control"
        rows="3"
        placeholder="Agrega una breve descripción de la categoría"
      ></textarea>
    </div>

    <!-- 🖼️ Campo de imagen -->
    <div class="mb-3">
      <label class="form-label fw-semibold">Imagen de la categoría</label>
      <input type="file" id="imagenCategoria" name="imagenCategoria" />
    </div>

    <button type="submit" class="btn btn-success w-100 fw-semibold">
      Guardar Categoría
    </button>
  </form>

  <hr class="my-4" />

  <!-- ✅ LISTADO DE CATEGORÍAS -->
  <h4 class="fw-semibold">Categorías existentes</h4>
  <div id="lista-categorias" class="mt-3 d-flex flex-wrap gap-3"></div>
</div>

<!-- @ts-ignore -->
<script is:client>
  const apiUrl = "http://localhost:3000";

  // ✅ Cargar lista de categorías
  async function cargarCategorias() {
    const contenedor = document.getElementById("lista-categorias");
    if (!contenedor) return;

    try {
      const res = await fetch(`${apiUrl}/categorias`);
      if (!res.ok) throw new Error("Error al cargar categorías");

      const categorias = await res.json();

      contenedor.innerHTML =
        categorias.length > 0
          ? categorias
              .map(
                (c) => `
              <div class="card p-3 shadow-sm text-center" style="width:200px">
                <img src="${
                  c.url_imagen
                    ? apiUrl + "/uploads/" + c.url_imagen
                    : "https://via.placeholder.com/150"
                }" class="img-fluid rounded mb-2" alt="${c.nombre_categoria}" />
                <h6 class="fw-bold mb-1">${c.nombre_categoria}</h6>
                <p class="text-muted small">${
                  c.descripcion || "Sin descripción"
                }</p>
              </div>`
              )
              .join("")
          : "<p class='text-center text-muted'>No hay categorías aún.</p>";
    } catch (err) {
      console.error("❌ Error:", err);
    }
  }

  document.addEventListener("DOMContentLoaded", cargarCategorias);
</script>

<style>
  .card img {
    object-fit: cover;
    height: 150px;
  }
</style>



