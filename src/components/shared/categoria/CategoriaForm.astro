---
const apiUrl = "http://localhost:3000";
---

<div class="container my-4">
  

  <!-- ✅ FORMULARIO -->
  <form id="formCategoria" class="bg-white p-4 shadow rounded">

    <div class="mb-3">
      <label class="form-label fw-semibold">Nombre de la categoría</label>
      <input
        type="text"
        name="nombre_categoria"
        class="form-control"
        placeholder="Ejemplo: Dormitorio"
        required
      />
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold">Descripción</label>
      <textarea
        name="descripcion"
        class="form-control"
        rows="3"
        placeholder="Descripción opcional"
      ></textarea>
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold">Imagen de la categoría</label>
      <!-- 🔥 IMPORTANTE: id correcto -->
      <input type="file" id="imagenCategoria" name="file" />
    </div>

    <!-- 🔥 BOTÓN CORRECTO -->
    <button type="submit" class="btn btn-success w-100 fw-semibold">
      Guardar Categoría
    </button>
  </form>

  <hr class="my-4" />

  <!-- 📋 LISTADO -->
  <h4 class="fw-semibold">Categorías existentes</h4>
  <div id="lista-categorias" class="mt-3 d-flex flex-wrap gap-3"></div>
</div>



<style>
  .card img {
    object-fit: cover;
    height: 150px;
  }
</style>



