---
import ModalEditCategoria from "../../ui/categoria/ModalEditCategoria.astro"
---
const apiUrl = "http://localhost:3000";
---

<div class="container my-4">
  <h3 class="fw-bold mb-3">Lista de Categorías</h3>
  <p id="contador" class="text-muted">Cargando categorías...</p>

  <div id="lista-categorias" class="d-flex flex-column gap-3 mt-3">
    <p class="text-center text-muted">Cargando categorías...</p>
  </div>
</div>

<!-- 🔥 MODAL DE EDICIÓN -->
<ModalEditCategoria id="modal-editar-categoria" />

<!-- @ts-ignore -->
<script is:client>
  const apiUrl = "http://localhost:3000";

  async function cargarCategorias() {
    const contenedor = document.getElementById("lista-categorias");
    const contador = document.getElementById("contador");

    try {
      const res = await fetch(`${apiUrl}/categorias`, {
        credentials: "include",
        cache: "no-store",
      });

      if (!res.ok) {
        contenedor.innerHTML = `<p class="text-danger">❌ Error ${res.status}: ${res.statusText}</p>`;
        contador.textContent = "Error al cargar categorías";
        return;
      }

      const categorias = await res.json();
      contador.textContent = `Total categorías: ${categorias.length}`;

      if (categorias.length === 0) {
        contenedor.innerHTML =
          "<p class='text-center text-muted'>No hay categorías aún.</p>";
        return;
      }

      contenedor.innerHTML = categorias
        .map((c) => {
          const imagenUrl = c.url_imagen
            ? `${apiUrl}/uploads/${c.url_imagen}`
            : "https://via.placeholder.com/100";

          return `
            <div class="card p-3 shadow-sm d-flex flex-row align-items-center gap-3" data-id="${c.id_categoria}">
              <img src="${imagenUrl}" width="100" height="100" class="rounded" />
              <div class="flex-grow-1">
                <h5 class="mb-1">${c.nombre_categoria}</h5>
                <p class="text-muted mb-1">${c.descripcion || "Sin descripción"}</p>
              </div>
              <div class="d-flex gap-2">
                <button class="btn btn-warning btn-sm btn-editar">✏️ Editar</button>
                <button class="btn btn-danger btn-sm btn-eliminar">🗑️ Eliminar</button>
              </div>
            </div>`;
        })
        .join("");

      /* ✏️ Editar */
      contenedor.querySelectorAll(".btn-editar").forEach((btn) =>
        btn.addEventListener("click", async (e) => {
          const card = e.target.closest(".card");
          const id = card.dataset.id;

          const res = await fetch(`${apiUrl}/categorias/${id}`, {
            credentials: "include",
            cache: "no-store",
          });
          const categoria = await res.json();

          document.getElementById("cat-id").value = categoria.id_categoria;
          document.getElementById("cat-nombre").value = categoria.nombre_categoria;
          document.getElementById("cat-descripcion").value =
            categoria.descripcion || "";
          document.getElementById("cat-img-preview").src = categoria.url_imagen
            ? `${apiUrl}/uploads/${categoria.url_imagen}`
            : "https://via.placeholder.com/120";

          document
            .getElementById("modal-editar-categoria")
            .classList.add("visible");
        })
      );
    } catch (err) {
      contenedor.innerHTML = `<p class="text-danger">❌ Error: ${err.message}</p>`;
      contador.textContent = "Error de conexión";
    }
  }

  // 🔥 CLAVE DE LA OPCIÓN A
  window.cargarCategorias = cargarCategorias;

  document.addEventListener("DOMContentLoaded", cargarCategorias);
</script>


<style>
.card img {
  object-fit: cover;
}
</style>

