---
import ModalEditCategoria from "../../ui/categoria/ModalEditCategoria.astro";
import { API_URL, UPLOADS_URL } from "../../../config/api";
---

<div
  class="container my-4"
  id="categorias-root"
  data-api-url={API_URL}
  data-uploads-url={UPLOADS_URL}
>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <a href="/admin/categoria-nueva" class="btn btn-primary">
      ➕ Nueva Categoría
    </a>
  </div>

  <p id="contador" class="text-muted">Cargando categorías...</p>

  <div id="lista-categorias" class="d-flex flex-column gap-3 mt-3">
    <p class="text-muted">Cargando...</p>
  </div>
</div>

<ModalEditCategoria id="modal-editar-categoria" />

<script is:client>
  const root = document.getElementById("categorias-root");
const apiUrl = root?.dataset.apiUrl;
const uploadsUrl = root?.dataset.uploadsUrl;

if (!apiUrl || !uploadsUrl) {
  console.error("No se encontró configuración de categorías");
}

  async function fetchJSON(url, options = {}) {
    const res = await fetch(url, {
      credentials: "include",
      ...options,
    });

    const result = await res.json().catch(() => ({}));

    if (!res.ok) {
      throw new Error(result?.message || result?.msg || "Error en la API");
    }

    return result.data ?? result;
  }

  function escapeHTML(value = "") {
    return String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function safeUploadUrl(fileName) {
    if (!fileName) return "/img/no-image.png";

    const clean = String(fileName).replace(/^\/?uploads\//, "");

    if (
      clean.includes("..") ||
      clean.includes("<") ||
      clean.includes(">") ||
      clean.includes('"') ||
      clean.includes("'")
    ) {
      return "/img/no-image.png";
    }

    return `${uploadsUrl}/${encodeURIComponent(clean)}`;
  }

  async function cargarCategorias() {
    const contenedor = document.getElementById("lista-categorias");
    const contador = document.getElementById("contador");

    try {
      const categorias = await fetchJSON(`${apiUrl}/categorias`, {
        cache: "no-store",
      });

      const lista = Array.isArray(categorias) ? categorias : [];

contador.textContent = `Total categorías: ${lista.length}`;

     if (lista.length === 0) {
  contenedor.innerHTML =
    "<p class='text-center text-muted'>No hay categorías aún.</p>";
  return;
}

      contenedor.innerHTML = categorias
        .map((c) => {
          const idCategoria = Number(c.id_categoria) || 0;
          const imagenUrl = safeUploadUrl(c.url_imagen);
          const nombre = escapeHTML(c.nombre_categoria ?? "-");
          const descripcion = escapeHTML(c.descripcion || "Sin descripción");

          return `
            <div
              class="card p-3 shadow-sm d-flex flex-row align-items-center gap-3"
              data-id="${idCategoria}"
            >
              <img
                src="${imagenUrl}"
                width="100"
                height="100"
                class="rounded"
                alt="${nombre}"
              />

              <div class="flex-grow-1">
                <h5 class="mb-1">${nombre}</h5>
                <p class="text-muted mb-1">${descripcion}</p>
              </div>

              <div class="d-flex gap-2">
                <button class="btn btn-warning btn-sm btn-editar">
                  ✏️ Editar
                </button>

                <button class="btn btn-danger btn-sm btn-eliminar">
                  🗑️ Eliminar
                </button>
              </div>
            </div>
          `;
        })
        .join("");

      contenedor.querySelectorAll(".btn-editar").forEach((btn) =>
        btn.addEventListener("click", async (e) => {
          const card = e.target.closest(".card");
          const id = Number(card.dataset.id);

          if (!id) {
            alert("ID de categoría inválido");
            return;
          }

          try {
            const categoria = await fetchJSON(`${apiUrl}/categorias/${id}`, {
              cache: "no-store",
            });

            document.getElementById("cat-id").value =
              categoria.id_categoria;

            document.getElementById("cat-nombre").value =
              categoria.nombre_categoria ?? "";

            document.getElementById("cat-descripcion").value =
              categoria.descripcion || "";

            document.getElementById("cat-img-preview").src =
              safeUploadUrl(categoria.url_imagen);

            document
              .getElementById("modal-editar-categoria")
              .classList.add("visible");
          } catch (error) {
            alert("❌ Error cargando categoría");
          }
        })
      );

      contenedor.querySelectorAll(".btn-eliminar").forEach((btn) =>
        btn.addEventListener("click", async (e) => {
          const card = e.target.closest(".card");
          const id = Number(card.dataset.id);

          if (!id) {
            alert("ID de categoría inválido");
            return;
          }

          const confirmar = confirm(
            "¿Estás seguro de eliminar esta categoría?\nEsta acción no se puede deshacer."
          );

          if (!confirmar) return;

          try {
            await fetchJSON(`${apiUrl}/categorias/${id}`, {
              method: "DELETE",
            });

            await cargarCategorias();
          } catch (error) {
            console.error("💥 Error eliminando:", error);
            alert("❌ Error al eliminar la categoría");
          }
        })
      );
    } catch (err) {
      contenedor.innerHTML = `
        <p class="text-danger">
          ❌ Error: ${escapeHTML(err.message)}
        </p>
      `;

      contador.textContent = "Error de conexión";
    }
  }

  window.cargarCategorias = cargarCategorias;

  document.addEventListener("DOMContentLoaded", cargarCategorias);
</script>

<style>
  .card img {
    object-fit: cover;
  }
</style>