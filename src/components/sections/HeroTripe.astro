---
export const prerender = false;

import { API_URL, UPLOADS_URL } from "../../config/api";


  const imagenHeroSegura = (path = "") => {
  const cleanPath = String(path || "").replace(/^\/+/, "");

  if (!cleanPath) return "/img/no-image.png";
  if (cleanPath.includes("..")) return "/img/no-image.png";

  return `${UPLOADS_URL}/${encodeURIComponent(cleanPath)}`;
};

const urlInternaSegura = (url = "") => {
  return /^\/[a-zA-Z0-9/_?=&-]*$/.test(url) ? url : "#";
};

interface HeroSlide {
  id_hero: number;
  titulo1: string | null;
  titulo2: string | null;
  imagen: string;
  tipo_layout: string;
  mostrar_boton: boolean;
  boton_texto: string | null;
  boton_url: string | null;
  link_url: string | null;
  orden: number;
  activo: boolean;
}

let tripleSlides: HeroSlide[] = [];

try {
  const res = await fetch(`${API_URL}/hero?type=triple`, {
    cache: "no-store",
  });

  if (!res.ok) {
    console.error("Error cargando hero triple:", res.status, res.statusText);
  } else {
    const result = await res.json();
    tripleSlides = result.data ?? [];
  }
} catch (error) {
  console.error("Error cargando hero triple:", error);
}
---

<div class="hero-triple container">
  <div class="row g-5 gx-5">
    {tripleSlides.map((slide) => (
      <div class="col-md-4">
        <a
          href={urlInternaSegura(slide.link_url ?? slide.boton_url ?? "")}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-card"
        >
          <img
            src={imagenHeroSegura(slide.imagen)}
            alt={slide.titulo1 ?? "banner promocional"}
          />

          {(slide.titulo1 || slide.titulo2) && (
            <div class="hero-overlay">
              {slide.titulo1 && <h4>{slide.titulo1}</h4>}
              {slide.titulo2 && <p>{slide.titulo2}</p>}
            </div>
          )}
        </a>
      </div>
    ))}
  </div>
</div>

<style>
.hero-triple {
  margin: 60px auto;
}

.hero-card {
  display: block;
  overflow: hidden;
  border-radius: 12px;
  aspect-ratio: 16/15;
  box-shadow: 0 10px 20px rgba(0,0,0,0.08);
  transition: all .35s ease;
  position: relative;
}

.hero-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 25px 50px rgba(0,0,0,0.18);
}

.hero-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .4s;
}

.hero-card:hover img {
  transform: scale(1.05);
}

.hero-overlay {
  position: absolute;
  bottom: 20px;
  left: 20px;
  right: 20px;
  color: white;
  text-shadow: 0 3px 10px rgba(0,0,0,.7);
}

.hero-overlay h4 {
  margin: 0;
  font-size: 22px;
  font-weight: 700;
}

.hero-overlay p {
  margin: 4px 0 0 0;
  font-size: 14px;
}
</style>