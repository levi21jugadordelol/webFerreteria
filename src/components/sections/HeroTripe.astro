---
export const prerender = false;

const API_URL = "http://localhost:3000";

interface HeroSlide {
  id_hero: number;
  titulo1: string | null;
  titulo2: string | null;
  imagen: string;
  tipo_layout: string;
  mostrar_boton: boolean;
  boton_texto: string | null;
  boton_url: string | null;
  link_url: string | null;
  orden: number;
  activo: boolean;
}

const res = await fetch(`${API_URL}/api/hero?type=triple`);
const tripleSlides: HeroSlide[] = await res.json();
---

<div class="hero-triple container">

  <div class="row g-5 gx-5">

    {tripleSlides.map((slide) => (

      <div class="col-md-4">

        <a
          href={slide.link_url ?? slide.boton_url ?? "#"}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-card"
        >

          <img
            src={`${API_URL}/uploads/${slide.imagen}`}
            alt={slide.titulo1 ?? "banner promocional"}
          />

          {(slide.titulo1 || slide.titulo2) && (
            <div class="hero-overlay">

              {slide.titulo1 && <h4>{slide.titulo1}</h4>}

              {slide.titulo2 && <p>{slide.titulo2}</p>}

            </div>
          )}

        </a>

      </div>

    ))}

  </div>

</div>

<style>

.hero-triple{
  margin:60px auto;
}

/* CARD */

.hero-card{
  display:block;
  overflow:hidden;
  border-radius:12px;
  aspect-ratio:16/15;

  box-shadow:0 10px 20px rgba(0,0,0,0.08);
  transition:all .35s ease;
}

.hero-card:hover{
  transform:translateY(-6px);
  box-shadow:0 25px 50px rgba(0,0,0,0.18);
}

/* IMAGEN */

.hero-card img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:transform .4s;
}

.hero-card:hover img{
  transform:scale(1.05);
}

/* TEXTO SOBRE EL BANNER */

.hero-overlay{
  position:absolute;
  bottom:20px;
  left:20px;
  right:20px;

  color:white;

  text-shadow:0 3px 10px rgba(0,0,0,.7);
}

.hero-overlay h4{
  margin:0;
  font-size:22px;
  font-weight:700;
}

.hero-overlay p{
  margin:4px 0 0 0;
  font-size:14px;
}

</style>