---
type Footer = {
  titulo?: string;
  titulo2?: string;
  titulo3?: string;
  parrafo?: string;
  enlaces?: { label: string; url: string }[];
  social?: { icon: string; url: string }[];
};

let footer: Footer = {};

try {
  const res = await fetch("http://localhost:3000/api/site-settings?key=footer");

  if (res.ok) {
    footer = await res.json();
  }
} catch (error) {
  console.error("Error cargando footer:", error);
}
---

<footer class="footer bg-dark text-light pt-5 pb-3 mt-5">
  <div class="container">
    <div class="row">

      <!-- Columna 1 -->
      <div class="col-md-4 mb-4">
        <h5 class="fw-bold">
          {footer?.titulo || "Enlaces de interés"}
        </h5>

        <ul class="list-unstyled">
          {footer?.enlaces?.length
            ? footer.enlaces.map((item:any) => (
              <li>
                <a href={item.url} class="footer-link">
                  {item.label}
                </a>
              </li>
            ))
            : (
              <li>
                <a href="#" class="footer-link">Sin enlaces</a>
              </li>
            )
          }
        </ul>
      </div>

      <!-- Columna 2 -->
      <div class="col-md-4 mb-4">
        <h5 class="fw-bold">
          {footer?.titulo2 || "Acerca de"}
        </h5>

        <p>
          {footer?.parrafo || "Contenido no disponible"}
        </p>
      </div>

      <!-- Columna 3 -->
      <div class="col-md-4 mb-4">
        <h5 class="fw-bold">
          {footer?.titulo3 || "Redes"}
        </h5>

        <div class="social-icons d-flex gap-3">
          {footer?.social?.map((s:any) => (
            <a href={s.url} target="_blank" class="social-link">
              <i class={`fab fa-${s.icon}`}></i>
            </a>
          ))}
        </div>
      </div>

    </div>

    <div class="text-center mt-4 small text-secondary">
      © {new Date().getFullYear()} - Todos los derechos reservados
    </div>
  </div>
</footer>