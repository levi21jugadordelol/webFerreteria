---
type Footer = {
  titulo?: string;
  titulo2?: string;
  titulo3?: string;
  parrafo?: string;
  enlaces?: { label: string; url: string }[];
  social?: { icon: string; url: string }[];
};

import { API_URL } from "../../config/api";

let footer: Footer = {};

try {
  const res = await fetch(`${API_URL}/site-settings`, {
    cache: "no-store",
  });

  if (res.ok) {
    const result = await res.json();
    footer = result.data?.footer ?? {};
  }
} catch (error) {
  console.error("Error cargando footer:", error);
}

/* =========================
   HELPERS
========================= */

function safeUrl(url = "") {
  const value = String(url).trim();

  if (!value) return "#";

  // enlaces internos
  if (value.startsWith("/")) {
    return value;
  }

  try {
    const parsed = new URL(value);

    if (
      parsed.protocol === "http:" ||
      parsed.protocol === "https:"
    ) {
      return value;
    }

    return "#";
  } catch {
    return "#";
  }
}

const ICONOS_VALIDOS = [
  "facebook",
  "instagram",
  "tiktok",
  "youtube",
  "linkedin",
  "whatsapp",
];

function safeIcon(icon = "") {
  return ICONOS_VALIDOS.includes(icon)
    ? icon
    : "facebook";
}
---

<footer class="footer pt-5 pb-3 mt-5">
  <div class="container">
    <div class="row">

      <!-- Columna 1 -->
      <div class="col-md-4 mb-4">
        <h5 class="fw-bold">
          {footer?.titulo || "Enlaces de interés"}
        </h5>

       <ul class="list-unstyled">
  {footer?.enlaces?.length ? (
    footer.enlaces.map((item:any) => (
      <li>
        <a
          href={safeUrl(item.url)}
          class="footer-link"
        >
          {item.label}
        </a>
      </li>
    ))
  ) : (
    <li>
      <a href="#" class="footer-link">
        Sin enlaces
      </a>
    </li>
  )}
</ul>
      </div>

      <!-- Columna 2 -->
      <div class="col-md-4 mb-4">
        <h5 class="fw-bold">
          {footer?.titulo2 || "Acerca de"}
        </h5>

        <p>
          {footer?.parrafo || "Contenido no disponible"}
        </p>
      </div>

      <!-- Columna 3 -->
      <div class="col-md-4 mb-4">
        <h5 class="fw-bold">
          {footer?.titulo3 || "Redes"}
        </h5>

       <div class="social-icons d-flex gap-3">
  {footer?.social?.map((s:any) => (
    <a
      href={safeUrl(s.url)}
      target="_blank"
      rel="noopener noreferrer"
      class="social-link"
      aria-label={safeIcon(s.icon)}
    >
      <i class={`fab fa-${safeIcon(s.icon)}`}></i>
    </a>
  ))}
</div>
      </div>

    </div>

    <div class="text-center mt-4 small text-secondary">
      © {new Date().getFullYear()} - Todos los derechos reservados
    </div>
  </div>
</footer>