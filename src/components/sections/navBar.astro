---
import Buscador from "../ui/Buscador.astro";
import CarritoCounter from "../ui/carrito/CarritoCounter.astro";
import ThemeToggle from "../ui/themeToggle/ThemeToggle.astro";



const API = "http://localhost:3000";

const resSettings = await fetch(`${API}/api/site-settings`);
const config = await resSettings.json();

const logo = config.site_content?.logo || "/img/logo-default.png";

interface MenuItem {
  url: string;
  titulo: string;
  tipo?: string;
  children?: MenuItem[]; // 🔥 AGREGA ESTO
}

const res = await fetch(`${API}/api/menu`);
const data = await res.json();

const links: MenuItem[] = Array.isArray(data) ? data : [];
---

<nav class="nav-container">

<div class="nav-inner">

<a href="/" class="logo">
  <img src={logo} alt="logo" />
</a>

<div class="nav-links">

{links.map((item) => (

<div class="nav-item">

<a
 href={item.url}
 class={`nav-link 
 ${item.titulo === "categoria" ? "nav-link-categorias" : ""}
 ${item.titulo === "marcas" ? "nav-link-marcas" : ""}
 `}
>
 {item.titulo}
</a>

{/* 🔥 SUBMENÚ DESDE BD */}
{item.children && item.children.length > 0 && (
  <div class="mega-menu">
    {item.children.map(child => (
      <a href={child.url} class="categoria-item">
        {child.titulo}
      </a>
    ))}
  </div>
)}

{/* 🔥 CATEGORÍAS DINÁMICAS */}
{item.titulo === "categoria" && (
  <div id="mega-categorias" class="mega-menu">
    <p>Cargando...</p>
  </div>
)}

{/* 🔥 MARCAS DINÁMICAS */}
{item.titulo === "marcas" && (
  <div id="mega-marcas" class="mega-menu">
    <p>Cargando...</p>
  </div>
)}

</div>

))}

</div>

<div class="buscador-wrapper">
<Buscador />
</div>

<div class="icons">
<CarritoCounter />
<ThemeToggle />
</div>

</div>

</nav>




<style>
/* ------ NAVBAR ------ */
.nav-container {
  position: fixed;
  top: 0;
  width: 100%;
  background: #fff;
  z-index: 3000;
  border-bottom: 1px solid #eee;
   backdrop-filter: blur(10px);
}

.nav-inner {
  max-width: 1400px;
  margin: auto;
  min-height: 80px;
  padding: 10px 25px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.icons {
  display: flex;
  align-items: center;
  gap: 18px;
}

.icons a,
.icons button {
  background: transparent;
  border: none;
  padding: 8px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--color-text);
  transition: all 0.2s ease;
}

.icons a:hover,
.icons button:hover {
  background: var(--color-border);
  transform: translateY(-1px);
}




/* LOGO */
.logo img {
  width: 55px;
  height: 55px;
  border-radius: 12px; /* 🔥 le da estilo moderno */
}

/* LINKS */
.nav-links {
  display: flex;
  gap: 18px;
}

.nav-item {
  position: relative;
}

.nav-link {
  color: #333;
  text-decoration: none;
  padding: 8px 12px;
  border-radius: 6px;
  transition: all 0.2s ease;
  
}

.nav-link:hover {
  background: #f3f3f3;
  transform: translateY(-1px);
}

/* MEGA MENU */
.mega-menu {
  position: absolute;
  top: 50px;
  left: 0;
  width: 230px;
  background: white;
  padding: 10px 0;

  opacity: 0;
  visibility: hidden;
  transform: translateY(10px) scale(0.98);
  filter: blur(2px);

  transition: 
    opacity 0.25s ease,
    transform 0.25s ease,
    filter 0.25s ease,
    visibility 0.25s;

  border-radius: 10px;
  border: 1px solid #e5e5eb;
  box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    pointer-events: none;
}

.mega-menu.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0) scale(1);
  filter: blur(0);
}

:global(.categoria-item) {
  display: block;
  padding: 10px 18px;
  color: #222;
  text-decoration: none;
}

:global(.categoria-item:hover) {
  background: #f7f7f7;
}

/* CARRITO BADGE */
.cart-count-badge {
  position: absolute;
  top: -6px;
  right: -8px;
  background: var(--color-primary);
  color: white;
  font-size: 11px;
  font-weight: 600;
  padding: 2px 6px;
  border-radius: 999px;
  min-width: 18px;
  text-align: center;
  display: none;
}


/* WHATSAPP BUTTON */
.whatsapp-wrapper .whatsapp-float {
  position: fixed;
  bottom: 22px;
  right: 22px;
  width: 62px;
  height: 62px;
  background: #25D366;
  border-radius: 50%;
  color: white !important;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 3000;
}


</style>

<!-- ========== JS MEGA MENÚ ========== -->
<script is:inline>

document.addEventListener("DOMContentLoaded", () => {
  const apiUrl = "http://localhost:3000";

  /* --------------------
     CATEGORÍAS
  ---------------------*/
  const catLink = document.querySelector(".nav-link-categorias");
  const megaCat = document.getElementById("mega-categorias");
  let catLoaded = false;

  async function cargarCategorias() {
    const res = await fetch(apiUrl + "/categorias");
    const cats = await res.json();
    megaCat.innerHTML = cats
      .map(c => `<a href="/productos?categoria=${c.id_categoria}" class="categoria-item">${c.nombre_categoria}</a>`)
      .join("");
    catLoaded = true;
  }

  if (catLink && megaCat) {
    catLink.addEventListener("mouseenter", () => {
      megaCat.classList.add("visible");
      if (!catLoaded) cargarCategorias();
    });

    megaCat.addEventListener("mouseenter", () => megaCat.classList.add("visible"));
    catLink.addEventListener("mouseleave", () => {
      setTimeout(() => {
        if (!megaCat.matches(":hover")) megaCat.classList.remove("visible");
      }, 150);
    });
    megaCat.addEventListener("mouseleave", () => megaCat.classList.remove("visible"));
  }

  /* --------------------
     MARCAS
  ---------------------*/
  const marLink = document.querySelector(".nav-link-marcas");
  const megaMar = document.getElementById("mega-marcas");
  let marLoaded = false;

  async function cargarMarcas() {
    const res = await fetch(apiUrl + "/marcas");
    const marcas = await res.json();
    megaMar.innerHTML = marcas
      .map(m => `<a href="/productos?marca=${m.id_marca}" class="categoria-item">${m.nombre_marca}</a>`)
      .join("");
    marLoaded = true;
  }

  if (marLink && megaMar) {
    marLink.addEventListener("mouseenter", () => {
      megaMar.classList.add("visible");
      if (!marLoaded) cargarMarcas();
    });

    megaMar.addEventListener("mouseenter", () => megaMar.classList.add("visible"));
    marLink.addEventListener("mouseleave", () => {
      setTimeout(() => {
        if (!megaMar.matches(":hover")) megaMar.classList.remove("visible");
      }, 150);
    });
    megaMar.addEventListener("mouseleave", () => megaMar.classList.remove("visible"));
  }
});
</script>























