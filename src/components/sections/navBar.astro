---
import Buscador from "../ui/Buscador.astro";
import CarritoCounter from "../ui/carrito/CarritoCounter.astro";
import ThemeToggle from "../ui/themeToggle/ThemeToggle.astro";
import { loadNavbarData } from "../../api/services/navbar.service";
import { API_URL } from "../../config/api";

/* =========================
   TIPOS
========================= */
interface MenuItem {
  url: string;
  titulo: string;
  tipo?: string;
  children?: MenuItem[];
}

/* =========================
   SSR DATA
========================= */
let logo: string = "";
let links: MenuItem[] = [];

const urlSegura = (url = "") => {
  return /^\/[a-zA-Z0-9/_?=&-]*$/.test(url) ? url : "/";
};

const logoSeguro = (url = "") => {
  return /^(https?:\/\/|\/)[^\s"'<>]+$/.test(url) ? url : "";
};

try {
  const { menu, settings } = await loadNavbarData();

  logo = settings?.logo || settings?.site_content?.logo || logo;
  links = Array.isArray(menu) ? (menu as MenuItem[]) : [];

} catch (error) {
  console.error("Navbar error:", error);
}
---

<nav class="nav-container" data-api-url={API_URL}>

  <div class="nav-inner">

    <!-- LOGO -->
   <a href="/" class="logo">
  {logoSeguro(logo) ? (
  <img src={logoSeguro(logo)} alt="logo" />
) : (
  <span>Logo</span>
)}
</a>

    <!-- LINKS -->
    <div class="nav-links">
      {links.map((item) => (
        <div class="nav-item">

          <a
            href={urlSegura(item.url)}
            class={`nav-link 
            ${item.titulo === "categoria" ? "nav-link-categorias" : ""}
            ${item.titulo === "marcas" ? "nav-link-marcas" : ""}
            `}
          >
            {item.titulo}
          </a>

          {/* SUBMENÚ DESDE BD */}
          {item.children && item.children.length > 0 && (
            <div class="mega-menu">
              {item.children.map(child => (
                <a href={urlSegura(child.url)} class="categoria-item">
                  {child.titulo}
                </a>
              ))}
            </div>
          )}

          {/* CATEGORÍAS DINÁMICAS */}
          {item.titulo === "categoria" && (
            <div id="mega-categorias" class="mega-menu">
              <p>Cargando...</p>
            </div>
          )}

          {/* MARCAS DINÁMICAS */}
          {item.titulo === "marcas" && (
            <div id="mega-marcas" class="mega-menu">
              <p>Cargando...</p>
            </div>
          )}

        </div>
      ))}
    </div>

    <!-- BUSCADOR -->
    <div class="buscador-wrapper">
      <Buscador />
    </div>

    <!-- ICONOS -->
    <div class="icons">
      <CarritoCounter />
      <ThemeToggle />
    </div>

  </div>

</nav>

<style>
/* ------ NAVBAR ------ */
.nav-container {
  position: fixed;
  top: 0;
  width: 100%;
  background: #fff;
  z-index: 3000;
  border-bottom: 1px solid #eee;
  backdrop-filter: blur(10px);
}

.nav-inner {
  max-width: 1400px;
  margin: auto;
  min-height: 80px;
  padding: 10px 25px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.icons {
  display: flex;
  align-items: center;
  gap: 18px;
}

.logo img {
  width: 55px;
  height: 55px;
  border-radius: 12px;
}

.nav-links {
  display: flex;
  gap: 18px;
}

.nav-item {
  position: relative;
}

.nav-link {
  color: #333;
  text-decoration: none;
  padding: 8px 12px;
  border-radius: 6px;
  transition: all 0.2s ease;
}

.nav-link:hover {
  background: #f3f3f3;
}

.mega-menu {
  position: absolute;
  top: 50px;
  left: 0;
  width: 230px;
  background: white;
  padding: 10px 0;
  opacity: 0;
  visibility: hidden;
  transform: translateY(10px);
  transition: all 0.25s ease;
  border-radius: 10px;
  border: 1px solid #e5e5eb;
  box-shadow: 0 10px 30px rgba(0,0,0,0.12);
}

.mega-menu.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

:global(.categoria-item) {
  display: block;
  padding: 10px 18px;
  color: #222;
  text-decoration: none;
}

:global(.categoria-item:hover) {
  background: #f7f7f7;
}
</style>

<!-- JS CLIENTE -->
<script type="module">
document.addEventListener("DOMContentLoaded", () => {

const API_URL = document.querySelector(".nav-container")?.dataset.apiUrl;

if (!API_URL) {
  console.error("No se encontró API_URL en navbar");
  return;
}

  const catLink = document.querySelector(".nav-link-categorias");
  const megaCat = document.getElementById("mega-categorias");

  const marLink = document.querySelector(".nav-link-marcas");
  const megaMar = document.getElementById("mega-marcas");

  let catLoaded = false;
  let marLoaded = false;
  let closeTimer = null;

  function closeAllMenus() {
    megaCat?.classList.remove("visible");
    megaMar?.classList.remove("visible");
  }

  function openMenu(menu) {
    if (closeTimer) {
      clearTimeout(closeTimer);
    }

    closeAllMenus();
    menu?.classList.add("visible");
  }

  function scheduleClose() {
    if (closeTimer) {
      clearTimeout(closeTimer);
    }

    closeTimer = setTimeout(() => {
      closeAllMenus();
    }, 120);
  }

  function cancelClose() {
    if (closeTimer) {
      clearTimeout(closeTimer);
    }
  }


  function crearItemMenu(texto, href) {
  const a = document.createElement("a");
  a.className = "categoria-item";
  a.href = href;
  a.textContent = texto || "Sin nombre";
  return a;
}

function crearMensajeMenu(texto) {
  const p = document.createElement("p");
  p.className = "categoria-item";
  p.textContent = texto;
  return p;
}

function idSeguro(valor) {
  const numero = Number(valor);
  return Number.isInteger(numero) && numero > 0 ? numero : null;
}

  async function cargarCategorias() {
  if (catLoaded || !megaCat) return;

  try {
    const res = await fetch(`${API_URL}/categorias`, {
      credentials: "include",
    });

    const result = await res.json();
    const cats = Array.isArray(result.data) ? result.data : [];

    megaCat.replaceChildren();

    cats.forEach((c) => {
      const id = idSeguro(c.id_categoria);
      if (!id) return;

      megaCat.appendChild(
        crearItemMenu(
          c.nombre_categoria,
          `/productos?categoria=${encodeURIComponent(id)}`
        )
      );
    });

    if (megaCat.children.length === 0) {
      megaCat.appendChild(crearMensajeMenu("No hay categorías"));
    }

    catLoaded = true;
  } catch (error) {
    megaCat.replaceChildren(
      crearMensajeMenu("Error al cargar categorías")
    );
    console.error("Error cargando categorías navbar:", error);
  }
}

  async function cargarMarcas() {
  if (marLoaded || !megaMar) return;

  try {
    const res = await fetch(`${API_URL}/marcas`, {
      credentials: "include",
    });

    const result = await res.json();
    const marcas = Array.isArray(result.data) ? result.data : [];

    megaMar.replaceChildren();

    marcas.forEach((m) => {
      const id = idSeguro(m.id_marca);
      if (!id) return;

      megaMar.appendChild(
        crearItemMenu(
          m.nombre_marca,
          `/productos?marca=${encodeURIComponent(id)}`
        )
      );
    });

    if (megaMar.children.length === 0) {
      megaMar.appendChild(crearMensajeMenu("No hay marcas"));
    }

    marLoaded = true;
  } catch (error) {
    megaMar.replaceChildren(
      crearMensajeMenu("Error al cargar marcas")
    );
    console.error("Error cargando marcas navbar:", error);
  }
}

  if (catLink && megaCat) {
    catLink.addEventListener("mouseenter", async () => {
      openMenu(megaCat);
      await cargarCategorias();
    });

    catLink.addEventListener("mouseleave", scheduleClose);
    megaCat.addEventListener("mouseenter", cancelClose);
    megaCat.addEventListener("mouseleave", scheduleClose);
  }

  if (marLink && megaMar) {
    marLink.addEventListener("mouseenter", async () => {
      openMenu(megaMar);
      await cargarMarcas();
    });

    marLink.addEventListener("mouseleave", scheduleClose);
    megaMar.addEventListener("mouseenter", cancelClose);
    megaMar.addEventListener("mouseleave", scheduleClose);
  }

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeAllMenus();
    }
  });
});
</script>























