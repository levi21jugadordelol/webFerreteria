---

interface Props {
   id: number;
  titulo: string;
  precio: string;
  descripcion?: string;
  imagen: { src: string };
   stock: number;
  agotado?: boolean;
}

const {
  id,
  titulo,
  precio,
  descripcion,
  imagen,
  stock,
  agotado = false
} = Astro.props;
---

<div
  class="product-card ui-card"
  data-producto
  data-id={id}
  data-nombre={titulo}
  data-precio={precio}
  data-imagen={imagen.src}
  data-stock={stock} 
  data-agotado={agotado}
>

  <!-- Imagen -->
  <div class="product-card-img ui-card-img is-cover">
    <img src={imagen.src} alt={titulo} />

    {agotado && (
      <span class="badge-agotado">Agotado</span>
    )}

    {!agotado && (
   <button class="btn-add">
  agregar al carrito
</button>
    )}
  </div>

  <!-- Información -->
  <div class="product-card-body ui-card-body">
    <h5 class="product-title">{titulo}</h5>
    <p class="product-price">{precio}</p>

    {descripcion && (
      <p class="product-desc">{descripcion}</p>
    )}
  </div>

</div>

<style>

.btn-add {
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%) translateY(20px) scale(0.9);

  padding: 10px 18px;
  border-radius: 999px;
  border: none;

  background: linear-gradient(135deg, #ff6600, #ff8533);
  color: white;
  font-weight: 600;
  font-size: 0.85rem;

  box-shadow: 0 8px 20px rgba(255,102,0,0.35);

  opacity: 0;
  transition:
    transform 0.35s cubic-bezier(.2,.8,.2,1),
    opacity 0.25s ease,
    box-shadow 0.25s ease;

  z-index: 10;
}

/* aparece suave */
.product-card-img:hover .btn-add {
  opacity: 1;
  transform: translateX(-50%) translateY(0) scale(1);
}

/* hover del botón */
.btn-add:hover {
  transform: translateX(-50%) scale(1.08);
  box-shadow: 0 12px 30px rgba(255,102,0,0.5);
}
/* =========================
   🧱 CARD BASE
========================= */

.product-card {
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* =========================
   🖼 IMAGEN
========================= */

.product-card-img {
  position: relative;
  height: 260px;
  overflow: hidden;
}

.product-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.product-card:hover img {
  transform: scale(1.05);
}

/* Badge agotado */
.badge-agotado {
  position: absolute;
  top: 12px;
  left: 12px;
  background: #d32f2f;
  color: white;
  padding: 4px 10px;
  font-size: 0.75rem;
  border-radius: 6px;
}


.product-card-img::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0,0,0,0.4),
    rgba(0,0,0,0.05)
  );
  opacity: 0;
  transition: opacity 0.35s ease;

  pointer-events: none; /* 👈 ESTA ES LA CLAVE */
}

.product-card-img:hover::after {
  opacity: 1;
}

.product-card:hover .product-card-img::after {
  opacity: 1;
}


/* =========================
   📝 BODY
========================= */

.product-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.product-title {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-text);
  margin: 0;
}

.product-price {
  font-weight: 700;
  color: var(--color-primary);
  margin: 0;
}

.product-desc {
  font-size: 0.85rem;
  color: var(--color-muted);
  margin: 0;
}

/* =========================
   🌙 DARK MODE
========================= */

html[data-theme="dark"] .badge-agotado {
  background: #ff4d4d;
}
</style>






