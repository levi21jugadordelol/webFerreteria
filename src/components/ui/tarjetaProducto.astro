---
interface Props {
  titulo: string;
  precio: string;
  descripcion?: string;
  imagen: { src: string };
  agotado?: boolean;
}

const {
  titulo,
  precio,
  descripcion,
  imagen,
  agotado = false
} = Astro.props;
---

<div class="product-card ui-card">

  <!-- Imagen -->
  <div class="product-card-img ui-card-img is-cover">
    <img src={imagen.src} alt={titulo} />

    {agotado && (
      <span class="badge-agotado">Agotado</span>
    )}

    {!agotado && (
      <button class="btn-cms btn-primary btn-sm btn-overlay">
        Agregar al carrito
      </button>
    )}
  </div>

  <!-- Información -->
  <div class="product-card-body ui-card-body">
    <h5 class="product-title">{titulo}</h5>
    <p class="product-price">{precio}</p>

    {descripcion && (
      <p class="product-desc">{descripcion}</p>
    )}
  </div>

</div>

<style>
/* =========================
   🧱 CARD BASE
========================= */

.product-card {
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* =========================
   🖼 IMAGEN
========================= */

.product-card-img {
  position: relative;
  height: 260px;
  overflow: hidden;
}

.product-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.product-card:hover img {
  transform: scale(1.05);
}

/* Badge agotado */
.badge-agotado {
  position: absolute;
  top: 12px;
  left: 12px;
  background: #d32f2f;
  color: white;
  padding: 4px 10px;
  font-size: 0.75rem;
  border-radius: 6px;
}

/* Botón overlay */
.btn-overlay {
  position: absolute;
  bottom: -50px;
  left: 50%;
  transform: translateX(-50%);
  opacity: 0;
  transition: all 0.3s ease;
}

.product-card:hover .btn-overlay {
  bottom: 16px;
  opacity: 1;
}

/* =========================
   📝 BODY
========================= */

.product-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.product-title {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-text);
  margin: 0;
}

.product-price {
  font-weight: 700;
  color: var(--color-primary);
  margin: 0;
}

.product-desc {
  font-size: 0.85rem;
  color: var(--color-muted);
  margin: 0;
}

/* =========================
   🌙 DARK MODE
========================= */

html[data-theme="dark"] .badge-agotado {
  background: #ff4d4d;
}
</style>






