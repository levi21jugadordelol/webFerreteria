---
import Hero from "../ui/Hero.astro";
import Button from "../ui/Button.astro";

export const prerender = false;

const API_URL =
  import.meta.env.PUBLIC_API_URL || "http://localhost:3000/api/v1";

const UPLOADS_URL =
  import.meta.env.PUBLIC_UPLOADS_URL || "http://localhost:3000/uploads";

  const imagenHeroSegura = (path = "") => {
  const cleanPath = String(path || "").replace(/^\/+/, "");

  if (!cleanPath) return "/img/no-image.png";
  if (cleanPath.includes("..")) return "/img/no-image.png";

  return `${UPLOADS_URL}/${encodeURIComponent(cleanPath)}`;
};

const urlInternaSegura = (url = "") => {
  return /^\/[a-zA-Z0-9/_?=&-]*$/.test(url) ? url : "#";
};

interface HeroSlide {
  id_hero: number;
  titulo1: string | null;
  titulo2: string | null;
  imagen: string;
  tipo_layout: string;
  mostrar_boton: boolean;
  boton_texto: string | null;
  boton_url: string | null;
  orden: number;
  activo: boolean;
}

let clientes: HeroSlide[] = [];

try {
  const res = await fetch(`${API_URL}/hero?type=carousel`, {
    cache: "no-store",
  });

  if (!res.ok) {
    console.error("Error cargando hero:", res.status, res.statusText);
  } else {
    const result = await res.json();
    clientes = result.data ?? [];
  }
} catch (error) {
  console.error("Error cargando hero:", error);
}
---

<Hero height="500px">

  <div class="testimonio-carousel">

    <!-- SLIDER -->
    <div class="slides-container">
      <div class="slides-wrapper">

        {clientes.map((slide) => (

          <div class="slide">

            {/* 🖼 BANNER */}
            {slide.tipo_layout === "banner" && (
              <div class="w-100 h-100 d-flex align-items-center">

                <img
                  src={imagenHeroSegura(slide.imagen)}
                  alt=""
                  class="img-fluid w-100 rounded"
                  style="height:100%; object-fit:cover;"
                />
              </div>
            )}

            {/* 🎨 IMAGEN + TEXTO */}
        {slide.tipo_layout !== "banner" && (
  <div class="container h-100">
    <div class={`row align-items-center h-100 ${
      slide.tipo_layout === "text-right" ? "flex-row-reverse" : ""
    }`}>



                  <div class="col-lg-7">
                  <img
  src={imagenHeroSegura(slide.imagen)}
  alt=""
  class="w-100"
  style="height:100%; object-fit:cover;"
/>

                  </div>

                  <div class="col-lg-5">

                    {slide.titulo1 && (
                      <p class="hero-subtitle mb-2">

                        {slide.titulo1}
                      </p>
                    )}

                    {slide.titulo2 && (
                      <h1 class="fw-bold mb-3">
                        {slide.titulo2}
                      </h1>
                    )}

                    {slide.mostrar_boton && slide.boton_texto && (
                      <Button href={urlInternaSegura(slide.boton_url ?? "")}>
                        {slide.boton_texto}
                      </Button>
                    )}

                  </div>

                </div>
              </div>
            )}

          </div>

        ))}

      </div>
    </div>

    <!-- INDICADORES -->
   <div class="indicators">
  {clientes.length > 0 &&
    clientes.map((_, index:any) => (
      <span class="dot" data-index={index}></span>
    ))
  }
</div>


  </div>

</Hero>

<style>
.testimonio-carousel {
  height: 100%;
  position: relative;
}


/* Contenedor que oculta lo que se sale */
.slides-container {
  height: 100%;
  overflow: hidden;
}


/* Wrapper que se mueve */
.slides-wrapper {
  display: flex;
  height: 100%;
  transition: transform 0.6s ease;
}

.slide {
  min-width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
}

.slides-container {
  flex: 1;
  overflow: hidden;
  height: 100%;
}

.slide > div {
  width: 100%;
  height: 100%;
}

.slide img {
  height: 100%;
  object-fit: cover;
}



/* Dots */
.indicators {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
  padding: 8px 14px;
  background: rgba(0, 0, 0, 0.6);   /* fondo oscuro */
  backdrop-filter: blur(6px);       /* efecto moderno */
  border-radius: 30px;
  border: 1px solid rgba(255,255,255,0.3);
  z-index: 20;
}

.testimonio-carousel {
  height: 100%;
  position: relative;
}




.dot {
  width: 12px;
  height: 12px;
  background-color: white;
  opacity: 0.6;
  border-radius: 50%;
  cursor: pointer;
  transition: all 0.3s ease;
}
.dot:hover {
  transform: scale(1.2);
}

.dot.active {
  opacity: 1;
  background-color: #7a0c23;
  transform: scale(1.2);
}
</style>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {

  const carousel = document.querySelector(".testimonio-carousel");
  if (!carousel) return;

  const wrapper = carousel.querySelector(".slides-wrapper");
  const slides = carousel.querySelectorAll(".slide");
  const dots = carousel.querySelectorAll(".dot");

  if (!wrapper || slides.length === 0 || dots.length === 0) return;

  let current = 0;

  function goToSlide(index) {
    wrapper.style.transform = `translateX(-${index * 100}%)`;
    dots.forEach(dot => dot.classList.remove("active"));
    dots[index]?.classList.add("active");
    current = index;
  }

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => goToSlide(i));
  });

  goToSlide(0);

});
</script>






