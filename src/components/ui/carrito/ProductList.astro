---
/* NO usar imports aquí para evitar errores 404 */
---

<div class="products-list">
  <h2 class="titulo">Productos</h2>

  <div id="lista-carrito">
    Cargando...
  </div>
</div>

<style is:global>
.products-list {
  background: var(--color-card);
  padding: 1.5rem;
  border-radius: 12px;
  border: 1px solid var(--color-border);
  color: var(--color-text);
}

.product-row {
  display: grid;
  grid-template-columns: 80px 1fr 120px 120px 40px;
  gap: 1rem;
  padding: 1rem 0;
  border-bottom: 1px solid var(--color-border);
}

.product-row img {
  width: 70px;
  height: 70px;
  object-fit: cover;
  border-radius: 8px;
}

.qty-controls button {
  padding: 5px 10px;
  border: 1px solid var(--color-border);
  background: var(--color-input-bg);
  color: var(--color-text);
  cursor: pointer;
  border-radius: 6px;
  transition: 0.2s ease;
}

.qty-controls button:hover {
  background: var(--color-border);
}

.eliminar {
  background: transparent;
  border: none;
  font-size: 1.25rem;
  cursor: pointer;
  color: #d9534f;
}

</style>

<script>
  import carritoStore from "../../../store/carritoStore.js";

  const contenedor = document.getElementById("lista-carrito") as HTMLElement;

  

  function render() {
    const store = carritoStore;
    const carrito = store.get();

    console.log("Carrito:", carrito);

    if (!carrito.length) {
      contenedor.innerHTML = "<p>No hay productos en tu carrito.</p>";
      return;
    }

    contenedor.innerHTML = carrito
      .map(
        (p : any) => `
      <div class="product-row" data-id="${p.id}">
        <img src="${p.imagen}" />
        
        <div>
          <strong>${p.nombre}</strong>
          <p>Precio: S/ ${p.precio}</p>
        </div>

        <div class="qty-controls">
          <button class="menos">-</button>
          <span>${p.cantidad}</span>
          <button class="mas">+</button>
        </div>

        <div><strong>S/ ${(p.precio * p.cantidad).toFixed(2)}</strong></div>

        <button class="eliminar">
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>
    `
      )
      .join("");
  }

  contenedor.addEventListener("click", (e) => {
const target = e.target as HTMLElement;
const row = target.closest(".product-row") as HTMLElement;
    if (!row) return;

    const store = carritoStore;
    const id = row.dataset.id;

    let carrito = store.get();
    let producto = carrito.find((p : any) => p.id == id);
    if (!producto) return;

   

if (target.classList.contains("mas")) producto.cantidad++;

if (target.classList.contains("menos")) {
  producto.cantidad > 1
    ? producto.cantidad--
    : (carrito = carrito.filter((p : any) => p.id != id));
}

if (target.closest(".eliminar")) {
  carrito = carrito.filter((p : any) => p.id != id);
}

    store.save(carrito);
  });

  console.log("✔ carritoStore listo");
  render();

  document.addEventListener("carrito-actualizado", render);
</script>




