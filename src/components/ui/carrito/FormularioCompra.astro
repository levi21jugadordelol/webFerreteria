---
import qrImage from "../../../assets/qrlenin.jpeg";
import carritoStore from "../../../store/carritoStore";
---

<div class="form-container">
  <form id="form-compra" class="form-compra">

    <h3 class="sec-title">Datos de facturación</h3>

    <div class="grid-2">
      <div>
        <label>Nombre *</label>
        <input type="text" id="nombre" required />
      </div>
      <div>
        <label>Apellidos *</label>
        <input type="text" id="apellidos" required />
      </div>
    </div>

    <div>
      <label>Teléfono *</label>
      <input type="tel" id="telefono" required />
    </div>

    <div>
      <label>Dirección *</label>
      <input type="text" id="direccion" required />
    </div>

    <h3 class="sec-title">Método de pago</h3>

    <div class="pago-group">
      <label class="pago-opcion">
        <input type="radio" name="pago" value="transferencia" />
        <span>Transferencia</span>
      </label>

      <label class="pago-opcion">
        <input type="radio" name="pago" value="yape" />
        <span>Yape</span>
      </label>

      <label class="pago-opcion">
        <input type="radio" name="pago" value="contra" />
        <span>Contra entrega</span>
      </label>
    </div>

    <p id="pago-hint" class="pago-hint">
      Selecciona un método de pago para continuar
    </p>

    <!-- DETALLES DE PAGO -->
    <div class="pago-detalle">

      <div id="transferencia-box" class="box hidden">
        <p><strong>Banco:</strong> BCP</p>
        <p><strong>Cuenta:</strong> 123-4567890</p>
        <p><strong>Monto:</strong> S/ <span id="transferencia-monto"></span></p>
      </div>

      <div id="yape-box" class="box hidden">
        <img src={qrImage.src} class="yape-img" />
        <p>Monto: <strong>S/ <span id="yape-monto"></span></strong></p>
      </div>

      <div id="comprobante-box" class="box hidden">
        <label>Sube tu comprobante *</label>

        <!-- 🔥 CLAVE: name="file" para que multer lo reciba -->
        <input
          type="file"
          id="comprobante-file"
          name="file"
          accept="image/*"
        />

        <div id="preview-comprobante"></div>
      </div>

      <div id="contra-box" class="box hidden">
        <a id="btn-whatsapp" target="_blank" class="btn-whatsapp">
          Coordinar por WhatsApp
        </a>
      </div>

    </div>

    <!-- ESTADO DE ENVÍO -->
    <div id="estado-envio" class="estado hidden"></div>

    <button type="submit" class="btn-pedido" id="btn-submit">
      Realizar pedido
    </button>

  </form>
</div>

<style is:global>
.form-container { max-height: 80vh; overflow-y: auto; }
.form-compra {
  background:#fff; padding:1.8rem; border-radius:14px;
  box-shadow:0 12px 30px rgba(0,0,0,.12);
  display:flex; flex-direction:column; gap:1.4rem;
}
.sec-title { font-size:1rem; font-weight:700; }
.form-compra input[type="text"],
.form-compra input[type="tel"],
.form-compra input[type="file"] { width:100%; }
.grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.pago-group { display:flex; flex-direction:column; gap:.7rem; }
.pago-opcion {
  display:flex; align-items:center; gap:.75rem;
  padding:.75rem 1rem; border-radius:8px;
  cursor:pointer; user-select:none;
}
.pago-opcion:hover { background:#f5f7fa; }
.pago-opcion input[type="radio"] { width:auto; margin:0; flex-shrink:0; }
.pago-opcion span { line-height:1.3; text-align:left; }
.pago-hint { font-size:.9rem; color:#666; }
.pago-detalle { display:flex; flex-direction:column; gap:1rem; }
.box { background:#f4f4f4; padding:14px; border-radius:10px; }
.hidden { display:none; }
.yape-img { width:140px; margin:.5rem auto; display:block; }
.btn-pedido {
  margin-top:1rem; padding:14px; font-weight:700; border-radius:10px;
  background:#0d6efd; color:white; border:none; cursor:pointer;
}
.btn-pedido.loading { opacity:.6; cursor:not-allowed; }
.btn-whatsapp {
  display:block; padding:14px; background:#25d366; color:white;
  border-radius:10px; font-weight:700; text-align:center; text-decoration:none;
}
.estado { padding:1rem; border-radius:10px; text-align:center; font-weight:700; }
.estado.loading { background:#fff3cd; color:#856404; }
.estado.success { background:#d4edda; color:#155724; }
.estado.error { background:#f8d7da; color:#721c24; }
</style>

<script is:client>
const form = document.getElementById("form-compra");
const btn = document.getElementById("btn-submit");
const estado = document.getElementById("estado-envio");
const pagoHint = document.getElementById("pago-hint");

const radios = document.querySelectorAll("input[name='pago']");
const yapeBox = document.getElementById("yape-box");
const transferenciaBox = document.getElementById("transferencia-box");
const comprobanteBox = document.getElementById("comprobante-box");
const contraBox = document.getElementById("contra-box");
const comprobanteFile = document.getElementById("comprobante-file");
const preview = document.getElementById("preview-comprobante");
const btnWhatsapp = document.getElementById("btn-whatsapp");

const yapeMonto = document.getElementById("yape-monto");
const transferenciaMonto = document.getElementById("transferencia-monto");

let enviando = false;

// ⚙️ Ajusta tu backend base URL (según tu puerto)
const API_BASE = "http://localhost:3000/api";


function setEstado(tipo, mensaje) {
  estado.className = `estado ${tipo}`;
  estado.textContent = mensaje;
  estado.classList.remove("hidden");
}

function getTotal() {
  return carritoStore.get()
    .reduce((s,p)=>s + p.precio * p.cantidad, 0)
    .toFixed(2);
}

function resetUI() {
  [yapeBox, transferenciaBox, comprobanteBox, contraBox]
    .forEach(b => b.classList.add("hidden"));
  preview.innerHTML = "";
  comprobanteFile.value = "";
}

radios.forEach(radio => {
  radio.addEventListener("change", () => {
    resetUI();
    pagoHint.style.display = "none";

    const total = getTotal();

    if (radio.value === "yape") {
      yapeBox.classList.remove("hidden");
      comprobanteBox.classList.remove("hidden");
      yapeMonto.textContent = total;
    }

    if (radio.value === "transferencia") {
      transferenciaBox.classList.remove("hidden");
      comprobanteBox.classList.remove("hidden");
      transferenciaMonto.textContent = total;
    }

    if (radio.value === "contra") {
      contraBox.classList.remove("hidden");
      btnWhatsapp.href =
        `https://wa.me/51999999999?text=Pedido%20contra%20entrega%20Total:%20S/%20${total}`;
    }
  });
});

// 👀 Preview + log
comprobanteFile.addEventListener("change", () => {
  const file = comprobanteFile.files[0];
  if (!file) return;

  console.log("🖼️ [FRONT] Archivo seleccionado:", {
    name: file.name,
    type: file.type,
    size: file.size
  });

  const reader = new FileReader();
  reader.onload = () => {
    preview.innerHTML =
      `<img src="${reader.result}" style="max-width:100%;border-radius:8px;margin-top:.5rem;">`;
  };
  reader.readAsDataURL(file);
});

// 🔥 helpers fetch
async function postJSON(url, bodyObj) {
  console.log("📤 [FRONT] POST JSON =>", url, bodyObj);

  const res = await fetch(url, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(bodyObj),
  });

  const data = await res.json().catch(() => ({}));
  console.log("📥 [FRONT] Resp JSON <=", res.status, data);

  if (!res.ok) throw new Error(data?.msg || "Error en POST JSON");
  return data;
}

async function postFormData(url, formData) {
  console.log("📤 [FRONT] POST FormData =>", url);

  // log de entries (ojo: file se verá como File)
  for (const [k, v] of formData.entries()) {
    console.log("   ↳", k, v);
  }

  const res = await fetch(url, {
    method: "POST",
    body: formData, // NO headers aquí
  });

  const data = await res.json().catch(() => ({}));
  console.log("📥 [FRONT] Resp FormData <=", res.status, data);

  if (!res.ok) throw new Error(data?.msg || "Error en POST FormData");
  return data;
}

form.addEventListener("submit", async (e) => {
  e.preventDefault();
  if (enviando) return;

  const selected = document.querySelector("input[name='pago']:checked");
  if (!selected) {
    setEstado("error", "Selecciona un método de pago");
    return;
  }

  if (selected.value !== "contra" && !comprobanteFile.files.length) {
    setEstado("error", "Debes subir el comprobante");
    return;
  }

  enviando = true;
  btn.classList.add("loading");
  btn.disabled = true;
  setEstado("loading", "⏳ Enviando pedido...");

  try {
    // 1) Crear pedido (JSON)
    const carrito = carritoStore.get().map(p => ({
      id: p.id,
      cantidad: p.cantidad,
      precio: p.precio
    }));

    const nombre = document.getElementById("nombre").value.trim();
    const apellidos = document.getElementById("apellidos").value.trim();
    const telefono = document.getElementById("telefono").value.trim();
    const direccion = document.getElementById("direccion").value.trim();
    const total = getTotal();

    // ⚠️ Ajusta si tu backend usa "dni" sí o sí.
    // En tu pedidoController pide { nombre, dni, telefono, total, metodo_pago, carrito }
    const pedidoPayload = {
      nombre: `${nombre} ${apellidos}`.trim(),
      dni: "00000000",                 // 🔧 CAMBIA por tu input real si tienes DNI
      telefono,
      total,
      metodo_pago: selected.value,
      carrito,
      direccion,                       // si tu backend no lo usa, no pasa nada
    };

    const pedidoResp = await postJSON(`${API_BASE}/pedidos`, pedidoPayload);

    const pedido_id = pedidoResp?.pedido?.id_pedido || pedidoResp?.pedido?.id;
    console.log("🧾 [FRONT] pedido_id obtenido:", pedido_id);

    if (!pedido_id) {
      throw new Error("No se obtuvo pedido_id del backend");
    }

    // 2) Subir comprobante (FormData) si NO es contra
    if (selected.value !== "contra") {
      const fd = new FormData();
      fd.append("pedido_id", String(pedido_id));
      fd.append("file", comprobanteFile.files[0]); // coincide con multer.single("file")

      await postFormData(`${API_BASE}/pagos/comprobante`, fd);
    }

    // 3) Limpiar y cerrar
    carritoStore.clear();
    setEstado("success", "✅ Pedido enviado correctamente");

    setTimeout(() => {
      document.dispatchEvent(new CustomEvent("cerrar-modal"));
    }, 1200);

  } catch (err) {
    console.error("🔥 [FRONT] Error:", err);
    setEstado("error", `❌ ${err?.message || "Error al enviar"}`);
  } finally {
    enviando = false;
    btn.classList.remove("loading");
    btn.disabled = false;
  }
});
</script>









