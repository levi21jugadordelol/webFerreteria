---
import qrImage from "../../../assets/qrlenin.jpeg";
---

<div class="form-container">
  <form id="form-compra" class="form-compra">

    <h3 class="sec-title">Datos de facturación</h3>

    <div class="grid-2">
      <div>
        <label>Nombre *</label>
        <input type="text" id="nombre" required>
      </div>
      <div>
        <label>Apellidos *</label>
        <input type="text" id="apellidos" required>
      </div>
    </div>

    <div>
      <label>Teléfono *</label>
      <input type="tel" id="telefono" required>
    </div>

    <div>
      <label>Dirección *</label>
      <input type="text" id="direccion" required>
    </div>

    <h3 class="sec-title">Método de pago</h3>

    <div class="pago-group">
      <label class="pago-opcion">
        <input type="radio" name="pago" value="transferencia" checked>
        Transferencia
      </label>

      <label class="pago-opcion">
        <input type="radio" name="pago" value="yape">
        Yape
      </label>

      <label class="pago-opcion">
        <input type="radio" name="pago" value="contra">
        Contra entrega
      </label>
    </div>

    <!-- DETALLES DE PAGO -->
    <div class="pago-detalle">

      <div id="transferencia-box" class="box hidden">
        <p><strong>Banco:</strong> BCP</p>
        <p><strong>Cuenta:</strong> 123-4567890</p>
        <p><strong>Monto:</strong> S/ <span id="transferencia-monto"></span></p>
      </div>

      <div id="yape-box" class="box hidden">
        <img src={qrImage.src} class="yape-img">
        <p>Monto: <strong>S/ <span id="yape-monto"></span></strong></p>
      </div>

      <div id="comprobante-box" class="box hidden">
        <label>Sube tu comprobante *</label>
        <input type="file" id="comprobante-file" accept="image/*">
      </div>

      <div id="contra-box" class="box hidden">
        <a id="btn-whatsapp" target="_blank" class="btn-whatsapp">
          Coordinar por WhatsApp
        </a>
      </div>

    </div>

    <button type="submit" class="btn-pedido" id="btn-submit">
      Realizar pedido
    </button>

  </form>
</div>

<style is:global>
 /* CONTENEDOR */
.form-container {
  max-width: 420px;
  margin: auto;
  padding: 1rem;
}

/* FORMULARIO */
.form-compra {
  background: #ffffff;
  padding: 1.8rem;
  border-radius: 14px;
  box-shadow: 0 12px 30px rgba(0,0,0,.12);
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
}

/* TÍTULOS */
.sec-title {
  font-size: 1rem;
  font-weight: 700;
  margin-top: 1rem;
  margin-bottom: .2rem;
}

/* INPUTS */
.form-compra input[type="text"],
.form-compra input[type="tel"],
.form-compra input[type="file"] {
  width: 100%;
  padding: 12px 14px;
  border-radius: 8px;
  border: 1px solid #dcdcdc;
  font-size: .95rem;
  background: #fafafa;
}

.form-compra input:focus {
  outline: none;
  border-color: #0d6efd;
  background: #fff;
}

/* GRID */
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

/* MÉTODOS DE PAGO */
.pago-group {
  display: flex;
  flex-direction: column;
  gap: .7rem;
}

.pago-opcion {
  display: flex;
  align-items: center;
  gap: .6rem;
  font-weight: 600;
}

/* BLOQUE DE DETALLES */
.pago-detalle {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-top: .5rem;
}

/* CAJAS */
.box {
  background: #f4f4f4;
  padding: 14px;
  border-radius: 10px;
}

/* OCULTAR */
.hidden {
  display: none;
}

/* YAPE */
.yape-img {
  width: 140px;
  margin: .5rem auto;
  display: block;
}

/* BOTÓN */
.btn-pedido {
  margin-top: 1rem;
  padding: 14px;
  font-weight: 700;
  border: none;
  border-radius: 10px;
  background: #0d6efd;
  color: #fff;
  cursor: pointer;
  font-size: 1rem;
}

.btn-pedido.loading {
  opacity: .6;
  cursor: not-allowed;
}

/* WHATSAPP */
.btn-whatsapp {
  display: block;
  padding: 14px;
  background: #25d366;
  color: #fff;
  border-radius: 10px;
  font-weight: 700;
  text-align: center;
  text-decoration: none;
}


</style>

<script is:client>
  const form = document.getElementById("form-compra");
  const btn = document.getElementById("btn-submit");

  const radios = document.querySelectorAll("input[name='pago']");
  const yapeBox = document.getElementById("yape-box");
  const transferenciaBox = document.getElementById("transferencia-box");
  const comprobanteBox = document.getElementById("comprobante-box");
  const contraBox = document.getElementById("contra-box");
  const comprobanteFile = document.getElementById("comprobante-file");
  const btnWhatsapp = document.getElementById("btn-whatsapp");

  const yapeMonto = document.getElementById("yape-monto");
  const transferenciaMonto = document.getElementById("transferencia-monto");

  let enviando = false;

  function getTotal() {
    const carrito = JSON.parse(localStorage.getItem("carrito") || "[]");
    return carrito.reduce((s,p)=>s+p.precio*p.cantidad,0).toFixed(2);
  }

  function resetUI() {
    [yapeBox, transferenciaBox, comprobanteBox, contraBox].forEach(b=>b.classList.add("hidden"));
    comprobanteFile.value = "";
  }

  radios.forEach(radio => {
    radio.addEventListener("change", () => {
      resetUI();
      const total = getTotal();

      if (radio.value === "yape") {
        yapeBox.classList.remove("hidden");
        comprobanteBox.classList.remove("hidden");
        yapeMonto.textContent = total;
      }

      if (radio.value === "transferencia") {
        transferenciaBox.classList.remove("hidden");
        comprobanteBox.classList.remove("hidden");
        transferenciaMonto.textContent = total;
      }

      if (radio.value === "contra") {
        contraBox.classList.remove("hidden");
        btnWhatsapp.href =
          `https://wa.me/51999999999?text=Pedido%20contra%20entrega%20Total:%20S/%20${total}`;
      }
    });
  });

  // estado inicial
  document.querySelector("input[name='pago']:checked")
    ?.dispatchEvent(new Event("change"));

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (enviando) return;

    const metodo = document.querySelector("input[name='pago']:checked").value;

    if ((metodo !== "contra") && !comprobanteFile.files.length) {
      alert("Debes subir el comprobante");
      return;
    }

    // LOADING STATE
    enviando = true;
    btn.classList.add("loading");
    btn.textContent = "Enviando pedido...";
    btn.disabled = true;

    try {
      // aquí va TU fetch real a /pedidos y /pagos
      await new Promise(r => setTimeout(r, 1200)); // simulación
      alert("Pedido enviado correctamente 🎉");
      document.dispatchEvent(new CustomEvent("cerrar-modal"));
    } catch {
      alert("Error al enviar el pedido");
    } finally {
      enviando = false;
      btn.classList.remove("loading");
      btn.textContent = "Realizar pedido";
      btn.disabled = false;
    }
  });
</script>






