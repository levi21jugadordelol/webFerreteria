---
import carritoStore from "../../../store/carritoStore.js";
---

<div class="resumen-container">
  <h2 class="titulo">Resumen de compra</h2>

  <div id="lista-items" class="items"></div>

  <div class="total-box">
    <span>Total:</span>
    <strong id="total-precio">S/ 0.00</strong>
  </div>

  <button id="btn-realizar-compra" class="btn-realizar-compra">
    Realizar compra
  </button>

  <button id="btn-whatsapp" class="btn-realizar-compra" style="background:#25D366;margin-top:10px;">
  💬 Cotizar por WhatsApp
</button>
</div>

<style is:global>
.resumen-container {
  padding: 1.5rem;
  background: var(--color-card);
  border-radius: 12px;
  border: 1px solid var(--color-border);
  color: var(--color-text);
  max-width: 420px;
}

.item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid var(--color-border);
}

.item img {
  width: 60px;
  height: 60px;
  object-fit: cover;
  border-radius: 6px;
}

.item-name {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-text);
}

.item-detail {
  font-size: 0.85rem;
  color: var(--color-muted);
}

.item-subtotal {
  font-weight: 700;
  color: var(--color-primary);
  white-space: nowrap;
}

.total-box {
  margin-top: 1rem;
  font-size: 1.1rem;
  display: flex;
  justify-content: space-between;
}

.btn-realizar-compra {
  width: 100%;
  padding: 14px 0;
  background: var(--color-primary);
  color: white;
  font-size: 1rem;
  font-weight: 700;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  margin-top: 18px;
  transition: 0.2s ease;
}

.btn-realizar-compra:hover {
  opacity: 0.9;
}

</style>

<script is:client type="module">
  const contenedor = document.getElementById("lista-items");
  const totalElemento = document.getElementById("total-precio");

  function renderItem(p) {
    return `
      <div class="item">
        <img src="${p.imagen}" alt="${p.nombre}">
        <div class="item-info">
          <div class="item-name">${p.nombre}</div>
          <div class="item-detail">${p.cantidad} × S/ ${p.precio}</div>
        </div>
        <div class="item-subtotal">S/ ${(p.precio * p.cantidad).toFixed(2)}</div>
      </div>`;
  }

  function actualizarResumen() {
    const carrito = carritoStore.get();

    if (!carrito.length) {
      contenedor.innerHTML = "<p>Tu carrito está vacío.</p>";
      totalElemento.textContent = "S/ 0.00";
      return;
    }

    contenedor.innerHTML = carrito.map(renderItem).join("");
    const total = carrito.reduce((s, p) => s + p.precio * p.cantidad, 0).toFixed(2);
    totalElemento.textContent = "S/ " + total;
  }

  actualizarResumen();
  document.addEventListener("carrito-actualizado", actualizarResumen);

  const btn = document.getElementById("btn-realizar-compra");
  btn?.addEventListener("click", () => {
    const modal = document.getElementById("modal-compra");
    if (modal) {
      modal.classList.add("visible");
      // 🔔 evento CLAVE
      document.dispatchEvent(new CustomEvent("modal-compra-abierto"));
    }
  });

  const btnWhatsApp = document.getElementById("btn-whatsapp");

btnWhatsApp?.addEventListener("click", async () => {

  const carrito = carritoStore.get();

  if (!carrito.length) {
    alert("Tu carrito está vacío");
    return;
  }

let mensaje = "👋 Hola, vi sus productos en la web y me interesa:%0A%0A";

let total = 0;

carrito.forEach(p => {
  mensaje += `- ${p.nombre} (${p.cantidad}) → S/ ${(p.precio * p.cantidad).toFixed(2)}%0A`;
  total += p.precio * p.cantidad;
});

mensaje += `%0ATotal: S/ ${total.toFixed(2)}`;

mensaje += "%0A%0A📲 ¿Me confirmas disponibilidad y tiempo de entrega?";
mensaje += "%0A🚚 ¿Realizan envío a domicilio?";
mensaje += "%0A🙏 Gracias";

  // 🔥 obtener número dinámico (tu sistema ya lo tiene)
  let telefono = "";

  try {
    const res = await fetch("http://localhost:3000/api/site-settings");
    const config = await res.json();
    telefono = config.site_content?.whatsapp || "";
  } catch {}

  if (!telefono) {
    alert("No hay número de WhatsApp configurado");
    return;
  }

  const url = `https://wa.me/${telefono}?text=${mensaje}`;

  window.open(url, "_blank");

});
</script>







