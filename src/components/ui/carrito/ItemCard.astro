---
// Props que recibe
const { nombre, precio, imagen, cantidad } = Astro.props;
---

<div class="item-card">
  <img src={imagen} alt={nombre} />

  <div class="info">
    <h4>{nombre}</h4>
    <p>{cantidad} × S/ {precio}</p>
  </div>

  <div class="subtotal">
    S/ {(precio * cantidad).toFixed(2)}
  </div>
</div>

<style>
.item-card {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #eee;
}

.item-card img {
  width: 55px;
  height: 55px;
  object-fit: cover;
  border-radius: 6px;
}

.info h4 { margin: 0 }
.subtotal { font-weight: bold; color: #0d6efd; }
</style>

