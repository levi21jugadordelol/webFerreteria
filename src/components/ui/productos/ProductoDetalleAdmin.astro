---
const { id } = Astro.props;
const apiUrl = "http://localhost:3000";
---

<section class="bg-white p-4 shadow rounded mb-4">

<h3 class="fw-semibold mb-3">Imágenes adicionales</h3>

<form id="form-img-extra" class="d-flex gap-2 align-items-center">
<input type="file" id="img-extra" class="form-control" />
<button type="submit" class="btn btn-secondary btn-sm">
Subir
</button>
</form>

<div id="lista-imagenes-extra" class="d-flex flex-wrap gap-3 mt-3"></div>

</section>


<section class="bg-white p-4 shadow rounded">

<div class="d-flex justify-content-between align-items-center mb-3">
<h3 class="fw-semibold mb-0">Características</h3>
<small id="contador-carac" class="text-muted"></small>
</div>


<form id="form-carac" class="row g-3 align-items-end mb-4">

<div class="col-md-3">
<label class="form-label fw-semibold">Tipo</label>
<select id="carac-tab" class="form-select"></select>
</div>

<div class="col-md-3">
<label class="form-label fw-semibold">Característica</label>
<input type="text" id="carac-titulo" class="form-control" required />
</div>

<div class="col-md-3">
<label class="form-label fw-semibold">Valor</label>
<input type="text" id="carac-valor" class="form-control" required />
</div>

<div class="col-md-1">
<label class="form-label fw-semibold">Orden</label>
<input type="number" id="carac-orden" class="form-control" value="0" />
</div>

<div class="col-md-2">
<button class="btn btn-primary w-100" type="submit">
Agregar
</button>
</div>

</form>


<div class="table-responsive">

<table class="table table-sm align-middle mb-0" id="tabla-caracteristicas">

<thead class="table-light">
<tr>
<th style="width:20%">Tipo</th>
<th style="width:10%">Orden</th>
<th style="width:30%">Característica</th>
<th style="width:25%">Valor</th>
<th class="text-end" style="width:15%">Acciones</th>
</tr>
</thead>

<tbody></tbody>

</table>

</div>

</section>


<script is:client>

const apiUrl = "http://localhost:3000";

let tabsCache = [];

/* =====================================
CARGAR TABS
===================================== */

async function cargarTabs(){

const res = await fetch(`${apiUrl}/producto-tabs`);
tabsCache = await res.json();

const select = document.getElementById("carac-tab");

select.innerHTML = tabsCache.map(tab=>`
<option value="${tab.id_tab}">
${tab.nombre}
</option>
`).join("");

activarPlaceholder();

}

/* =====================================
PLACEHOLDER INTELIGENTE
===================================== */

const tituloInput = document.getElementById("carac-titulo");
const valorInput = document.getElementById("carac-valor");

const placeholders = {

especificaciones:{
titulo:"Ej: Material",
valor:"Ej: Acero"
},

caracteristicas:{
titulo:"Ej: Uso",
valor:"Ej: Interior"
},

garantia:{
titulo:"Ej: Tiempo",
valor:"Ej: 12 meses"
},

manual:{
titulo:"Ej: Descarga",
valor:"Ej: manual.pdf"
}

};

function activarPlaceholder(){

const select = document.getElementById("carac-tab");

const nombre = select.options[select.selectedIndex]
  .text
  .toLowerCase()
  .normalize("NFD")
  .replace(/[\u0300-\u036f]/g, "");

if(placeholders[nombre]){

tituloInput.placeholder = placeholders[nombre].titulo;
valorInput.placeholder = placeholders[nombre].valor;

}

}

document.getElementById("carac-tab").addEventListener("change",activarPlaceholder);


/* =====================================
PRODUCTO
===================================== */

const productoId = Number(
document.getElementById("producto-detalle").dataset.id
);


async function obtenerProductoDetalle(){

const res = await fetch(`${apiUrl}/productos/${productoId}/caracteristicas`);

if(!res.ok) throw new Error("No se pudo cargar producto");

return res.json();

}


/* =====================================
CARGAR CARACTERISTICAS
===================================== */

async function cargarCaracteristicas(){

const tbody = document.querySelector("#tabla-caracteristicas tbody");
const contador = document.getElementById("contador-carac");

const prod = await obtenerProductoDetalle();

if(!prod || prod.length===0){

contador.textContent="";

tbody.innerHTML=`
<tr>
<td colspan="5" class="text-center py-4 text-muted">
No hay características agregadas
</td>
</tr>
`;

return;

}

contador.textContent = `${prod.length} registradas`;

tbody.innerHTML = prod.map(c=>`

<tr data-id="${c.id_caracteristica}">

<td class="carac-tipo">${c.tab?.nombre ?? "Tab"}</td>

<td class="carac-orden">${c.orden ?? 0}</td>

<td class="fw-semibold carac-titulo">${c.titulo}</td>

<td class="carac-valor">${c.valor}</td>

<td class="text-end">

<button class="btn btn-sm btn-outline-primary btn-edit-carac">✏</button>

<button class="btn btn-sm btn-danger btn-del-carac" data-id="${c.id_caracteristica}">✕</button>

</td>

</tr>

`).join("");

activarEliminar();
activarEdicion();

}


/* =====================================
ELIMINAR
===================================== */

function activarEliminar(){

document.querySelectorAll(".btn-del-carac").forEach(btn=>{

btn.addEventListener("click",async(e)=>{

const idCarac = e.currentTarget.dataset.id;

if(!confirm("¿Eliminar característica?")) return;

await fetch(
`${apiUrl}/productos/admin/${productoId}/caracteristicas/${idCarac}`,
{method:"DELETE",credentials:"include"}
);

cargarCaracteristicas();

});

});

}


/* =====================================
EDITAR
===================================== */

function activarEdicion(){

document.querySelectorAll(".btn-edit-carac").forEach(btn=>{

btn.addEventListener("click",e=>{

const row = e.currentTarget.closest("tr");

const tipoTd = row.querySelector(".carac-tipo");
const ordenTd = row.querySelector(".carac-orden");
const tituloTd = row.querySelector(".carac-titulo");
const valorTd = row.querySelector(".carac-valor");

const ordenActual = ordenTd.textContent.trim();
const tituloActual = tituloTd.textContent.trim();
const valorActual = valorTd.textContent.trim();

tipoTd.innerHTML = `
<select class="form-select form-select-sm edit-tab">
${tabsCache.map(tab=>`
<option value="${tab.id_tab}">
${tab.nombre}
</option>
`).join("")}
</select>
`;

ordenTd.innerHTML=`<input type="number" class="form-control form-control-sm edit-orden" value="${ordenActual}">`;

tituloTd.innerHTML=`<input type="text" class="form-control form-control-sm edit-titulo" value="${tituloActual}">`;

valorTd.innerHTML=`<input type="text" class="form-control form-control-sm edit-valor" value="${valorActual}">`;

const accionesTd = row.querySelector("td.text-end");

accionesTd.innerHTML=`
<button class="btn btn-sm btn-success btn-save-carac">💾</button>
<button class="btn btn-sm btn-secondary btn-cancel-carac">↩</button>
`;

accionesTd.querySelector(".btn-save-carac").addEventListener("click",async()=>{

const nuevoTab = row.querySelector(".edit-tab").value;
const nuevoOrden = row.querySelector(".edit-orden").value;
const nuevoTitulo = row.querySelector(".edit-titulo").value.trim();
const nuevoValor = row.querySelector(".edit-valor").value.trim();
const idCarac = row.dataset.id;

await fetch(
`${apiUrl}/productos/admin/${productoId}/caracteristicas/${idCarac}`,
{
method:"PUT",
headers:{ "Content-Type":"application/json" },
credentials:"include",
body:JSON.stringify({
titulo:nuevoTitulo,
valor:nuevoValor,
tab_id:nuevoTab,
orden:nuevoOrden
})
}
);

cargarCaracteristicas();

});

accionesTd.querySelector(".btn-cancel-carac")
.addEventListener("click",cargarCaracteristicas);

});

});

}


/* =====================================
CREAR
===================================== */

document.getElementById("form-carac")
.addEventListener("submit",async e=>{

e.preventDefault();

const tab_id = document.getElementById("carac-tab").value;

const titulo = tituloInput.value.trim();
const valor = valorInput.value.trim();
const orden = document.getElementById("carac-orden").value;

await fetch(
`${apiUrl}/productos/admin/${productoId}/caracteristicas`,
{
method:"POST",
headers:{ "Content-Type":"application/json" },
credentials:"include",
body:JSON.stringify({
titulo,
valor,
tab_id,
orden
})
}
);

tituloInput.value="";
valorInput.value="";
document.getElementById("carac-orden").value=0;

cargarCaracteristicas();

});


/* =====================================
INIT
===================================== */

document.addEventListener("DOMContentLoaded",async()=>{

await cargarTabs();
await cargarCaracteristicas();

});

</script>



