---
const { id } = Astro.props;
const apiUrl = "http://localhost:3000";
---

<!-- ========================= -->
<!-- 🖼️ IMÁGENES ADICIONALES -->
<!-- ========================= -->
<section class="bg-white p-4 shadow rounded mb-4">
  <h3 class="fw-semibold mb-3">Imágenes adicionales</h3>

  <form id="form-img-extra" class="d-flex gap-2 align-items-center">
    <input type="file" id="img-extra" class="form-control" />
    <button type="submit" class="btn btn-secondary btn-sm">
      Subir
    </button>
  </form>

  <div id="lista-imagenes-extra" class="d-flex flex-wrap gap-3 mt-3"></div>
</section>

<!-- ========================= -->
<!-- 🧾 CARACTERÍSTICAS -->
<!-- ========================= -->
<section class="bg-white p-4 shadow rounded">

  <!-- Header con contador -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="fw-semibold mb-0">Características</h3>
    <small id="contador-carac" class="text-muted"></small>
  </div>

  <!-- Formulario -->
  <form id="form-carac" class="row g-3 align-items-end mb-4">
    <div class="col-md-5">
      <label class="form-label fw-semibold">
        Nombre de la característica
      </label>
      <input
        type="text"
        id="carac-titulo"
        class="form-control"
        placeholder="Ej: Material, Dimensiones, Peso..."
        required
      />
    </div>

    <div class="col-md-5">
      <label class="form-label fw-semibold">Valor</label>
      <input
        type="text"
        id="carac-valor"
        class="form-control"
        placeholder="Ej: Algodón, 20cm x 15cm, 1.2kg..."
        required
      />
    </div>

    <div class="col-md-2">
      <button class="btn btn-primary w-100" type="submit">
        Agregar
      </button>
    </div>
  </form>

  <!-- Tabla -->
  <div class="table-responsive">
    <table class="table table-sm align-middle mb-0" id="tabla-caracteristicas">
      <thead class="table-light">
        <tr>
          <th style="width:40%">Característica</th>
          <th style="width:45%">Valor</th>
          <th class="text-end" style="width:15%">Acciones</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>

</section>

<script is:client>
  const apiUrl = "http://localhost:3000";
  const productoId = Number(
    document.getElementById("producto-detalle").dataset.id
  );

  // =========================================
  // 🔵 Obtener producto completo
  // =========================================
  async function obtenerProductoDetalle() {
    const res = await fetch(`${apiUrl}/productos/${productoId}`);
    if (!res.ok) throw new Error("No se pudo cargar el producto");
    return res.json();
  }

  // =========================================
  // 🔵 Cargar características
  // =========================================
  async function cargarCaracteristicas() {
  const tbody = document.querySelector("#tabla-caracteristicas tbody");
  const contador = document.getElementById("contador-carac");
  const prod = await obtenerProductoDetalle();

  if (!prod.caracteristicas || prod.caracteristicas.length === 0) {
    contador.textContent = "";
    tbody.innerHTML = `
      <tr>
        <td colspan="3" class="text-center py-4 text-muted">
          No hay características agregadas
        </td>
      </tr>
    `;
    return;
  }

  contador.textContent = `${prod.caracteristicas.length} registradas`;

  tbody.innerHTML = prod.caracteristicas
    .map(
      (c) => `
    <tr data-id="${c.id_caracteristica}">
      <td class="fw-semibold carac-titulo">${c.titulo}</td>
      <td class="carac-valor">${c.valor}</td>
      <td class="text-end">
        <button
          class="btn btn-sm btn-outline-primary btn-edit-carac"
          title="Editar"
        >
          ✏
        </button>
        <button
          class="btn btn-sm btn-danger btn-del-carac"
          data-id="${c.id_caracteristica}"
          title="Eliminar"
        >
          ✕
        </button>
      </td>
    </tr>
  `
    )
    .join("");

  // -------------------------
  // ELIMINAR
  // -------------------------
  tbody.querySelectorAll(".btn-del-carac").forEach((btn) =>
    btn.addEventListener("click", async (e) => {
      const idCarac = e.currentTarget.dataset.id;

      if (!confirm("¿Eliminar característica?")) return;

      const r = await fetch(
        `${apiUrl}/productos/admin/${productoId}/caracteristicas/${idCarac}`,
        {
          method: "DELETE",
          credentials: "include",
        }
      );

      if (!r.ok) return alert("Error al eliminar característica");

      cargarCaracteristicas();
    })
  );

  // -------------------------
  // EDITAR
  // -------------------------
  tbody.querySelectorAll(".btn-edit-carac").forEach((btn) =>
    btn.addEventListener("click", (e) => {
      const row = e.currentTarget.closest("tr");
      const tituloTd = row.querySelector(".carac-titulo");
      const valorTd = row.querySelector(".carac-valor");

      const tituloActual = tituloTd.textContent.trim();
      const valorActual = valorTd.textContent.trim();

      tituloTd.innerHTML = `
        <input type="text" 
               class="form-control form-control-sm edit-titulo"
               value="${tituloActual}">
      `;

      valorTd.innerHTML = `
        <input type="text" 
               class="form-control form-control-sm edit-valor"
               value="${valorActual}">
      `;

      const accionesTd = row.querySelector("td.text-end");

      accionesTd.innerHTML = `
        <button class="btn btn-sm btn-success btn-save-carac">💾</button>
        <button class="btn btn-sm btn-secondary btn-cancel-carac">↩</button>
      `;

      // Guardar
      accionesTd.querySelector(".btn-save-carac")
        .addEventListener("click", async () => {

          const nuevoTitulo =
            row.querySelector(".edit-titulo").value.trim();
          const nuevoValor =
            row.querySelector(".edit-valor").value.trim();

          const idCarac = row.dataset.id;

          if (!nuevoTitulo || !nuevoValor) return;

          const r = await fetch(
            `${apiUrl}/productos/admin/${productoId}/caracteristicas/${idCarac}`,
            {
              method: "PUT",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify({
                titulo: nuevoTitulo,
                valor: nuevoValor,
              }),
            }
          );

          if (!r.ok) return alert("Error al actualizar");

          cargarCaracteristicas();
        });

      // Cancelar
      accionesTd.querySelector(".btn-cancel-carac")
        .addEventListener("click", () => {
          cargarCaracteristicas();
        });
    })
  );
}


  // =========================================
  // 🔵 Eventos
  // =========================================
  document.addEventListener("DOMContentLoaded", () => {
    cargarCaracteristicas();

    document
      .getElementById("form-carac")
      .addEventListener("submit", async (e) => {
        e.preventDefault();

        const titulo = document.getElementById("carac-titulo").value.trim();
        const valor = document.getElementById("carac-valor").value.trim();
        if (!titulo || !valor) return;

        const res = await fetch(
          `${apiUrl}/productos/admin/${productoId}/caracteristicas`,
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({ titulo, valor }),
          }
        );

        if (!res.ok) return alert("Error al agregar característica");

        document.getElementById("carac-titulo").value = "";
        document.getElementById("carac-valor").value = "";

        cargarCaracteristicas();
      });
  });
</script>



