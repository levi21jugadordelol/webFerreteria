---
const { id, titulo, precio, imagen } = Astro.props;
const imgSrc = imagen?.src ?? "/img/no-image.png";
---

<div 
  class="card-simple"
  data-producto
  data-id={id}
  data-nombre={titulo}
  data-precio={precio}
  data-imagen={imgSrc}
>
  <div class="card-img">
    <img src={imgSrc} alt={titulo} />
    <button class="btn-add">Agregar al carrito</button>
  </div>

  <div class="card-info">
    <h3>{titulo}</h3>
    <p class="precio">S/ {precio}</p>
  </div>
</div>

<style>
.card-simple {
  background: #fff;
  border-radius: 10px;
  overflow: hidden;
  text-align: center;
  border: 1px solid #e5e5e5;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  cursor: pointer;
}

.card-simple:hover {
  transform: translateY(-4px);
  box-shadow: 0 6px 18px rgba(0,0,0,0.12);
}

.card-img {
  position: relative;
  height: 240px;
  overflow: hidden;
  width: 100%;
  background: #fff;
}

.card-img img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.btn-add {
  position: absolute;
  bottom: -60px;
  left: 50%;
  transform: translateX(-50%);
  opacity: 0;
  background: #007bff;
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 0.6rem 1.2rem;
  font-size: 0.9rem;
  transition: all 0.4s ease;
}

.card-simple:hover .btn-add {
  bottom: 1rem;
  opacity: 1;
}

.card-info {
  padding: 1rem;
}

.card-info h3 {
  font-size: 1rem;
  font-weight: 600;
  color: #222;
  margin-bottom: 0.3rem;
}

.precio {
  font-size: 1.1rem;
  font-weight: 700;
  color: #0d6efd;
  margin: 0;
}
</style>

<!-- SOLO REFERENCIA AL ARCHIVO addToCart.js -->
<script is:client type="module" src="/src/js/addToCart.js"></script>







