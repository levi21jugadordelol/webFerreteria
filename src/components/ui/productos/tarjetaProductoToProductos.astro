---
const { id, titulo, precio, imagen, agotado = false } = Astro.props;
const imgSrc = imagen?.src ?? "/img/no-image.png";
---


<div
  class="card-simple"
  data-producto
  data-id={id}
  data-nombre={titulo}
  data-precio={precio}
  data-imagen={imgSrc}
  data-agotado={agotado}  
>

  <!-- Navegar -->
  <a href={`/productos/${id}`} class="card-link">
   <div class="card-img">
  <img src={imgSrc} alt={titulo} />

  {agotado && (
    <span class="badge-agotado">
      AGOTADO
    </span>
  )}
</div>


    <div class="card-info">
      <h3>{titulo}</h3>
      <p class="precio">S/ {precio}</p>
    </div>
  </a>

  <!-- Carrito -->
  <button
  class="btn-add"
  disabled={agotado}
>
  {agotado ? "Sin stock" : "Agregar al carrito"}
</button>

</div>


<style>
.card-img {
  position: relative;
  height: 240px;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  overflow: hidden;
}

.card-img img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}



.card-simple:hover {
  transform: translateY(-4px);
  box-shadow: 0 6px 18px rgba(0,0,0,0.12);
}

.card-img {
  position: relative;
  height: 240px;
  overflow: hidden;
  width: 100%;
  background: #fff;
}

.card-img img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.btn-add {
  position: absolute;
  bottom: -60px;
  left: 50%;
  transform: translateX(-50%);
  opacity: 0;
  background: #007bff;
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 0.6rem 1.2rem;
  font-size: 0.9rem;
  transition: all 0.4s ease;
}

.card-simple:hover .btn-add {
  bottom: 1rem;
  opacity: 1;
}

.card-info {
  padding: 1rem;
}

.card-info h3 {
  font-size: 1rem;
  font-weight: 600;
  color: #222;
  margin-bottom: 0.3rem;
}

.precio {
  font-size: 1.1rem;
  font-weight: 700;
  color: #0d6efd;
  margin: 0;
}

.badge-agotado {
  position: absolute;
  top: 10px;
  left: 10px;
  background: rgba(220, 53, 69, 0.95);
  color: white;
  padding: 0.4rem 0.7rem;
  font-size: 0.75rem;
  font-weight: 700;
  border-radius: 6px;
  z-index: 2;
}

.btn-add:disabled {
  background: #aaa;
  cursor: not-allowed;
  opacity: 0.8;
}

</style>










