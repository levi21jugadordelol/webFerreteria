---
import Title from "../shared/Title.astro";

const { title, cantidad, imageUrl } = Astro.props;
---

<div class="card-wrapper">
  <div class="card_rubro">
    <div class="card_rubro-image">
      <img src={imageUrl} alt={title} class="card-img" />
    </div>
  </div>

  <div class="card_rubro-info">
    <Title>{title}</Title>
    <p class="cantidad">{cantidad ?? ""}</p>
  </div>
</div>

<style>
.card-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  overflow: hidden;
  width: 100%;        /* 🔥 que pueda adaptarse al carrusel */
   scroll-snap-align: start;
  
}

/* 🔹 El card ahora ocupa SIEMPRE el ancho que le asigne el carrusel */
.card_rubro {
  width: 100%;
  height: 260px;
  border-radius: 12px;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
}

.card_rubro-image {
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.card_rubro-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.card_rubro:hover img {
  transform: scale(1.05);
}

.card_rubro-info {
  text-align: center;
  padding: 0.8rem;
}

.card_rubro-info h1,
.card_rubro-info h2,
.card_rubro-info h3 {
  font-size: 1.1rem;
  font-weight: 700;
  color: #222;
  margin: 0;
}

.cantidad {
  font-size: 0.9rem;
  font-weight: 500;
  color: #0077cc;
  margin-top: 0.4rem;
}
</style>





