---
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Marca {
  id_marca: number;
  nombre_marca: string;
  descripcion: string | null;
  url_logo: string | null;
}

const apiUrl = "http://localhost:3000";

const res = await fetch(apiUrl + "/marcas");
const marcas: Marca[] = await res.json();
---

<BaseLayout title="Marcas">

  <div class="container py-5">

    <h2 class="mb-4 fw-bold text-center section-title">
      Nuestras Marcas
    </h2>

   <div class="row g-4">

  {marcas.map((m) => (
    <div class="col-6 col-md-4 col-lg-3">
      <a 
        href={`/productos?marca=${m.id_marca}`}
        class="ui-card text-decoration-none"
      >

        <div class="ui-card-img is-contain">
          <img 
            src={m.url_logo 
              ? `${apiUrl}/uploads/${m.url_logo}` 
              : "/img/no-image.png"}
            alt={m.nombre_marca}
          />
        </div>

        <div class="ui-card-body">
          <h5>{m.nombre_marca}</h5>
        </div>

      </a>
    </div>
  ))}

</div>



  </div>

</BaseLayout>


