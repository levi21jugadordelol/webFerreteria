---
import NavBar from "../../components/sections/navBar.astro";

interface Marca {
  id_marca: number;
  nombre_marca: string;
  descripcion: string | null;
  url_logo: string | null;
}

const apiUrl = "http://localhost:3000";

// Fetch marcas
const res = await fetch(apiUrl + "/marcas");
const marcas: Marca[] = await res.json();
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Marcas</title>

  <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
    rel="stylesheet" 
  />

  <link 
    rel="stylesheet" 
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" 
  />
</head>

<body class="bg-light" style="padding-top: 90px;">

  <!-- NAVBAR -->
  <header>
    <NavBar />
  </header>

  <!-- CONTENIDO -->
  <main class="container py-5">

    <h2 class="mb-4 fw-bold text-center">Nuestras Marcas</h2>

    <div class="row g-4">

      {marcas.map((m) => (
        <div class="col-6 col-md-4 col-lg-3">
          <a 
            href={`/productos?marca=${m.id_marca}`}
            class="card marca-card text-decoration-none"
          >

            <div class="marca-img">
              <img 
                src={m.url_logo ? `${apiUrl}/uploads/${m.url_logo}` : "/img/no-image.png"}
                alt={m.nombre_marca}
              />
            </div>

            <div class="p-3 text-center">
              <h5 class="text-dark fw-semibold">{m.nombre_marca}</h5>
            </div>

          </a>
        </div>
      ))}

    </div>

  </main>

</body>
</html>

<style>
.marca-card {
  background: white;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid #e5e5e5;
  transition: transform .2s, box-shadow .2s;
}

.marca-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 6px 18px rgba(0,0,0,0.12);
}

.marca-img {
  width: 100%;
  height: 180px;
  overflow: hidden;
  background: #fff;
}

.marca-img img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}
</style>

