---
const apiUrl = "http://localhost:3000";

const q = Astro.url.searchParams.get("q") || "";
let productos = [];

if (q) {
  const res = await fetch(`${apiUrl}/productos?search=${encodeURIComponent(q)}`);
  productos = await res.json();
}
---

<h2>Resultados de búsqueda para: <strong>{q}</strong></h2>

{productos.length === 0 && (
  <p class="text-muted">No se encontraron productos.</p>
)}

<div class="productos-grid">
  {productos.map((p: any) => (
    <a href={`/producto/${p.id_producto}`} class="producto-card">
      <img src={`${apiUrl}/uploads/${p.url_imagen}`} alt={p.nombre_producto}/>
      <h4>{p.nombre_producto}</h4>
      <p>S/ {p.precio}</p>
    </a>
  ))}
</div>


<style>
.productos-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 18px;
  margin-top: 20px;
}
.producto-card {
  padding: 10px;
  border-radius: 8px;
  border: 1px solid #ddd;
  text-decoration: none;
  color: #222;
}
.producto-card:hover {
  border-color: #0d6efd;
}
.producto-card img {
  width: 100%;
  height: 160px;
  object-fit: cover;
  border-radius: 6px;
}
</style>
