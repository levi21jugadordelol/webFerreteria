---
import AdminLayout from "../../layouts/AdminLayout.astro";

const API_URL = "http://localhost:3000";

const res = await fetch(`${API_URL}/api/site-settings`);
const config = await res.json();

const whatsapp = config.site_content?.whatsapp ?? "";

// NUEVO
const mostrarEspecificaciones =
  config.product_settings?.mostrar_especificaciones ?? true;

const mostrarCaracteristicas =
  config.product_settings?.mostrar_caracteristicas ?? true;
---

<AdminLayout title="Configuración del sitio">

<div class="container-fluid" style="max-width:700px">

  <!-- CONTACTO -->
  <div class="card shadow-sm mb-4">

    <div class="card-header bg-light fw-bold">
      <i class="bi bi-whatsapp"></i> Contacto
    </div>

    <div class="card-body">

      <form id="settingsForm">

        <div class="mb-3">

          <label class="form-label fw-semibold">
            Número de WhatsApp
          </label>

          <input
            type="text"
            name="whatsapp"
            class="form-control"
            value={whatsapp}
            placeholder="51987654321"
          />

          <small class="text-muted">
            Ejemplo: 51987654321
          </small>

        </div>

        <!-- CONFIGURACIÓN PRODUCTO -->
        <hr class="my-4">

        <h6 class="fw-bold mb-3">
          Configuración de producto
        </h6>

        <div class="form-check form-switch mb-3">
          <input
            class="form-check-input"
            type="checkbox"
            id="mostrar_especificaciones"
            checked={mostrarEspecificaciones}
          >
          <label class="form-check-label fw-semibold">
            Mostrar Especificaciones en página de producto
          </label>
        </div>

        <div class="form-check form-switch mb-4">
          <input
            class="form-check-input"
            type="checkbox"
            id="mostrar_caracteristicas"
            checked={mostrarCaracteristicas}
          >
          <label class="form-check-label fw-semibold">
            Mostrar Características en página de producto
          </label>
        </div>

        <button class="btn btn-primary">
          <i class="bi bi-save"></i> Guardar configuración
        </button>

      </form>

    </div>

  </div>

  <div id="mensaje"></div>

</div>

<script is:inline>

const form = document.getElementById("settingsForm");

form.addEventListener("submit", async (e) => {

  e.preventDefault();

  const whatsapp = form.whatsapp.value;

  const mostrar_especificaciones =
    document.getElementById("mostrar_especificaciones").checked;

  const mostrar_caracteristicas =
    document.getElementById("mostrar_caracteristicas").checked;

 const res = await fetch("http://localhost:3000/api/site-settings", {
  method: "PUT",
  credentials: "include",
  headers: {
    "Content-Type": "application/json"
  },
  body: JSON.stringify({
    site_content:{
      whatsapp
    },
    product_settings:{
      mostrar_especificaciones,
      mostrar_caracteristicas
    }
  })
});

  if (!res.ok) {
  const err = await res.json();

  document.getElementById("mensaje").innerHTML =
    `<div class="alert alert-danger">${err.msg}</div>`;

  return;
}

const data = await res.json();

document.getElementById("mensaje").innerHTML =
  `<div class="alert alert-success">${data.msg}</div>`;

});

</script>

</AdminLayout>