---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Validar Comprobantes de Pago">
  <div id="app-comprobantes" class="table-responsive"></div>
</AdminLayout>

<script is:client>
const API_BASE = "http://localhost:3000/api/pagos";
const container = document.getElementById("app-comprobantes");

/* 🔥 AQUÍ VA */
async function fetchJSON(url, options = {}) {
  const res = await fetch(url, {
    credentials: "include", // 👈 ENVÍA COOKIES (_token)
    ...options,
  });

  if (!res.ok) {
    const text = await res.text();
    throw new Error(text || "Error en la API");
  }

  return res.json();
}

/* 📥 Cargar comprobantes */
async function cargarComprobantes() {
  try {
    const data = await fetchJSON(`${API_BASE}/admin/lista`);

    if (!Array.isArray(data) || data.length === 0) {
      container.innerHTML = "<p>No hay comprobantes</p>";
      return;
    }

    container.innerHTML = `
      <table class="table table-striped">
        <thead>
          <tr>
            <th>ID</th>
            <th>Pedido</th>
            <th>Cliente</th>
            <th>Dirección</th>
            <th>Total</th>
            <th>Imagen</th>
            <th>Estado Pago</th>
<th>Estado Pedido</th>

            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          ${data.map(c => `
            <tr>
              <td>${c.id_comprobante}</td>
              <td>#${c.pedido.id_pedido}</td>
              <td>${c.pedido.nombre_comprador}</td>
              <td>${c.pedido.direccion_envio}</td>
              <td>S/ ${c.pedido.total_pedido}</td>
              <td>
                <a href="http://localhost:3000${c.url_imagen}" target="_blank">
                  Ver
                </a>
              </td>
             <td>
  <span class="badge bg-${
    c.estado_validacion === "validado"
      ? "success"
      : c.estado_validacion === "rechazado"
      ? "danger"
      : "warning"
  }">
    ${c.estado_validacion}
  </span>
</td>

<td>
  <span class="badge bg-${
    c.pedido.estado_pedido === "pagado"
      ? "success"
      : "secondary"
  }">
    ${c.pedido.estado_pedido}
  </span>
</td>

<td>
  ${
    c.estado_validacion === "pendiente"
      ? `
        <button class="btn btn-success btn-sm"
          onclick="validar(${c.id_comprobante})">
          Validar
        </button>
        <button class="btn btn-danger btn-sm"
          onclick="rechazar(${c.id_comprobante})">
          Rechazar
        </button>
      `
      : c.estado_validacion === "validado"
      ? `
        <button class="btn btn-warning btn-sm"
          onclick="revertir(${c.id_comprobante})">
          Revertir
        </button>
      `
      : `
        <span class="text-muted fw-bold">
          Acción completada
        </span>
      `
  }
</td>


            </tr>
          `).join("")}
        </tbody>
      </table>
    `;
  } catch (err) {
    container.innerHTML = `
      <div class="alert alert-danger">
        Error cargando comprobantes
      </div>
    `;
    console.error(err);
  }
}

/* ✔ Validar */
async function validar(id) {
  if (!confirm("¿Validar comprobante?")) return;
  await fetchJSON(`${API_BASE}/admin/${id}/validar`, { method: "PUT" });
  cargarComprobantes();
}

/* ✖ Rechazar */
async function rechazar(id) {
  if (!confirm("¿Rechazar comprobante?")) return;
  await fetchJSON(`${API_BASE}/admin/${id}/rechazar`, { method: "PUT" });
  cargarComprobantes();
}

  async function revertir(id) {
    if (!confirm("⚠️ ¿Revertir este pago validado?")) return;
    await fetchJSON(`${API_BASE}/admin/${id}/revertir`, { method: "PUT" });
    cargarComprobantes();
  }

cargarComprobantes();
</script>

