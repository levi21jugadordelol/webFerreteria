---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { API_URL, BACKEND_URL } from "../../../config/api";
---

<AdminLayout title="Validar Comprobantes de Pago">

  <div class="mb-3">
    <input
      id="search-comprobantes"
      type="search"
      class="form-control"
      placeholder="Buscar por cliente, documento, teléfono, pedido o producto..."
    />
  </div>

  <div id="app-comprobantes" class="table-responsive"></div>

</AdminLayout>

<script is:inline define:vars={{ API_URL, BACKEND_URL }}>
  window.API_URL = API_URL;
  window.BACKEND_URL = BACKEND_URL;
</script>

<script is:client>
const API_BASE = `${window.API_URL}/pagos`;
const BACKEND_URL = window.BACKEND_URL;
const container = document.getElementById("app-comprobantes");

async function fetchJSON(url, options = {}) {
  const res = await fetch(url, {
    credentials: "include",
    ...options,
  });

  const contentType = res.headers.get("content-type") || "";
  const raw = await res.text();

  if (!contentType.includes("application/json")) {
    throw new Error("La API devolvió HTML o texto");
  }

  const result = raw ? JSON.parse(raw) : null;

  if (!res.ok) {
    throw new Error(result?.message || result?.msg || "Error en la API");
  }

  return result?.data ?? result;
}

function escapeHTML(value = "") {
  return String(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");
}

function safeComprobanteUrl(url = "") {
  const value = String(url || "").trim();

  if (!value) {
    return "#";
  }

  if (value.includes("..")) {
    return "#";
  }

  // Cloudinary
  if (value.startsWith("https://res.cloudinary.com/")) {
    return value;
  }

  // Compatibilidad con comprobantes antiguos
  if (value.startsWith("/uploads/")) {
    return `${BACKEND_URL}${value}`;
  }

  return "#";
}

function tiempoDesde(fecha) {
  const diff = Date.now() - new Date(fecha).getTime();
  const minutos = Math.floor(diff / 60000);

  if (minutos < 1) return "hace unos segundos";
  if (minutos < 60) return `hace ${minutos} min`;

  const horas = Math.floor(minutos / 60);
  if (horas < 24) return `hace ${horas}h`;

  const dias = Math.floor(horas / 24);
  return `hace ${dias} día${dias > 1 ? "s" : ""}`;
}

function resumenComprobante(c) {
  const pedidoId = c.pedido?.id_pedido ?? c.pedido_id;

  if (c.estado_validacion === "pendiente") {
    return `
      <strong>Pedido #${pedidoId}</strong><br>
      <span>Comprobante enviado ${tiempoDesde(c.fecha_hora)}</span><br>
      <small class="text-warning fw-bold">Aún no revisado</small>
    `;
  }

  if (c.estado_validacion === "validado") {
    return `
      <strong>Pedido #${pedidoId}</strong><br>
      <span>Comprobante validado</span><br>
      <small class="text-success fw-bold">Pago aprobado</small>
    `;
  }

  if (c.estado_validacion === "rechazado") {
    return `
      <strong>Pedido #${pedidoId}</strong><br>
      <span>Comprobante rechazado</span><br>
      <small class="text-danger fw-bold">Requiere revisión</small>
    `;
  }

  return `
    <strong>Pedido #${pedidoId}</strong><br>
    <span>Comprobante vencido</span><br>
    <small class="text-muted fw-bold">Reserva liberada</small>
  `;
}

function resumenProductos(c) {
  const detalles = c.pedido?.detalles ?? [];

  if (!detalles.length) {
    return `<span class="text-muted">Sin productos</span>`;
  }

  return detalles
    .map((d) => {
      const nombre = escapeHTML(
  d.producto?.nombre_producto ?? "Producto"
);

return `<span>${nombre} x${d.cantidad}</span>`;
    })
    .join("<br>");
}

function resumenCliente(c) {
  const pedido = c.pedido;

  if (!pedido) return "-";

  const nombre = escapeHTML(pedido.nombre_comprador ?? "-");
  const telefono = escapeHTML(pedido.telefono_comprador ?? "-");
  const numeroDocumento = escapeHTML(pedido.numero_documento ?? "-");
  const tipoDocumento = escapeHTML(pedido.tipo_documento ?? "");

  const documento =
    tipoDocumento && tipoDocumento !== "SIN_DOCUMENTO"
      ? `${tipoDocumento}: ${numeroDocumento}`
      : "Sin documento";

  return `
    <strong>${nombre}</strong><br>
    <small>Tel: ${telefono}</small><br>
    <small>${documento}</small>
  `;
}

function estadoBadge(valor) {
  const color =
    valor === "validado" || valor === "pagado"
      ? "success"
      : valor === "rechazado" || valor === "cancelado"
      ? "danger"
      : valor === "vencido"
      ? "secondary"
      : "warning";

  return `<span class="badge bg-${color}">${valor}</span>`;
}

let currentPage = 1;
let currentSearch = "";
const pageLimit = 10;

async function cargarComprobantes(page = 1, search = "") {
  try {
    currentPage = page;
    currentSearch = search;

    const params = new URLSearchParams({
      page: String(page),
      limit: String(pageLimit),
    });

    if (search.trim()) {
      params.set("search", search.trim());
    }

    const response = await fetchJSON(`${API_BASE}/admin/lista?${params}`);

    const data = response.items ?? [];
    const pagination = response.pagination ?? {
      page: 1,
      limit: pageLimit,
      total: 0,
      totalPages: 1,
    };

    if (!Array.isArray(data) || data.length === 0) {
      container.innerHTML = `
        <div class="alert alert-info">
          No hay comprobantes para mostrar.
        </div>
      `;
      return;
    }

    container.innerHTML = `
      <table class="table table-striped align-middle">
        <thead>
          <tr>
            <th>Resumen</th>
            <th>Productos</th>
            <th>Cliente</th>
            <th>Dirección</th>
            <th>Total</th>
            <th>Comprobante</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>

        <tbody>
          ${data.map(c => `
            <tr>
              <td>${resumenComprobante(c)}</td>
              <td>${resumenProductos(c)}</td>
              <td>${resumenCliente(c)}</td>
              <td>${escapeHTML(
  c.pedido?.direccion_envio ?? "-"
)}</td>
              <td>S/ ${c.pedido?.total_pedido ?? "0.00"}</td>

              <td>
               <a href="${safeComprobanteUrl(c.url_imagen)}" target="_blank" rel="noopener noreferrer">
                  Ver imagen
                </a>
              </td>

              <td>
                <div class="d-flex flex-column gap-1">
                  <span>Pago: ${estadoBadge(c.estado_validacion)}</span>
                  <span>Pedido: ${estadoBadge(c.pedido?.estado_pedido ?? "-")}</span>
                </div>
              </td>

              <td>
                ${
                  c.estado_validacion === "pendiente"
                    ? `
                      <button class="btn btn-success btn-sm mb-1"
                        onclick="validar(${c.id_comprobante})">
                        Validar
                      </button>

                      <button class="btn btn-danger btn-sm mb-1"
                        onclick="rechazar(${c.id_comprobante})">
                        Rechazar
                      </button>
                    `
                    : c.estado_validacion === "validado"
                    ? `
                      <button class="btn btn-warning btn-sm"
                        onclick="revertir(${c.id_comprobante})">
                        Revertir
                      </button>
                    `
                    : `
                      <span class="text-muted fw-bold">
                        Acción completada
                      </span>
                    `
                }
              </td>
            </tr>
          `).join("")}
        </tbody>
      </table>

      ${renderPagination(pagination)}
    `;
  } catch (err) {
    container.innerHTML = `
      <div class="alert alert-danger">
        Error cargando comprobantes
      </div>
    `;
    console.error(err);
  }
}


function conectarBuscador() {
  const input = document.getElementById("search-comprobantes");
  if (!input) return;

  let timer = null;

  input.addEventListener("input", () => {
    clearTimeout(timer);

    timer = setTimeout(() => {
      cargarComprobantes(1, input.value);
    }, 400);
  });
}

function renderPagination(pagination) {
  if (!pagination || pagination.totalPages <= 1) return "";

  const prevPage = pagination.page - 1;
  const nextPage = pagination.page + 1;

  return `
    <div class="d-flex justify-content-between align-items-center mt-3">
      <small class="text-muted">
        Página ${pagination.page} de ${pagination.totalPages}
        · Total: ${pagination.total}
      </small>

      <div class="d-flex gap-2">
        <button
          class="btn btn-outline-secondary btn-sm"
          ${pagination.page <= 1 ? "disabled" : ""}
          onclick="cargarComprobantes(${prevPage}, currentSearch)"
        >
          Anterior
        </button>

        <button
          class="btn btn-outline-secondary btn-sm"
          ${pagination.page >= pagination.totalPages ? "disabled" : ""}
          onclick="cargarComprobantes(${nextPage}, currentSearch)"
        >
          Siguiente
        </button>
      </div>
    </div>
  `;
}

async function validar(id) {
  if (!confirm("¿Validar comprobante? Esto marcará el pedido como pagado y descontará stock.")) return;
  await fetchJSON(`${API_BASE}/admin/${id}/validar`, { method: "PUT" });
  cargarComprobantes(currentPage, currentSearch);
}

async function rechazar(id) {
  if (!confirm("¿Rechazar comprobante? Esto cancelará el pedido y liberará stock reservado.")) return;
  await fetchJSON(`${API_BASE}/admin/${id}/rechazar`, { method: "PUT" });
  cargarComprobantes(currentPage, currentSearch);
}

async function revertir(id) {
  if (!confirm("¿Revertir pago validado? Esto devolverá stock y volverá el pedido a pendiente.")) return;
  await fetchJSON(`${API_BASE}/admin/${id}/revertir`, { method: "PUT" });
  cargarComprobantes(currentPage, currentSearch);
}

window.validar = validar;
window.rechazar = rechazar;
window.revertir = revertir;

window.cargarComprobantes = cargarComprobantes;

conectarBuscador();
cargarComprobantes();


</script>