---
import AdminLayout from "../../../layouts/AdminLayout.astro";

import { BACKEND_URL } from "../../../config/api";

type Footer = {
  titulo?: string;
  titulo2?: string;
  titulo3?: string;
  parrafo?: string;
  enlaces?: { label: string; url: string }[];
  social?: { icon: string; url: string }[];
};

let footer: Footer = {};

try {
  const res = await fetch(`${BACKEND_URL}/api/site-settings?key=footer`);

  if (res.ok) {
    footer = await res.json();
  }
} catch (error) {
  console.error("Error cargando footer", error);
}
---

<AdminLayout title="Configuración Footer">
  <div class="container-fluid" style="max-width:700px">
    <div class="card shadow-sm">
      <div class="card-header bg-light fw-bold">
        <i class="bi bi-layout-text-window"></i> Footer
      </div>

      <div class="card-body">
        <form id="footerForm">
          <div class="mb-3">
            <label class="form-label">Título</label>
            <input
              type="text"
              id="titulo"
              class="form-control"
              value={footer.titulo || ""}
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Título 2</label>
            <input
              type="text"
              id="titulo2"
              class="form-control"
              value={footer.titulo2 || ""}
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Título 3</label>
            <input
              type="text"
              id="titulo3"
              class="form-control"
              value={footer.titulo3 || ""}
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Descripción</label>
            <textarea id="parrafo" class="form-control">
              {footer.parrafo || ""}
            </textarea>
          </div>

          <!-- ENLACES -->
<div class="mb-3">
  <label class="form-label fw-bold">Enlaces</label>

  <div id="enlacesContainer">
    {footer.enlaces?.map((item, i) => (
      <div class="d-flex gap-2 mb-2">
        <input type="text" class="form-control enlace-label" value={item.label} placeholder="Texto" />
        <input type="text" class="form-control enlace-url" value={item.url} placeholder="/ruta" />
        <button type="button" class="btn btn-danger btn-sm remove-enlace">✕</button>
      </div>
    ))}
  </div>

  <button type="button" id="addEnlace" class="btn btn-sm btn-outline-primary">
    + Agregar enlace
  </button>
</div>



<!-- REDES -->
<div class="mb-3">
  <label class="form-label fw-bold">Redes sociales</label>

  <div id="socialContainer">
    {footer.social?.map((s, i) => (
      <div class="d-flex gap-2 mb-2">
        <input type="text" class="form-control social-icon" value={s.icon} placeholder="facebook" />
        <input type="text" class="form-control social-url" value={s.url} placeholder="https://..." />
        <button type="button" class="btn btn-danger btn-sm remove-social">✕</button>
      </div>
    ))}
  </div>

  <button type="button" id="addSocial" class="btn btn-sm btn-outline-primary">
    + Agregar red
  </button>
</div>

          

          <button class="btn btn-primary">
            <i class="bi bi-save"></i> Guardar footer
          </button>
        </form>
      </div>
    </div>

    <div id="mensaje" class="mt-3"></div>
  </div>
</AdminLayout>

<script is:inline define:vars={{ API_URL: BACKEND_URL }}>
  window.API_URL = API_URL;
</script>

<script is:inline>
const API_URL = window.API_URL;

const form = document.getElementById("footerForm");
const mensaje = document.getElementById("mensaje");

function mostrarMensaje(tipo, texto) {
  const div = document.createElement("div");
  div.className = `alert ${tipo}`;
  div.textContent = texto || "Operación procesada";
  mensaje.replaceChildren(div);
}

function crearInput(clase, placeholder) {
  const input = document.createElement("input");
  input.type = "text";
  input.className = `form-control ${clase}`;
  input.placeholder = placeholder;
  return input;
}

function crearBotonEliminar(clase) {
  const button = document.createElement("button");
  button.type = "button";
  button.className = `btn btn-danger btn-sm ${clase}`;
  button.textContent = "✕";
  return button;
}

function crearFilaEnlace() {
  const div = document.createElement("div");
  div.className = "d-flex gap-2 mb-2";

  div.append(
    crearInput("enlace-label", "Texto"),
    crearInput("enlace-url", "/ruta"),
    crearBotonEliminar("remove-enlace")
  );

  return div;
}

function crearFilaSocial() {
  const div = document.createElement("div");
  div.className = "d-flex gap-2 mb-2";

  div.append(
    crearInput("social-icon", "facebook"),
    crearInput("social-url", "https://..."),
    crearBotonEliminar("remove-social")
  );

  return div;
}

form.addEventListener("submit", async (e) => {
  e.preventDefault();

  const enlaces = Array.from(
    document.querySelectorAll("#enlacesContainer .d-flex")
  )
    .map((el) => ({
      label: el.querySelector(".enlace-label").value.trim(),
      url: el.querySelector(".enlace-url").value.trim(),
    }))
    .filter((e) => e.label && e.url);

  const social = Array.from(
    document.querySelectorAll("#socialContainer .d-flex")
  )
    .map((el) => ({
      icon: el.querySelector(".social-icon").value.trim(),
      url: el.querySelector(".social-url").value.trim(),
    }))
    .filter((s) => s.icon && s.url);

  const data = {
    footer: {
      titulo: document.getElementById("titulo").value.trim(),
      titulo2: document.getElementById("titulo2").value.trim(),
      titulo3: document.getElementById("titulo3").value.trim(),
      parrafo: document.getElementById("parrafo").value.trim(),
      enlaces,
      social,
    },
  };

  try {
    const res = await fetch(`${API_URL}/api/site-settings`, {
      method: "PUT",
      headers: {
        "Content-Type": "application/json",
      },
      credentials: "include",
      body: JSON.stringify(data),
    });

    const result = await res.json();

    if (!res.ok) {
      mostrarMensaje("alert-danger", result.msg || "Error al guardar");
      return;
    }

    mostrarMensaje("alert-success", result.msg || "Footer guardado");
  } catch (error) {
    mostrarMensaje("alert-danger", "Error guardando footer");
  }
});

document.getElementById("addEnlace").addEventListener("click", () => {
  const container = document.getElementById("enlacesContainer");
  container.appendChild(crearFilaEnlace());
});

document.getElementById("addSocial").addEventListener("click", () => {
  const container = document.getElementById("socialContainer");
  container.appendChild(crearFilaSocial());
});

document.addEventListener("click", (e) => {
  if (
    e.target.classList.contains("remove-enlace") ||
    e.target.classList.contains("remove-social")
  ) {
    e.target.parentElement.remove();
  }
});
</script>