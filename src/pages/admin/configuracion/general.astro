---
import AdminLayout from "../../../layouts/AdminLayout.astro";

const API_URL = "http://localhost:3000"; // 👈 FALTABA AQUÍ

type SiteContent = {
  whatsapp?: string;
  logo?: string;
};

type SiteSettings = {
  site_content?: SiteContent;
};

let config: SiteSettings = {};

try {
  const res = await fetch(`${API_URL}/api/site-settings`);
  if (res.ok) {
    config = await res.json();
  }
} catch (error) {
  console.error("Error cargando configuración");
}

const whatsapp = config.site_content?.whatsapp ?? "";
const logo = config.site_content?.logo ?? "";
---

<AdminLayout title="Configuración del sitio">

<div class="container-fluid" style="max-width:700px">

  <div class="card shadow-sm mb-4">

    <div class="card-header bg-light fw-bold">
      <i class="bi bi-whatsapp"></i> Contacto
    </div>

    <div class="card-body">

      <form id="settingsForm">

        <!-- WHATSAPP -->
        <div class="mb-3">
          <label class="form-label fw-semibold">
            Número de WhatsApp
          </label>

          <input
            type="text"
            name="whatsapp"
            class="form-control"
            value={whatsapp}
            placeholder="51987654321"
          />

          <small class="text-muted">
            Ejemplo: 51987654321
          </small>
        </div>

        <!-- LOGO -->
        <div class="mb-3">
          <label class="form-label fw-semibold">
            Logo del sitio
          </label>

          <input type="file" id="logoFile" class="form-control" />

          <input type="hidden" name="logo" id="logo" value={logo} />

          <div id="previewLogo" class="mt-2">
            {logo && (
              <img src={logo} style="max-width:120px;border-radius:8px" />
            )}
          </div>
        </div>

        <button class="btn btn-primary">
          <i class="bi bi-save"></i> Guardar configuración
        </button>

      </form>

    </div>

  </div>

  <div id="mensaje"></div>

</div>

<script is:inline>
const API_URL = "http://localhost:3000";

const form = document.getElementById("settingsForm");
const mensaje = document.getElementById("mensaje");

function mostrarMensaje(tipo, texto) {
  const div = document.createElement("div");
  div.className = `alert ${tipo}`;
  div.textContent = texto || "Operación procesada";
  mensaje.replaceChildren(div);
}

function safeImageUrl(url) {
  const value = String(url || "").trim();

  if (!value) return "";

  if (value.includes("..")) return "";

  if (
    value.startsWith("/") ||
    value.startsWith("http://") ||
    value.startsWith("https://")
  ) {
    return value;
  }

  return "";
}

form.addEventListener("submit", async (e) => {
  e.preventDefault();

  const whatsapp = form.whatsapp.value;
  const logo = form.logo.value;

  try {
    const res = await fetch(`${API_URL}/api/site-settings`, {
      method: "PUT",
      credentials: "include",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        site_content: {
          whatsapp,
          logo
        }
      })
    });

    const data = await res.json();

    if (!res.ok) {
      mostrarMensaje("alert-danger", data.msg);
      return;
    }

    mostrarMensaje("alert-success", data.msg);
  } catch (error) {
    mostrarMensaje("alert-danger", "Error de conexión");
  }
});

const logoFile = document.getElementById("logoFile");
const logoInput = document.getElementById("logo");
const previewLogo = document.getElementById("previewLogo");

logoFile.addEventListener("change", async () => {
  const file = logoFile.files[0];
  if (!file) return;

  if (!file.type.startsWith("image/")) {
    mostrarMensaje("alert-danger", "Solo se permiten imágenes");
    return;
  }

  const formData = new FormData();
  formData.append("imagen", file);

  try {
    const res = await fetch(`${API_URL}/api/uploads/editor`, {
      method: "POST",
      body: formData,
      credentials: "include"
    });

    const data = await res.json();

    const logoUrl = safeImageUrl(data.url);

    if (!res.ok || !logoUrl) {
      mostrarMensaje("alert-danger", data.msg || "No se pudo subir el logo");
      return;
    }

    logoInput.value = logoUrl;

    const img = document.createElement("img");
    img.src = logoUrl;
    img.alt = "Logo del sitio";
    img.style.maxWidth = "120px";
    img.style.borderRadius = "8px";

    previewLogo.replaceChildren(img);

    mostrarMensaje("alert-success", "Logo subido correctamente");
  } catch (err) {
    console.error(err);
    mostrarMensaje("alert-danger", "Error subiendo logo");
  }
});
</script>

</AdminLayout>