---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import { API_URL, UPLOADS_URL } from "../../../config/api";

interface HeroSlide {
  id_hero: number;
  imagen: string;
  link_url: string | null;
  activo: boolean;
  orden: number;
}

const getHeroImageUrl = (image = "") => {
  const value = String(image || "").trim();

  if (!value) return "/img/no-image.png";

  if (/^https?:\/\//i.test(value)) return value;

  const clean = value.replace(/^\/?uploads\//, "").replace(/^\/+/, "");

  if (!clean || clean.includes("..")) return "/img/no-image.png";

  return `${UPLOADS_URL}/${encodeURIComponent(clean)}`;
};

let slides: HeroSlide[] = [];

try {
  const res = await fetch(`${API_URL}/hero?type=triple`, {
    cache: "no-store",
  });

  if (res.ok) {
    const result = await res.json();
    slides = result.data ?? [];
  }
} catch (error) {
  console.error("Error cargando hero triple:", error);
}
---

<AdminLayout title="Hero Triple">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-1">Hero Triple Promocional</h2>
      <p class="text-muted mb-0">
        Administra los banners promocionales triples del inicio.
      </p>
    </div>

    <a href="/admin/hero-triple/nuevo" class="btn btn-primary">
      ➕ Nuevo Banner
    </a>
  </div>

  {slides.length === 0 ? (
    <div class="alert alert-info">
      No hay banners triples registrados.
    </div>
  ) : (
    <div class="row g-3">
      {slides.map((slide) => (
        <div class="col-md-4">
          <div class="card shadow-sm h-100">
            <img
              src={getHeroImageUrl(slide.imagen)}
              class="card-img-top"
              alt="Banner triple promocional"
              style="height:160px; object-fit:cover; object-position:center;"
            />

            <div class="card-body">
              <p class="mb-1">
                <strong>Orden:</strong> {slide.orden}
              </p>

              <p class="mb-1">
                <strong>Estado:</strong>{" "}
                <span class={slide.activo ? "badge bg-success" : "badge bg-danger"}>
                  {slide.activo ? "Activo" : "Inactivo"}
                </span>
              </p>

              <p class="small text-muted mb-3">
                {slide.link_url || "Sin link"}
              </p>

              <a
                href={`/admin/hero-triple/editar/${slide.id_hero}`}
                class="btn btn-warning btn-sm"
              >
                ✏️ Editar
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}
</AdminLayout>