---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { API_URL } from "../../../config/api";
---

<AdminLayout title="Páginas">

<div class="card shadow-sm p-4">

<div class="d-flex justify-content-between mb-3">

<h5 class="mb-0">Listado de páginas</h5>

<a href="/admin/paginas/nueva" class="btn btn-success">
<i class="bi bi-plus"></i> Nueva página
</a>

</div>

<table class="table table-hover">

<thead class="table-light">
<tr>
<th>ID</th>
<th>Título</th>
<th>Slug</th>
<th>Estado</th>
<th width="220">Acciones</th>
</tr>
</thead>

<tbody id="tablaPaginas"></tbody>

</table>

</div>

</AdminLayout>

<script is:inline define:vars={{ API_URL }}>
  window.API_URL = API_URL;
</script>

<script is:client>
const API = window.API_URL;
const tabla = document.getElementById("tablaPaginas");

function escapeHTML(value = "") {
  return String(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");
}

function safeSlug(slug = "") {
  const clean = String(slug).trim();

  if (!/^[a-zA-Z0-9-_\/]+$/.test(clean)) {
    return "#";
  }

  return `/${clean.replace(/^\/+/, "")}`;
}

async function fetchJSON(url, options = {}) {
  const res = await fetch(url, {
    credentials: "include",
    ...options,
  });

  const result = await res.json().catch(() => ({}));

  if (!res.ok) {
    throw new Error(result?.message || result?.msg || "Error en la API");
  }

  return result.data ?? result;
}

async function cargarPaginas() {
  try {
    const paginas = await fetchJSON(`${API}/paginas/admin/lista`);

    tabla.innerHTML = "";

    if (!Array.isArray(paginas) || paginas.length === 0) {
      tabla.innerHTML = `
        <tr>
          <td colspan="5" class="text-center text-muted">
            No hay páginas registradas.
          </td>
        </tr>
      `;
      return;
    }

    tabla.innerHTML = paginas.map((p) => {
      const idPagina = Number(p.id_pagina) || 0;
      const titulo = escapeHTML(p.titulo ?? "-");
      const slug = escapeHTML(p.slug ?? "-");
      const urlPublica = safeSlug(p.slug);

      const estado = p.activo
        ? '<span class="badge bg-success">Activo</span>'
        : '<span class="badge bg-secondary">Inactivo</span>';

      return `
        <tr>
          <td>${idPagina}</td>
          <td>${titulo}</td>
          <td>${slug}</td>
          <td>${estado}</td>

          <td class="d-flex gap-2">
            <a
              href="${urlPublica}"
              class="btn btn-sm btn-outline-primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="bi bi-eye"></i>
            </a>

            <a
              href="/admin/paginas/editar/${idPagina}"
              class="btn btn-sm btn-outline-warning"
            >
              <i class="bi bi-pencil"></i>
            </a>

            <button
              class="btn btn-sm btn-outline-danger btn-eliminar"
              data-id="${idPagina}"
            >
              <i class="bi bi-trash"></i>
            </button>
          </td>
        </tr>
      `;
    }).join("");

    document.querySelectorAll(".btn-eliminar").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = Number(btn.dataset.id);

        if (!id) {
          alert("ID de página inválido");
          return;
        }

        if (!confirm("¿Eliminar esta página?")) return;

        await fetchJSON(`${API}/paginas/admin/${id}`, {
          method: "DELETE",
        });

        cargarPaginas();
      });
    });
  } catch (err) {
    tabla.innerHTML = `
      <tr>
        <td colspan="5" class="text-danger">
          Error cargando páginas: ${escapeHTML(err.message)}
        </td>
      </tr>
    `;
  }
}

cargarPaginas();
</script>