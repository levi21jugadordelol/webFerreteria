---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";

const API_URL =
  import.meta.env.PUBLIC_API_URL || "http://localhost:3000/api/v1";

const UPLOADS_URL =
  import.meta.env.PUBLIC_UPLOADS_URL || "http://localhost:3000/uploads";

interface HeroSlide {
  id_hero: number;
  titulo1?: string;
  titulo2?: string;
  imagen: string;
  tipo_layout: string;
  mostrar_boton: boolean;
  boton_texto?: string;
  boton_url?: string;
  orden: number;
  activo: boolean;
}

let slides: HeroSlide[] = [];

try {
  const res = await fetch(`${API_URL}/hero`, {
    cache: "no-store",
  });

  if (!res.ok) {
    throw new Error(`Error ${res.status}`);
  }

  const result = await res.json();

  slides = result.data ?? [];
} catch (error) {
  console.error("Error cargando preview hero:", error);
}
---

<AdminLayout title="Preview Hero">
  <div class="container">
    <div class="carousel slide">
      {slides.map((slide: HeroSlide) => (
        <div class="mb-4 p-4 border rounded">
          <img
            src={`${UPLOADS_URL}/${slide.imagen}`}
            class="img-fluid mb-3"
          />

          <h3>{slide.titulo1}</h3>

          <p>{slide.titulo2}</p>

          {slide.mostrar_boton && (
            <a href={slide.boton_url} class="btn btn-primary">
              {slide.boton_texto}
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</AdminLayout>