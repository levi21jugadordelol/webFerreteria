---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import HeroForm from "../../../../components/admin/HeroForm.astro";

const API_URL =
  import.meta.env.PUBLIC_API_URL || "http://localhost:3000/api/v1";

const { id } = Astro.params;

const token = Astro.cookies.get("_token");
if (!token) return Astro.redirect("/admin/login");

const res = await fetch(`${API_URL}/hero/${id}`, {
  cache: "no-store",
  credentials: "include",
});

if (!res.ok) return Astro.redirect("/admin/hero");

const result = await res.json();
const slide = result.data ?? result;
---

<AdminLayout title="Editar Slide Hero">
  <div class="card shadow-sm p-4">
    <HeroForm slide={slide} />
  </div>
</AdminLayout>