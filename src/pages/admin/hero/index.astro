---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import HeroSortable from "../../../components/admin/HeroSortable.astro";

// 🔹 obtener carrusel
const resCarousel = await fetch("http://localhost:3000/api/hero?type=carousel");
const heroSlides = await resCarousel.json();

// 🔹 obtener banners triple
const resTriple = await fetch("http://localhost:3000/api/hero?type=triple");
const tripleSlides = await resTriple.json();
---

<AdminLayout title="Gestión Hero">

<h2>Hero Carrusel</h2>

<a href="/admin/hero/nuevo" class="btn btn-primary mb-4">
➕ Nuevo Slide
</a>

<HeroSortable slides={heroSlides} />

<hr class="my-5"/>

<h2>Hero Triple Promocional</h2>

<a href="/admin/hero/nuevo?layout=triple" class="btn btn-primary mb-4">
➕ Nuevo Banner Triple
</a>

<HeroSortable slides={tripleSlides} />

</AdminLayout>




