---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import HeroSortable from "../../../components/admin/HeroSortable.astro";

const API_URL =
  import.meta.env.PUBLIC_API_URL || "http://localhost:3000/api/v1";

let heroSlides = [];
let tripleSlides = [];

try {
  const resCarousel = await fetch(`${API_URL}/hero?type=carousel`, {
    cache: "no-store",
  });

  if (resCarousel.ok) {
    const result = await resCarousel.json();
    heroSlides = result.data ?? [];
  }

  const resTriple = await fetch(`${API_URL}/hero?type=triple`, {
    cache: "no-store",
  });

  if (resTriple.ok) {
    const result = await resTriple.json();
    tripleSlides = result.data ?? [];
  }
} catch (error) {
  console.error("Error cargando hero admin:", error);
}
---

<AdminLayout title="Gestión Hero">
  <h2>Hero Carrusel</h2>

  <a href="/admin/hero/nuevo" class="btn btn-primary mb-4">
    ➕ Nuevo Slide
  </a>

  <HeroSortable slides={heroSlides} />

  <hr class="my-5" />

  <h2>Hero Triple Promocional</h2>

  <a href="/admin/hero/nuevo?layout=triple" class="btn btn-primary mb-4">
    ➕ Nuevo Banner Triple
  </a>

  <HeroSortable slides={tripleSlides} />
</AdminLayout>