---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Panel Administrativo">

<div class="row g-4">

  <!-- PRODUCTOS -->
  <div class="col-md-3">
    <div class="card border-primary shadow-sm">
      <div class="card-body text-center">
        <h6 class="text-muted">Productos</h6>
        <h2 id="totalProductos">
          <span class="spinner-border spinner-border-sm"></span>
        </h2>
      </div>
    </div>
  </div>

  <!-- VENTAS HOY -->
  <div class="col-md-3">
    <div class="card border-success shadow-sm">
      <div class="card-body text-center">
        <h6 class="text-muted">Ventas Hoy</h6>
        <h2 id="ventasHoy">
          <span class="spinner-border spinner-border-sm"></span>
        </h2>
      </div>
    </div>
  </div>

  <!-- PAGOS PENDIENTES -->
  <div class="col-md-3">
    <div class="card border-warning shadow-sm">
      <div class="card-body text-center">
        <h6 class="text-muted">Pagos Pendientes</h6>
        <h2 id="pagosPendientes">
          <span class="spinner-border spinner-border-sm"></span>
        </h2>
      </div>
    </div>
  </div>

  <!-- STOCK BAJO -->
  <div class="col-md-3">
    <div class="card border-danger shadow-sm">
      <div class="card-body text-center">
        <h6 class="text-muted">Stock Bajo</h6>
        <h2 id="stockBajo">
          <span class="spinner-border spinner-border-sm"></span>
        </h2>
      </div>
    </div>
  </div>

</div>


<!-- ACTIVIDAD RECIENTE -->
<hr class="my-5">

<h4 class="mb-3">Actividad reciente</h4>

<div id="actividad-reciente">
  <div class="spinner-border spinner-border-sm"></div>
</div>

</AdminLayout>


<script is:client>
const API_URL = "http://localhost:3000/api/v1";

async function fetchJSON(url) {
  const res = await fetch(url, {
    credentials: "include",
  });

  const result = await res.json();

  if (!res.ok) {
    throw new Error(result?.message || result?.msg || "Error en la API");
  }

  return result.data ?? result;
}

async function cargarDashboard() {
  try {
    const data = await fetchJSON(`${API_URL}/dashboard`);

    const stats = data.stats ?? {};

    const totalProductos = stats.totalProductos ?? 0;
    const ventasHoy = stats.totalVentas ?? 0;
    const pagosPendientes = stats.pagosPendientes ?? 0;
    const stockBajo = stats.stockBajo ?? 0;

    document.getElementById("totalProductos").innerText = totalProductos;
    document.getElementById("ventasHoy").innerText = ventasHoy;
    document.getElementById("pagosPendientes").innerText = pagosPendientes;
    document.getElementById("stockBajo").innerText = stockBajo;

    if (pagosPendientes > 3) {
      document.getElementById("pagosPendientes").classList.add("text-danger");
    }

    if (stockBajo > 0) {
      document.getElementById("stockBajo").classList.add("text-danger");
    }
  } catch (error) {
    console.error("Error dashboard", error);
  }
}

async function cargarActividad() {
  try {
    const data = await fetchJSON(`${API_URL}/dashboard/actividad`);

    const cont = document.getElementById("actividad-reciente");

    if (data.length === 0) {
      cont.innerHTML = `
        <div class="alert alert-info">
          No hay actividad reciente
        </div>
      `;
      return;
    }

    cont.innerHTML = `
      <ul class="list-group">
        ${data.map(a => `
          <li class="list-group-item d-flex justify-content-between">
            <span>
              ${iconoAccion(a.accion)}
              ${a.accion} comprobante #${a.comprobante_id}
            </span>

            <small class="text-muted">
              ${new Date(a.fecha).toLocaleString()}
            </small>
          </li>
        `).join("")}
      </ul>
    `;
  } catch (error) {
    console.error("Error actividad", error);
  }
}

function iconoAccion(accion) {
  if (accion === "validado") return "✅";
  if (accion === "revertido") return "↩️";

  return "📌";
}

cargarDashboard();
cargarActividad();
</script>



