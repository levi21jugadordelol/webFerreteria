---
import AdminLayout from "../../../layouts/AdminLayout.astro";

const API_URL="http://localhost:3000";
---

<AdminLayout title="Nueva Tab">

<form id="formTab">

<input
id="tab-nombre"
name="nombre"
placeholder="Nombre"
class="form-control mb-3"
/>

<input
id="tab-slug"
name="slug"
placeholder="Slug"
class="form-control mb-3"
/>

<input
name="orden"
type="number"
placeholder="Orden"
class="form-control mb-3"
/>

<button class="btn btn-primary">
Guardar
</button>

</form>

<!-- 🔥 PASAR API -->
<script is:inline>
  window.API_URL = "http://localhost:3000";
</script>

<script is:inline>

const API_URL = window.API_URL;

const nombreInput = document.getElementById("tab-nombre");
const slugInput = document.getElementById("tab-slug");

function generarSlug(texto){
return texto
.toLowerCase()
.trim()
.normalize("NFD")
.replace(/[\u0300-\u036f]/g,"")
.replace(/[^a-z0-9\s-]/g,"")
.replace(/\s+/g,"-")
.replace(/-+/g,"-");
}

nombreInput.addEventListener("input",()=>{
slugInput.value = generarSlug(nombreInput.value);
});

document.getElementById("formTab").addEventListener("submit", async e => {

e.preventDefault();

const form = new FormData(e.target);

const data = {
nombre: form.get("nombre"),
slug: form.get("slug"),
orden: Number(form.get("orden"))
};

try {
  const res = await fetch(`${API_URL}/api/producto-tabs`, {
    method:"POST",
    credentials:"include",
    headers:{
      "Content-Type":"application/json"
    },
    body:JSON.stringify(data)
  });

  const result = await res.json();

  if(!res.ok){
    throw new Error(result.msg || "Error al crear tab");
  }

  // ✅ ÉXITO
  alert("✅ Tab creado correctamente");

  // limpiar
  e.target.reset();

} catch(err){
  console.error(err);
  alert("❌ " + err.message);
}

});

</script>

</AdminLayout>