---
import AdminLayout from "../../../layouts/AdminLayout.astro";

const API_URL =
  import.meta.env.PUBLIC_API_URL || "http://localhost:3000/api/v1";

const res = await fetch(`${API_URL}/producto-tabs`, {
  credentials: "include",
  cache: "no-store",
});

if (!res.ok) {
  throw new Error("Error cargando tabs");
}

const result = await res.json();
const tabs = result.data ?? [];
---

<AdminLayout title="Tabs de producto">
  <div class="container-fluid">
    <h3 class="fw-bold mb-4">
      Tabs de producto
    </h3>

    <a href="/admin/productos/tab-nueva" class="btn btn-primary mb-3">
      <i class="bi bi-plus-circle"></i> Nueva Tab
    </a>

    <table class="table table-striped align-middle">
      <thead>
        <tr>
          <th>ID</th>
          <th>Nombre</th>
          <th>Slug</th>
          <th>Orden</th>
          <th>Activo</th>
          <th style="width:200px">Acciones</th>
        </tr>
      </thead>

      <tbody>
        {tabs.map((tab: any) => (
          <tr>
            <td>{tab.id_tab}</td>

            <td>{tab.nombre}</td>

            <td>
              <span class="badge bg-secondary">
                {tab.slug}
              </span>
            </td>

            <td>{tab.orden}</td>

            <td>
              {tab.activo ? (
                <span class="badge bg-success">Activo</span>
              ) : (
                <span class="badge bg-danger">Inactivo</span>
              )}
            </td>

            <td>
              <button
                class="btn btn-sm btn-warning toggle-tab"
                data-id={tab.id_tab}
              >
                <i class="bi bi-arrow-repeat"></i>
              </button>

              <a
                href={`/admin/productos/tab-editar/${tab.id_tab}`}
                class="btn btn-sm btn-info"
              >
                Editar
              </a>

              <button
                class="btn btn-sm btn-danger delete-tab"
                data-id={tab.id_tab}
              >
                <i class="bi bi-trash"></i>
              </button>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <script is:inline>
    const API_URL = "http://localhost:3000/api/v1";

    document.querySelectorAll(".delete-tab").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.dataset.id;

        if (!confirm("¿Eliminar esta tab?")) return;

        try {
          const res = await fetch(`${API_URL}/producto-tabs/${id}`, {
            method: "DELETE",
            credentials: "include",
          });

          if (!res.ok) {
            alert("Error eliminando tab");
            return;
          }

          location.reload();
        } catch (err) {
          alert("Error eliminando tab");
        }
      });
    });

    document.querySelectorAll(".toggle-tab").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.dataset.id;

        try {
          const res = await fetch(`${API_URL}/producto-tabs/${id}/toggle`, {
            method: "PATCH",
            credentials: "include",
          });

          if (!res.ok) {
            alert("Error cambiando estado");
            return;
          }

          location.reload();
        } catch (err) {
          alert("Error cambiando estado");
        }
      });
    });
  </script>
</AdminLayout>