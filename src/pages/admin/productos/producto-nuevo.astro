---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import ProductoForm from "../../../components/shared/ProductoForm.astro";
import { BACKEND_URL } from "../../../config/api";

const token = Astro.cookies.get("_token");

if (!token) {
  return Astro.redirect("/admin/login");
}
---

<AdminLayout title="Nuevo Producto">
  <ProductoForm />
</AdminLayout>

<script is:inline define:vars={{ BACKEND_URL }}>
  window.API_URL = BACKEND_URL;
</script>

<link href="https://unpkg.com/filepond/dist/filepond.min.css" rel="stylesheet" />
<script src="https://unpkg.com/filepond/dist/filepond.min.js"></script>

<!-- ✅ SOLO ESTE -->
<script type="module" src="/js/productos/productos.page.js"></script>

