---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import ProductoForm from "../../../components/shared/ProductoForm.astro";

// 🔐 Validación admin
const token = Astro.cookies.get("_token");

if (!token) {
  return Astro.redirect("/admin/login");
}
---

<AdminLayout title="Nuevo Producto">
  <ProductoForm />
</AdminLayout>


