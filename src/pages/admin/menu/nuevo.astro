---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { API_URL } from "../../../config/api";
---

<AdminLayout title="Nuevo enlace de menú">
  <form id="formMenu">
    <div class="mb-3">
      <label>Título</label>
      <input class="form-control" name="titulo" id="tituloInput" required />
    </div>

    <div class="mb-3">
      <label>Menú padre</label>
      <select id="parentSelect" class="form-control">
        <option value="">Sin padre (nivel principal)</option>
      </select>
    </div>

    <div class="mb-3">
      <label>Tipo de enlace</label>
      <select id="tipoSelect" class="form-control">
        <option value="pagina">Página CMS</option>
        <option value="sistema">Ruta del sistema</option>
        <option value="ruta">Ruta manual</option>
      </select>
    </div>

    <div class="mb-3" id="grupoPagina">
      <label>Página</label>
      <select id="paginaSelect" class="form-control">
        <option value="">Seleccionar página</option>
      </select>
    </div>

    <div class="mb-3 d-none" id="grupoSistema">
      <label>Ruta del sistema</label>
      <select id="sistemaSelect" class="form-control">
        <option value="">Seleccionar ruta</option>
        <option value="/">Inicio</option>
        <option value="/productos">Productos</option>
        <option value="/categorias">Categorías</option>
        <option value="/marcas">Marcas</option>
        <option value="/contacto">Contacto</option>
      </select>
    </div>

    <div class="mb-3 d-none" id="grupoRuta">
      <label>Ruta manual</label>
      <input id="rutaInput" class="form-control" placeholder="/productos" />
    </div>

    <div class="form-check mb-3">
      <input type="checkbox" class="form-check-input" name="activo" checked />
      <label class="form-check-label">Activo</label>
    </div>

    <button class="btn btn-success">
      Guardar
    </button>
  </form>

  <div id="mensaje" class="mt-3"></div>
</AdminLayout>

<script is:inline define:vars={{ API_URL }}>
  window.API_URL = API_URL;
</script>

<script is:client>
const API_URL = window.API_URL;

const formMenu = document.getElementById("formMenu");
const tituloInput = document.getElementById("tituloInput");
const parentSelect = document.getElementById("parentSelect");
const tipoSelect = document.getElementById("tipoSelect");
const grupoPagina = document.getElementById("grupoPagina");
const grupoSistema = document.getElementById("grupoSistema");
const grupoRuta = document.getElementById("grupoRuta");
const paginaSelect = document.getElementById("paginaSelect");
const sistemaSelect = document.getElementById("sistemaSelect");
const rutaInput = document.getElementById("rutaInput");

function mostrarMensaje(tipo, texto) {
  const msg = document.getElementById("mensaje");

  if (!msg) return;

  msg.innerHTML = `
    <div class="alert alert-${tipo}">
      ${texto}
    </div>
  `;
}

function actualizarVistaTipo() {
  grupoPagina.classList.add("d-none");
  grupoSistema.classList.add("d-none");
  grupoRuta.classList.add("d-none");

  if (tipoSelect.value === "pagina") {
    grupoPagina.classList.remove("d-none");
  }

  if (tipoSelect.value === "sistema") {
    grupoSistema.classList.remove("d-none");
  }

  if (tipoSelect.value === "ruta") {
    grupoRuta.classList.remove("d-none");
  }
}

function normalizarRutaManual(ruta) {
  const value = String(ruta || "").trim();

  if (!value) return "";

  return value.startsWith("/") ? value : `/${value}`;
}

function obtenerUrlSeleccionada() {
  if (tipoSelect.value === "pagina") {
    const slug = paginaSelect.value.trim().replace(/^\/+/, "");
    return slug ? `/${slug}` : "";
  }

  if (tipoSelect.value === "sistema") {
    return sistemaSelect.value.trim();
  }

  return normalizarRutaManual(rutaInput.value);
}

async function cargarPaginas() {
  try {
    const res = await fetch(`${API_URL}/paginas`);
    const result = await res.json();
    const paginas = Array.isArray(result?.data) ? result.data : [];

    paginas.forEach((p) => {
      const option = document.createElement("option");
      option.value = p.slug;
      option.textContent = p.titulo;
      paginaSelect.appendChild(option);
    });
  } catch (err) {
    console.error("Error cargando páginas", err);
  }
}

async function cargarPadres() {
  try {
    const res = await fetch(`${API_URL}/menu/admin/lista`, {
      credentials: "include",
    });

    const result = await res.json();
    const menus = Array.isArray(result?.data) ? result.data : [];

    menus.forEach((m) => {
      const option = document.createElement("option");
      option.value = m.id_menu;
      option.textContent = m.titulo;
      parentSelect.appendChild(option);
    });
  } catch (err) {
    console.error("Error cargando padres", err);
  }
}

tipoSelect.addEventListener("change", actualizarVistaTipo);

formMenu.addEventListener("submit", async (e) => {
  e.preventDefault();

  const btn = e.target.querySelector("button");
  btn.disabled = true;
  btn.innerText = "Guardando...";

  const form = new FormData(e.target);
  const data = Object.fromEntries(form);

  data.url = obtenerUrlSeleccionada();
  data.tipo = tipoSelect.value === "pagina" ? "pagina" : "ruta";
  data.activo = form.get("activo") ? 1 : 0;
  data.parent_id = parentSelect.value || null;

  if (!data.titulo?.trim()) {
    mostrarMensaje("danger", "Debe ingresar un título");

    btn.disabled = false;
    btn.innerText = "Guardar";
    return;
  }

  if (!data.url) {
    mostrarMensaje("danger", "Debe seleccionar una página o ingresar una ruta");

    btn.disabled = false;
    btn.innerText = "Guardar";
    return;
  }

  if (!data.url.startsWith("/")) {
    mostrarMensaje("danger", "La ruta debe empezar con '/'");

    btn.disabled = false;
    btn.innerText = "Guardar";
    return;
  }

  try {
    const res = await fetch(`${API_URL}/menu/admin`, {
      method: "POST",
      body: JSON.stringify(data),
      headers: { "Content-Type": "application/json" },
      credentials: "include",
    });

    if (!res.ok) {
      mostrarMensaje("danger", "No se pudo crear el enlace");

      btn.disabled = false;
      btn.innerText = "Guardar";
      return;
    }

    mostrarMensaje("success", "Enlace creado correctamente");

    setTimeout(() => {
      window.location = "/admin/menu/lista";
    }, 1200);
  } catch (err) {
    console.error(err);

    mostrarMensaje("danger", "Error de conexión");

    btn.disabled = false;
    btn.innerText = "Guardar";
  }
});

actualizarVistaTipo();
cargarPaginas();
cargarPadres();
</script>