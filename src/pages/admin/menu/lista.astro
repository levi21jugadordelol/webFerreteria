---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import "../../../styles/admin/menu.css";

import { API_URL } from "../../../config/api";
---

<AdminLayout title="Menú del sitio">
  <div class="mb-3">
    <a href="/admin/menu/nuevo" class="btn btn-primary">
      Nuevo enlace
    </a>
  </div>

  <div id="menuList" class="menuList"></div>
</AdminLayout>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>


<script is:inline define:vars={{ API_URL }}>

  window.API_URL = API_URL;

</script>

<script is:inline>
document.addEventListener("DOMContentLoaded", async function () {
  const API = window.API_URL;

  async function fetchJSON(url, options = {}) {
    const res = await fetch(url, {
      credentials: "include",
      ...options,
    });

    const result = await res.json().catch(() => ({}));

    if (!res.ok) {
      throw new Error(result?.message || result?.msg || "Error en la API");
    }

    return result.data ?? result;
  }

  function escapeHTML(value = "") {
    return String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  async function cargarMenu() {
    const cont = document.getElementById("menuList");

    try {
      const data = await fetchJSON(`${API}/menu/admin/lista`);

      if (!Array.isArray(data) || data.length === 0) {
        cont.innerHTML = `<p class="text-muted">No hay enlaces de menú.</p>`;
        return;
      }

      cont.innerHTML = data
  .filter((m) => Number(m.id_menu) > 0)
  .map((m) => {
    const idMenu = Number(m.id_menu);
        const titulo = escapeHTML(m.titulo ?? "-");
        const url = escapeHTML(m.url ?? "-");
        const tipo = escapeHTML(m.tipo ?? "-");

        return `
          <div class="menu-row" data-id="${idMenu}">
            <div class="drag-handle">☰</div>

            <div class="menu-info">
              <strong>${titulo}</strong>
              <small>${url} | ${tipo}</small>
            </div>

            <div class="menu-actions">
              <a
                href="/admin/menu/editar/${idMenu}"
                class="btn btn-sm btn-warning"
              >
                ✏
              </a>

              <button
                class="btn btn-sm btn-danger btn-delete"
                data-id="${idMenu}"
              >
                🗑
              </button>
            </div>
          </div>
        `;
      }).join("");

      initSortable();
      initEliminar();
    } catch (err) {
      cont.innerHTML = `
        <p class="text-danger">
          Error cargando menú: ${escapeHTML(err.message)}
        </p>
      `;
    }
  }

  function initSortable() {
    const menuList = document.getElementById("menuList");

    if (!menuList) return;

    new Sortable(menuList, {
      animation: 200,
      handle: ".drag-handle",

      onEnd: async function () {
        const items = [...menuList.children];

        const menus = items
          .map((el, index) => ({
            id_menu: Number(el.dataset.id),
            orden: index + 1,
          }))
          .filter((item) => item.id_menu);

        await fetchJSON(`${API}/menu/admin/orden`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ menus }),
        });
      },
    });
  }

  function initEliminar() {
    document.querySelectorAll(".btn-delete").forEach((btn) => {
      btn.addEventListener("click", async function () {
        const id = Number(this.dataset.id);

        if (!id) {
          alert("ID inválido");
          return;
        }

        if (!confirm("¿Eliminar este enlace del menú?")) return;

        await fetchJSON(`${API}/menu/admin/${id}`, {
          method: "DELETE",
        });

        cargarMenu();
      });
    });
  }

  cargarMenu();
});
</script>