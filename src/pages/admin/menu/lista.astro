---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import "../../../styles/admin/menu.css"; // 🔥 IMPORTANTE
---

<AdminLayout title="Menú del sitio">

<div class="mb-3">
  <a href="/admin/menu/nuevo" class="btn btn-primary">
    Nuevo enlace
  </a>
</div>

<div id="menuList" class="menuList"></div>

</AdminLayout>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<script is:inline>
document.addEventListener("DOMContentLoaded", async function () {

  const API = "http://localhost:3000"

  async function cargarMenu(){

    const res = await fetch(
      API + "/api/menu/admin/lista",
      { credentials:"include" }
    )

    const data = await res.json()

    const cont = document.getElementById("menuList")

    cont.innerHTML = data.map(m => `
      <div class="menu-row" data-id="${m.id_menu}">

        <div class="drag-handle">☰</div>

        <div class="menu-info">
          <strong>${m.titulo}</strong>
          <small>${m.url} | ${m.tipo}</small>
        </div>

        <div class="menu-actions">
          <a href="/admin/menu/editar/${m.id_menu}" class="btn btn-sm btn-warning">✏</a>
          <button class="btn btn-sm btn-danger btn-delete" data-id="${m.id_menu}">🗑</button>
        </div>

      </div>
    `).join("")

    initSortable()
    initEliminar()
  }

  function initSortable(){

    const menuList = document.getElementById("menuList")

    new Sortable(menuList, {
      animation: 200,
      handle: ".drag-handle",
      ghostClass: "drag-ghost",
      chosenClass: "drag-chosen",

      onEnd: async function () {

        const items = [...menuList.children]

        const menus = items.map((el, index) => ({
          id_menu: el.dataset.id,
          orden: index + 1
        }))

        await fetch(API + "/api/menu/admin/orden", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ menus })
        })

      }
    })
  }

  function initEliminar(){

    document.querySelectorAll(".btn-delete").forEach(btn => {

      btn.addEventListener("click", async function () {

        const id = this.dataset.id

        if (!confirm("¿Eliminar este enlace del menú?")) return

        await fetch(API + "/api/menu/admin/" + id, {
          method:"DELETE",
          credentials:"include"
        })

        cargarMenu()
      })
    })
  }

  cargarMenu()

})
</script>