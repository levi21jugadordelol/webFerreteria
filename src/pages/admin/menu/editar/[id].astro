---
import AdminLayout from "../../../../layouts/AdminLayout.astro";

const { id } = Astro.params;
---

<AdminLayout title="Editar menú">

<form id="formMenu">

  <!-- Título -->
  <div class="mb-3">
    <label>Título</label>
    <input class="form-control" name="titulo" id="titulo">
  </div>

  <!-- URL -->
  <div class="mb-3">
    <label>URL</label>
    <input class="form-control" name="url" id="url">
  </div>

  <!-- 🔥 MENÚ PADRE -->
  <div class="mb-3">
    <label>Menú padre</label>
    <select id="parentSelect" class="form-control">
      <option value="">Sin padre (nivel principal)</option>
    </select>
  </div>

  <!-- Activo -->
  <div class="form-check mb-3">
    <input type="checkbox" class="form-check-input" id="activo">
    <label class="form-check-label">Activo</label>
  </div>

  <button class="btn btn-success">
    Guardar cambios
  </button>

</form>

</AdminLayout>

<script is:client>


const id = window.location.pathname.split("/").pop()

const parentSelect = document.getElementById("parentSelect")

/* --------------------------
   CARGAR PADRES
---------------------------*/
async function cargarPadres(){
  const res = await fetch("/api/menu/admin/lista", {
  credentials:"include"
})

  const menus = await res.json()

  menus.forEach(m=>{
    if(m.id_menu == id) return // evitar auto padre

    const option = document.createElement("option")
    option.value = m.id_menu
    option.textContent = m.titulo
    parentSelect.appendChild(option)
  })
}

/* --------------------------
   CARGAR MENU
---------------------------*/
async function cargar(){

 const res = await fetch("/api/menu/admin/" + id, {
  credentials:"include"
})

 const m = await res.json()

 document.getElementById("titulo").value = m.titulo
 document.getElementById("url").value = m.url
 document.getElementById("activo").checked = m.activo

 // 🔥 setear padre
 parentSelect.value = m.parent_id || ""

}

/* --------------------------
   SUBMIT
---------------------------*/
document
.getElementById("formMenu")
.addEventListener("submit", async (e)=>{

 e.preventDefault()

 const data = {
  titulo:document.getElementById("titulo").value,
  url:document.getElementById("url").value,
  activo:document.getElementById("activo").checked,
  parent_id: parentSelect.value || null
 }

await fetch("/api/menu/admin/" + id, {
  method:"PUT",
  headers:{ "Content-Type":"application/json" },
  body:JSON.stringify(data),
  credentials:"include"
})

 window.location="/admin/menu/lista"

})

/* --------------------------
   INIT
---------------------------*/
async function init(){
  await cargarPadres()
  await cargar()
}

init()

</script>