---
import AdminLayout from "../../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Editar menú">
  <form id="formMenu">
    <div class="mb-3">
      <label>Título</label>
      <input class="form-control" name="titulo" id="titulo" />
    </div>

    <div class="mb-3">
      <label>URL</label>
      <input class="form-control" name="url" id="url" />
    </div>

    <div class="mb-3">
      <label>Menú padre</label>
      <select id="parentSelect" class="form-control">
        <option value="">Sin padre (nivel principal)</option>
      </select>
    </div>

    <div class="form-check mb-3">
      <input type="checkbox" class="form-check-input" id="activo" />
      <label class="form-check-label">Activo</label>
    </div>

    <button class="btn btn-success">
      Guardar cambios
    </button>
  </form>
</AdminLayout>

<script>
import {
  getMenuAdmin,
  getMenuAdminById,
  actualizarMenu,
} from "../../../../libs/apis/menu.api";

const id = window.location.pathname.split("/").pop();

const formMenu = document.getElementById("formMenu");
const parentSelect = document.getElementById("parentSelect");
const tituloInput = document.getElementById("titulo");
const urlInput = document.getElementById("url");
const activoInput = document.getElementById("activo");

let menuActual = null;

async function cargarPadres() {
  const menus = await getMenuAdmin();

  menus.forEach((m) => {
    if (String(m.id_menu) === String(id)) return;

    const option = document.createElement("option");
    option.value = String(m.id_menu);
    option.textContent = m.titulo;

    parentSelect.appendChild(option);
  });
}

async function cargar() {
  const m = await getMenuAdminById(id);

  menuActual = m;

  tituloInput.value = m.titulo;
  urlInput.value = m.url;
  activoInput.checked = Boolean(m.activo);

  parentSelect.value = m.parent_id ? String(m.parent_id) : "";
}

formMenu.addEventListener("submit", async (e) => {
  e.preventDefault();

  if (!menuActual) {
    throw new Error("No se pudo cargar el menú actual");
  }

  const data = {
    titulo: tituloInput.value,
    url: urlInput.value,
    tipo: menuActual.tipo,
    orden: menuActual.orden,
    activo: activoInput.checked,
    parent_id: parentSelect.value || null,
  };

  await actualizarMenu(id, data);

  window.location.href = "/admin/menu/lista";
});

async function init() {
  await cargarPadres();
  await cargar();
}

init();
</script>