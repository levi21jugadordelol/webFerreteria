---
import NavBar from "../../components/sections/navBar.astro";

interface Categoria {
  id_categoria: number;
  nombre_categoria: string;
  descripcion: string | null;
  url_imagen: string | null;
}

const apiUrl = "http://localhost:3000";

// Fetch categorías
const res = await fetch(apiUrl + "/categorias");
const categorias: Categoria[] = await res.json();
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Categorías</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>

<body class="bg-light" style="padding-top: 90px;">

  <header>
    <NavBar />
  </header>

  <main class="container py-5">

    <h2 class="mb-4 fw-bold text-center">Categorías</h2>

    <div class="row g-4">

      {categorias.map((c) => (
        <div class="col-6 col-md-4 col-lg-3">
          <a href={`/productos?categoria=${c.id_categoria}`} class="card categoria-card text-decoration-none">

            <div class="categoria-img">
              <img 
                src={c.url_imagen ? `http://localhost:3000/uploads/${c.url_imagen}` : "/img/no-image.png"}
                alt={c.nombre_categoria}
              />
            </div>

            <div class="p-3 text-center">
              <h5 class="text-dark fw-semibold">{c.nombre_categoria}</h5>
            </div>

          </a>
        </div>
      ))}

    </div>

  </main>

</body>
</html>

<style>
.categoria-card {
  background: white;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid #e5e5e5;
  transition: transform .2s, box-shadow .2s;
}

.categoria-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 6px 18px rgba(0,0,0,0.12);
}

.categoria-img {
  width: 100%;
  height: 180px;
  overflow: hidden;
  background: #fff;
}

.categoria-img img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}
</style>
