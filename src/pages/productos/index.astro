---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LayoutToProductos from "../../layouts/index/LayoutToProductos.astro";
import BarraPrecio from "../../components/ui/BarraPrecio.astro";
import FiltroCategoria from "../../components/ui/FiltroCategoria.astro";
import FiltroMarcas from "../../components/ui/FiltroMarcas.astro";
import ProductosCatalogoLayout from "../../layouts/productos/ProductosCatalogoLayout.astro";
import ProductoCardSimpleBtn from "../../components/ui/productos/tarjetaProductoToProductos.astro";

interface Producto {
  id_producto: number;
  nombre_producto: string;
  slug: string;
  descripcion: string;
  precio: number;
  url_imagen: string | null;
  stock_total: number;
  stock_reservado: number;
  stock_disponible: number;
  agotado: boolean;
}

import {
  API_URL,
  UPLOADS_URL
} from "../../config/api";


const getProductImageUrl = (image: string | null = "") => {
  const value = String(image || "").trim();

  if (!value) return "/img/no-image.png";

  if (/^https?:\/\//i.test(value)) {
    return value;
  }

  const clean = value.replace(/^\/?uploads\//, "").replace(/^\/+/, "");

  if (!clean || clean.includes("..")) {
    return "/img/no-image.png";
  }

  return `${UPLOADS_URL}/${encodeURIComponent(clean)}`;
};

const urlParams = Astro.url.searchParams;

const marca = urlParams.get("marca");
const categoria = urlParams.get("categoria");
const maxPrecio = urlParams.get("max");

let backendURL = new URL(`${API_URL}/productos`);

if (maxPrecio && !isNaN(Number(maxPrecio))) {
  backendURL = new URL(`${API_URL}/productos/precio`);
  backendURL.searchParams.set("max", maxPrecio);
} else {
  if (marca) backendURL.searchParams.set("marca", marca);
  if (categoria) backendURL.searchParams.set("categoria", categoria);
}

let productos: Producto[] = [];

try {
  const res = await fetch(backendURL, {
    cache: "no-store",
  });

  if (!res.ok) {
    console.error("Error cargando productos:", res.status, res.statusText);
  } else {
    const result = await res.json();
    productos = result.data ?? [];
  }
} catch (error) {
  console.error("Error cargando productos:", error);
}
---

<BaseLayout title="Productos">

  <LayoutToProductos marca={marca} categoria={categoria}>

    <!-- ASIDE -->
  <!-- ASIDE -->
<BarraPrecio 
  slot="aside"
  marcaActual={marca}
  categoriaActual={categoria}
  maxActual={maxPrecio}
/>

<FiltroCategoria 
  slot="aside"
  marcaActual={marca} 
  categoriaActual={categoria} 
/>

<FiltroMarcas 
  slot="aside"
  marcaActual={marca} 
  categoriaActual={categoria} 
/>


    <!-- CONTENIDO PRINCIPAL -->
    <ProductosCatalogoLayout marca={marca} categoria={categoria}>

      {productos.length === 0 && (
        <p class="catalog-empty">
          No se encontraron productos.
        </p>
      )}

      {productos.length > 0 && (
        <div class="product-grid">
          {productos.map((p) => (
<ProductoCardSimpleBtn
  id={p.id_producto}
  slug={p.slug}
  titulo={p.nombre_producto}
  precio={p.precio}
  stock={p.stock_disponible}
  agotado={p.agotado}
  imagen={{
  src: getProductImageUrl(p.url_imagen),
}}
/>

          ))}
        </div>
      )}

    </ProductosCatalogoLayout>

  </LayoutToProductos>

</BaseLayout>

<script type="module" src="/js/addToCart.js"></script>































