---
import CaracteristicasProductosLayout from "../../layouts/productos/CaracteristicasProductosLayout.astro";

interface ImagenExtra {
  id_imagen: number;
  url: string;
}

interface Caracteristica {
  id_caracteristica: number;
  titulo: string;
  valor: string;
}

const apiUrl = "http://localhost:3000";
const { id } = Astro.params;

// Producto principal
const res = await fetch(`${apiUrl}/productos/${id}`);
const producto = await res.json();

if (!producto || !producto.id_producto) {
  return Astro.redirect("/productos");
}

// Productos relacionados
const relRes = await fetch(`${apiUrl}/productos/${id}/relacionados`);
const relacionados = await relRes.json();
---

<CaracteristicasProductosLayout
  title={producto.nombre_producto}
  description={producto.descripcion}
>
  <div class="row g-5">

    <!-- ===================== -->
    <!-- 🖼️ GALERÍA DE IMÁGENES -->
    <!-- ===================== -->
    <div class="col-md-6">

      <!-- 🔵 IMAGEN PRINCIPAL -->
      <div class="zoom-container border rounded mb-3 position-relative">
        <img
          id="img-principal"
          class="img-fluid"
          src={`${apiUrl}/uploads/${producto.url_imagen}`}
          data-zoom={`${apiUrl}/uploads/${producto.url_imagen}`}
          alt={producto.nombre_producto}
        />
        <div class="zoom-pane"></div>
      </div>

      <!-- 🔵 MINIATURAS -->
      <div class="d-flex gap-2 flex-wrap">

        <!-- 🟢 MINIATURA PRINCIPAL -->
        <img
          src={`${apiUrl}/uploads/${producto.url_imagen}`}
          width="80"
          class="border rounded miniatura"
          data-src={`${apiUrl}/uploads/${producto.url_imagen}`}
          alt="Imagen principal"
        />

        <!-- 🔵 MINIATURAS ADICIONALES -->
        {producto.imagenes?.map((img: ImagenExtra) => (
          <img
            src={`${apiUrl}/uploads/${img.url}`}
            width="80"
            class="border rounded miniatura"
            data-src={`${apiUrl}/uploads/${img.url}`}
            alt="Miniatura del producto"
          />
        ))}
      </div>
    </div>

    <!-- ===================== -->
    <!-- ℹ️ INFO DEL PRODUCTO -->
    <!-- ===================== -->
    <div class="col-md-6">
      <h1 class="fw-bold">{producto.nombre_producto}</h1>
      <p class="fs-4 text-primary fw-semibold">S/ {producto.precio}</p>

      <button class="btn btn-primary btn-lg mb-4">
        Agregar al carrito
      </button>

      <!-- TABS -->
      <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item">
          <button
            class="nav-link active"
            data-bs-toggle="tab"
            data-bs-target="#descripcion"
          >
            Descripción
          </button>
        </li>
        <li class="nav-item">
          <button
            class="nav-link"
            data-bs-toggle="tab"
            data-bs-target="#caracteristicas"
          >
            Características
          </button>
        </li>
      </ul>

      <div class="tab-content border border-top-0 p-4">
        <div class="tab-pane fade show active" id="descripcion">
          <p>{producto.descripcion}</p>
        </div>

        <div class="tab-pane fade" id="caracteristicas">
          <ul class="list-unstyled">
            {producto.caracteristicas?.map((c: Caracteristica) => (
              <li class="mb-2">
                <strong>{c.titulo}:</strong> {c.valor}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- ===================== -->
  <!-- 🔁 PRODUCTOS RELACIONADOS -->
  <!-- ===================== -->
  <hr class="my-5" />
  <h3 class="fw-bold mb-4">Productos relacionados</h3>

  <div class="row g-3">
    {relacionados.map((p: any) => (
      <div class="col-6 col-md-3">
        <a
          href={`/productos/${p.id_producto}`}
          class="text-decoration-none text-dark"
        >
          <div class="card h-100">
            <img
              src={
                p.url_imagen
                  ? `${apiUrl}/uploads/${p.url_imagen}`
                  : "/img/no-image.png"
              }
              class="card-img-top"
              style="height:180px;object-fit:contain"
            />
            <div class="card-body text-center">
              <h6 class="fw-semibold">{p.nombre_producto}</h6>
              <p class="text-primary fw-bold">S/ {p.precio}</p>
            </div>
          </div>
        </a>
      </div>
    ))}
  </div>

  <!-- ===================== -->
  <!-- 🧠 DRIFT SCRIPT -->
  <!-- ===================== -->
  <script type="module" src="/src/scripts/drift-producto.js"></script>

  <style>
    .zoom-container {
      overflow: hidden;
    }

    .miniatura {
      cursor: pointer;
    }

    .miniatura:hover {
      outline: 2px solid #0d6efd;
    }
  </style>

</CaracteristicasProductosLayout>




